    'page callback'    => 'droptime_reassign_confirm_page',
    'access callback'  => 'user_access',
    'access arguments' => array('administer droptime'),
    'file'             => 'droptime.admin.inc',
    'type'             => MENU_CALLBACK,
  );

  // Projects — redirect to DropCRM projects page (projects now live in DropCRM).
