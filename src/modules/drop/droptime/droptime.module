  // Team reports sub-tab — admin/project manager only.
  $items['admin/drop/time/reports/team'] = array(
    'title'            => 'Team',
    'page callback'    => 'droptime_team_reports_page',
    'access callback'  => 'user_access',
    'access arguments' => array('administer droptime'),
    'file'             => 'droptime.pages.inc',
