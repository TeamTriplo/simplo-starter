    'type'             => MENU_CALLBACK,
  );

  return $items;
}

// ---------------------------------------------------------------------------
// Time-log reminder banner
// ---------------------------------------------------------------------------

/**
 * Implements hook_preprocess_layout().
 *
 * Injects a dismissible reminder banner at the top of every Drop admin page
 * when the current user has not created any time entries in the last 24 hours.
 * The banner can be dismissed for 1 hour via a cookie.
 */
function droptime_preprocess_layout(&$variables) {
  global $user;

  // Only for logged-in users with time access.
  if (!$user->uid || !user_access('access droptime')) {
    return;
  }

  // Only on Drop admin pages.
  $path = current_path();
  if (strpos($path, 'admin/drop') !== 0) {
    return;
  }

  // Check the 1-hour dismiss cookie.
  $cookie = 'drop_time_reminder_dismissed';
  if (isset($_COOKIE[$cookie])) {
    $dismissed_at = (int) $_COOKIE[$cookie];
    if ($dismissed_at > (REQUEST_TIME - 3600)) {
      return;
    }
  }

  // Find the most recent time entry created by this user.
  $last_created = db_select('drop_time_entry', 't')
    ->fields('t', array('created'))
    ->condition('t.uid', $user->uid)
    ->orderBy('t.created', 'DESC')
    ->range(0, 1)
    ->execute()
    ->fetchField();

  // Only show if no entry in the last 24 hours.
  if ($last_created && $last_created >= REQUEST_TIME - 86400) {
    return;
  }

  // Calculate how many hours it has been since the last entry.
  if ($last_created) {
    $hours = (int) round((REQUEST_TIME - $last_created) / 3600);
  }
  else {
    $hours = NULL; // No entries at all.
  }

  // Attach CSS and JS.
  backdrop_add_css(backdrop_get_path('module', 'droptime') . '/droptime.css');
  backdrop_add_js(backdrop_get_path('module', 'droptime') . '/droptime.js');

  // Build the banner and prepend it to the layout content.
  $log_link = l(t('Log time now'), 'admin/drop/time');
  $icon     = icon('clock-countdown', array('attributes' => array('width' => 18, 'height' => 18)));
  if ($hours !== NULL) {
    $msg = t('You have not logged any time in the last @hours hours.', array('@hours' => $hours));
  }
  else {
    $msg = t('You have not logged any time yet.');
  }
  $banner   = '<div class="drop-time-reminder" id="drop-time-reminder">'
    . '<span class="drop-time-reminder-icon">' . $icon . '</span>'
    . '<span class="drop-time-reminder-msg">'
    . $msg . ' ' . $log_link
    . '</span>'
    . '<button type="button" class="drop-time-reminder-dismiss" title="' . t('Dismiss for 1 hour') . '">&#x2715;</button>'
    . '</div>';

  $variables['content']['content'] = $banner . $variables['content']['content'];
}

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

/**
 * Formats a duration in minutes as a human-readable string.
 *
 * @param int $minutes
 *   Duration in minutes.
 *
 * @return string
 *   E.g. "1h 30m", "45m", "2h".
 */
function droptime_format_duration($minutes) {
  $minutes = (int) $minutes;
  if ($minutes <= 0) {
    return '0m';
  }
  $h = (int) floor($minutes / 60);
  $m = $minutes % 60;
  if ($h && $m) {
    return $h . 'h ' . $m . 'm';
  }
  return $h ? $h . 'h' : $m . 'm';
}

