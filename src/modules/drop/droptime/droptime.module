/**
 * Implements hook_autoload_info().
 */
function droptime_autoload_info() {
  return array(
    'DropTimeEntry'           => 'droptime.entity.inc',
    'DropTimeEntryController' => 'droptime.entity.inc',
  );
}

// ---------------------------------------------------------------------------
// Entity info
// ---------------------------------------------------------------------------

/**
 * Implements hook_entity_info().
 */
function droptime_entity_info() {
  return array(
    // Note: drop_project entity is now declared in dropcrm_entity_info().
    'drop_time_entry' => array(
      'label'            => t('Time entry'),
      'plural label'     => t('Time entries'),
      'description'      => t('A logged time entry.'),
      'entity class'     => 'DropTimeEntry',
      'controller class' => 'DropTimeEntryController',
      'base table'       => 'drop_time_entry',
      'fieldable'        => FALSE,
      'entity keys'      => array('id' => 'eid'),
      'uri callback'    => 'entity_class_uri',
      'access callback' => 'droptime_entry_access',
      'module'          => 'droptime',
    ),
  );
}

// ---------------------------------------------------------------------------
// Permissions
// ---------------------------------------------------------------------------

/**
 * Implements hook_permission().
 */
function droptime_permission() {
  return array(
    'administer droptime' => array(
      'title'       => t('Administer DropTime'),
      'description' => t('Full access to all time entries and projects.'),
    ),
    'access droptime' => array(
      'title'       => t('Access DropTime'),
      'description' => t('View and log own time entries.'),
    ),
    'choose billable status' => array(
      'title'       => t('Choose billable status on time entries'),
      'description' => t('Shows the billable checkbox when logging time. Without this permission, all time is logged as billable automatically.'),
    ),
  );
}

// ---------------------------------------------------------------------------
// Access callbacks
// ---------------------------------------------------------------------------

/**
 * Access callback for drop_time_entry entities.
 */
function droptime_entry_access($op, $entry = NULL, $account = NULL) {
  global $user;
  if (!$account) {
    $account = $user;
  }
  if (user_access('administer droptime', $account)) {
    return TRUE;
  }
  if (!user_access('access droptime', $account)) {
    return FALSE;
  }
  if ($op === 'create') {
    return TRUE;
  }
  // view / update / delete: must own the entry.
  return $entry && $entry->uid == $account->uid;
}

// ---------------------------------------------------------------------------
// Menu loaders
// ---------------------------------------------------------------------------

/**
 * Menu loader: load a time entry by eid.
 */
function drop_time_entry_load($eid) {
  $entries = entity_load('drop_time_entry', array($eid));
  return $entries ? reset($entries) : FALSE;
}

