  // Reports parent tab.
  $items['admin/drop/time/reports'] = array(
    'title'            => 'Reports',
    'page callback'    => 'droptime_reports_page',
    'access callback'  => 'user_access',
    'access arguments' => array('access droptime'),
    'file'             => 'droptime.pages.inc',
