// ---------------------------------------------------------------------------
// DropCRM integration (formerly droptime_crm sub-module)
// ---------------------------------------------------------------------------

/**
 * Implements hook_dropcrm_contact_view_alter().
 *
 * Adds a Projects section to the CRM contact view page.
 */
function droptime_dropcrm_contact_view_alter(&$output, $contact) {
  $projects = db_select('drop_project', 'p')
    ->fields('p')
    ->condition('p.cid', $contact->cid)
    ->orderBy('p.name', 'ASC')
    ->execute()
    ->fetchAll();

  $rows = array();
  foreach ($projects as $project) {
    $rows[] = array(
      l(check_plain($project->name), 'admin/drop/crm/projects/' . $project->pid . '/edit'),
      $project->active ? t('Active') : t('Inactive'),
    );
  }

  $output['projects'] = array(
    '#type'   => 'container',
    '#weight' => 25,
  );
  $output['projects']['heading'] = array(
    '#markup' => drop_base_section_header(t('Projects')),
    '#weight' => -5,
  );
  $output['projects']['table'] = array(
    '#theme'  => 'table',
    '#header' => array(t('Project'), t('Status')),
    '#rows'   => $rows,
    '#empty'  => t('No projects linked to this contact.'),
  );
}
