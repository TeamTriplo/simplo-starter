}

/**
 * Returns active projects as pid => name options array.
 *
 * Delegates to dropcrm_project_options(). Kept for backward compatibility
 * with any callers within DropTime.
 *
 * @param int $uid
 *   Optional user ID to filter by owner. Pass 0 for all projects.
 *
 * @return array
 */
function droptime_project_options($uid = 0) {
