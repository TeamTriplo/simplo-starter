<?php
/**
 * @file
 * Tests for the DropTime module.
 */

/**
 * Shared base: helpers for creating projects and time entries.
 */
abstract class DropTimeTestBase extends BackdropWebTestCase {

  /** @var object Admin user with 'administer droptime'. */
  protected $adminUser;

  /** @var object Regular user with 'access droptime'. */
  protected $regularUser;

  /** @var object DropProject Test project. */
  protected $project;

  /**
   * Creates and saves a test project.
   */
  protected function createTestProject($name = 'Test Project') {
    $project = entity_create('drop_project', array(
      'name'   => $name,
      'active' => 1,
    ));
    $project->save();
    return $project;
  }

  /**
   * Creates and saves a time entry for the given user.
   *
   * @param int $uid
   * @param array $values
   *   Field overrides.
   *
   * @return DropTimeEntry
   */
  protected function createTestEntry($uid, array $values = array()) {
    $values += array(
      'pid'        => $this->project->pid,
      'uid'        => $uid,
      'entry_date' => date('Y-m-d'),
      'start_time' => '09:00',
      'end_time'   => '10:00',
      'duration'   => 60,
      'notes'      => '',
      'billable'   => 1,
    );
    $entry = entity_create('drop_time_entry', $values);
    $entry->save();
    return $entry;
  }
}

// ---------------------------------------------------------------------------
// CRUD tests
// ---------------------------------------------------------------------------

/**
 * Tests creating, viewing, editing, and deleting time entries.
 */
class DropTimeCRUDTest extends DropTimeTestBase {

  public static function getInfo() {
    return array(
      'name'        => 'DropTime CRUD',
      'description' => 'Create, view, edit, and delete time entries via entity API and UI.',
      'group'       => 'DropTime',
    );
  }

  public function setUp() {
    parent::setUp('drop_base', 'dropcrm', 'entity_plus', 'droptime');

    $this->adminUser = $this->backdropCreateUser(array(
      'administer droptime',
      'access droptime',
      'choose billable status',
    ));
    $this->regularUser = $this->backdropCreateUser(array(
      'access droptime',
    ));
    $this->project = $this->createTestProject();
  }

  /**
   * A newly created entry appears on the daily timesheet.
   */
  public function testEntryAppearsOnTimesheet() {
    $this->createTestEntry($this->regularUser->uid, array('notes' => 'My logged work'));

    $this->backdropLogin($this->regularUser);
    $this->backdropGet('admin/drop/time');

    $this->assertResponse(200);
    $this->assertText('My logged work');
  }

  /**
   * A new entry can be created via the log form on the timesheet page.
   */
  public function testAddEntryViaForm() {
    $this->backdropLogin($this->regularUser);
    $this->backdropPost('admin/drop/time', array(
      'pid'        => $this->project->pid,
      'start_time' => '14:00',
      'end_time'   => '15:30',
      'notes'      => 'Form-created entry',
    ), t('Log time'));

    $this->assertText('Time entry saved.');
    $this->assertText('Form-created entry');
  }

  /**
   * Editing an entry updates its notes.
   */
  public function testEditEntryNotes() {
    $entry = $this->createTestEntry($this->regularUser->uid, array('notes' => 'Original notes'));

    $this->backdropLogin($this->regularUser);
    $this->backdropPost(
      'admin/drop/time/entry/' . $entry->eid . '/edit',
      array('notes' => 'Updated notes'),
      t('Save')
    );

    $this->assertText('Time entry saved.');
    $this->backdropGet('admin/drop/time');
    $this->assertText('Updated notes');
  }

  /**
   * Deleting an entry removes it from the timesheet.
   */
  public function testDeleteEntry() {
    $entry = $this->createTestEntry($this->regularUser->uid, array('notes' => 'Entry to delete'));

    $this->backdropLogin($this->regularUser);
    $this->backdropPost(
      'admin/drop/time/entry/' . $entry->eid . '/delete',
      array(),
      t('Delete')
    );

    $this->assertText('deleted');
    $this->backdropGet('admin/drop/time');
    $this->assertNoText('Entry to delete');
  }

  /**
   * The timesheet shows a total duration summing all entries for the day.
   */
  public function testTimesheetShowsTotalDuration() {
    // Two 1-hour entries = 2h total.
    $this->createTestEntry($this->regularUser->uid, array(
      'start_time' => '09:00',
      'end_time'   => '10:00',
      'duration'   => 60,
    ));
    $this->createTestEntry($this->regularUser->uid, array(
      'start_time' => '10:00',
      'end_time'   => '11:00',
      'duration'   => 60,
    ));

    $this->backdropLogin($this->regularUser);
    $this->backdropGet('admin/drop/time');

    $this->assertText('2h', 'Total duration of 2h appears on the timesheet.');
  }

  /**
   * An entry created via entity API is saved to the DB with correct fields.
   */
  public function testEntryFieldsPersist() {
    $entry = $this->createTestEntry($this->regularUser->uid, array(
      'start_time' => '13:00',
      'end_time'   => '14:30',
      'duration'   => 90,
      'notes'      => 'Persisted notes',
      'billable'   => 1,
    ));

    $loaded = entity_load_single('drop_time_entry', $entry->eid);
    $this->assertEqual('13:00', $loaded->start_time);
    $this->assertEqual('14:30', $loaded->end_time);
    $this->assertEqual(90, (int) $loaded->duration);
    $this->assertEqual('Persisted notes', $loaded->notes);
    $this->assertEqual(1, (int) $loaded->billable);
  }
}

// ---------------------------------------------------------------------------
// Access control tests
// ---------------------------------------------------------------------------

/**
 * Tests that permissions and ownership correctly gate time entry operations.
 */
class DropTimeAccessTest extends DropTimeTestBase {

  public static function getInfo() {
    return array(
      'name'        => 'DropTime Access Control',
      'description' => 'Verifies that permissions and ownership gate time entry operations.',
      'group'       => 'DropTime',
    );
  }

  public function setUp() {
    parent::setUp('drop_base', 'dropcrm', 'entity_plus', 'droptime');

    $this->adminUser = $this->backdropCreateUser(array(
      'administer droptime',
      'access droptime',
    ));
    $this->regularUser = $this->backdropCreateUser(array(
      'access droptime',
    ));
    $this->project = $this->createTestProject();
  }

  /**
   * Anonymous users cannot access the time tracker.
   */
  public function testAnonymousCannotAccessTimeTracker() {
    $this->backdropGet('admin/drop/time');
    $this->assertResponse(403);
  }

  /**
   * A user without 'access droptime' is denied the timesheet.
   */
  public function testUserWithoutPermissionDenied() {
    $noAccess = $this->backdropCreateUser(array());
    $this->backdropLogin($noAccess);
    $this->backdropGet('admin/drop/time');
    $this->assertResponse(403);
  }

  /**
   * A user with 'access droptime' can view the timesheet.
   */
  public function testUserWithPermissionCanAccess() {
    $this->backdropLogin($this->regularUser);
    $this->backdropGet('admin/drop/time');
    $this->assertResponse(200);
  }

  /**
   * An owner can edit their own entry.
   */
  public function testOwnerCanEditEntry() {
    $entry = $this->createTestEntry($this->regularUser->uid);

    $this->backdropLogin($this->regularUser);
    $this->backdropGet('admin/drop/time/entry/' . $entry->eid . '/edit');
    $this->assertResponse(200);
  }

  /**
   * A non-owner cannot edit someone else's entry.
   */
  public function testNonOwnerCannotEditEntry() {
    $other = $this->backdropCreateUser(array('access droptime'));
    $entry = $this->createTestEntry($other->uid);

    $this->backdropLogin($this->regularUser);
    $this->backdropGet('admin/drop/time/entry/' . $entry->eid . '/edit');
    $this->assertResponse(403);
  }

  /**
   * An owner can delete their own entry.
   */
  public function testOwnerCanDeleteEntry() {
    $entry = $this->createTestEntry($this->regularUser->uid);

    $this->backdropLogin($this->regularUser);
    $this->backdropGet('admin/drop/time/entry/' . $entry->eid . '/delete');
    $this->assertResponse(200);
  }

  /**
   * A non-owner cannot delete someone else's entry.
   */
  public function testNonOwnerCannotDeleteEntry() {
    $other = $this->backdropCreateUser(array('access droptime'));
    $entry = $this->createTestEntry($other->uid);

    $this->backdropLogin($this->regularUser);
    $this->backdropGet('admin/drop/time/entry/' . $entry->eid . '/delete');
    $this->assertResponse(403);
  }

  /**
   * An admin can edit any entry regardless of ownership.
   */
  public function testAdminCanEditAnyEntry() {
    $entry = $this->createTestEntry($this->regularUser->uid);

    $this->backdropLogin($this->adminUser);
    $this->backdropGet('admin/drop/time/entry/' . $entry->eid . '/edit');
    $this->assertResponse(200);
  }

  /**
   * The team reports tab is only visible to admins.
   */
  public function testTeamReportsRequiresAdmin() {
    $this->backdropLogin($this->regularUser);
    $this->backdropGet('admin/drop/time/reports/team');
    $this->assertResponse(403);

    $this->backdropLogin($this->adminUser);
    $this->backdropGet('admin/drop/time/reports/team');
    $this->assertResponse(200);
  }

  /**
   * The reassign tab is only accessible to admins.
   */
  public function testReassignRequiresAdmin() {
    $this->backdropLogin($this->regularUser);
    $this->backdropGet('admin/drop/time/reassign');
    $this->assertResponse(403);

    $this->backdropLogin($this->adminUser);
    $this->backdropGet('admin/drop/time/reassign');
    $this->assertResponse(200);
  }
}

// ---------------------------------------------------------------------------
// Duration formatting tests
// ---------------------------------------------------------------------------

/**
 * Tests the droptime_format_duration() helper function.
 */
class DropTimeFormatDurationTest extends BackdropWebTestCase {

  public static function getInfo() {
    return array(
      'name'        => 'DropTime Format Duration',
      'description' => 'Verifies that droptime_format_duration() formats minutes correctly.',
      'group'       => 'DropTime',
    );
  }

  public function setUp() {
    parent::setUp('drop_base', 'dropcrm', 'entity_plus', 'droptime');
  }

  public function testZeroMinutes() {
    $this->assertEqual('0m', droptime_format_duration(0));
  }

  public function testNegativeMinutes() {
    $this->assertEqual('0m', droptime_format_duration(-30));
  }

  public function testMinutesOnly() {
    $this->assertEqual('45m', droptime_format_duration(45));
  }

  public function testExactlyOneHour() {
    $this->assertEqual('1h', droptime_format_duration(60));
  }

  public function testHoursAndMinutes() {
    $this->assertEqual('1h 30m', droptime_format_duration(90));
  }

  public function testMultipleHoursOnly() {
    $this->assertEqual('2h', droptime_format_duration(120));
  }

  public function testMultipleHoursAndMinutes() {
    $this->assertEqual('2h 15m', droptime_format_duration(135));
  }

  public function testLargeDuration() {
    $this->assertEqual('8h', droptime_format_duration(480));
  }
}

// ---------------------------------------------------------------------------
// Reassign entries tests
// ---------------------------------------------------------------------------

/**
 * Tests the admin reassign entries tool.
 */
class DropTimeReassignTest extends DropTimeTestBase {

  public static function getInfo() {
    return array(
      'name'        => 'DropTime Reassign Entries',
      'description' => 'Verifies that the reassign tool moves entries between users correctly.',
      'group'       => 'DropTime',
    );
  }

  public function setUp() {
    parent::setUp('drop_base', 'dropcrm', 'entity_plus', 'droptime');

    $this->adminUser = $this->backdropCreateUser(array(
      'administer droptime',
      'access droptime',
    ));
    $this->regularUser = $this->backdropCreateUser(array(
      'access droptime',
    ));
    $this->project = $this->createTestProject();
  }

  /**
   * Reassigning entries moves them from source to destination user.
   */
  public function testReassignMovesEntries() {
    $source = $this->backdropCreateUser(array('access droptime'));
    $dest   = $this->backdropCreateUser(array('access droptime'));

    // Create 2 entries owned by source.
    $this->createTestEntry($source->uid);
    $this->createTestEntry($source->uid);

    $this->backdropLogin($this->adminUser);

    // Step 1: preview form.
    $this->backdropPost('admin/drop/time/reassign', array(
      'from_uid' => $source->uid,
      'to_uid'   => $dest->uid,
    ), t('Preview'));

    // Step 2: confirm.
    $this->backdropGet('admin/drop/time/reassign/confirm', array(
      'query' => array(
        'from' => $source->uid,
        'to'   => $dest->uid,
      ),
    ));
    $this->backdropPost(NULL, array(), t('Move entries'));

    $this->assertText('Moved 2 time entries');

    // Verify entries now belong to dest.
    $count = db_select('drop_time_entry', 'e')
      ->condition('e.uid', $dest->uid)
      ->countQuery()->execute()->fetchField();
    $this->assertEqual(2, (int) $count, 'Both entries now belong to the destination user.');

    // Verify source has no entries.
    $remaining = db_select('drop_time_entry', 'e')
      ->condition('e.uid', $source->uid)
      ->countQuery()->execute()->fetchField();
    $this->assertEqual(0, (int) $remaining, 'Source user has no entries after reassignment.');
  }

  /**
   * Submitting the reassign form with the same source and destination is rejected.
   */
  public function testReassignSameUserIsRejected() {
    $this->createTestEntry($this->regularUser->uid);

    $this->backdropLogin($this->adminUser);
    $this->backdropPost('admin/drop/time/reassign', array(
      'from_uid' => $this->regularUser->uid,
      'to_uid'   => $this->regularUser->uid,
    ), t('Preview'));

    $this->assertText('Source and destination accounts must be different.');
  }

  /**
   * Reassign with a date range only moves entries within that range.
   */
  public function testReassignWithDateRangeOnlyMovesMatchingEntries() {
    $source = $this->backdropCreateUser(array('access droptime'));
    $dest   = $this->backdropCreateUser(array('access droptime'));

    // Entry in range.
    $this->createTestEntry($source->uid, array('entry_date' => '2030-06-15'));
    // Entry outside range.
    $this->createTestEntry($source->uid, array('entry_date' => '2030-07-01'));

    $this->backdropLogin($this->adminUser);

    $this->backdropGet('admin/drop/time/reassign/confirm', array(
      'query' => array(
        'from'      => $source->uid,
        'to'        => $dest->uid,
        'date_from' => '2030-06-01',
        'date_to'   => '2030-06-30',
      ),
    ));
    $this->backdropPost(NULL, array(), t('Move entries'));

    $this->assertText('Moved 1 time entries');

    // Dest should have 1 entry; source should still have 1.
    $dest_count = db_select('drop_time_entry', 'e')
      ->condition('e.uid', $dest->uid)
      ->countQuery()->execute()->fetchField();
    $this->assertEqual(1, (int) $dest_count, 'Only the in-range entry was moved to destination.');

    $source_count = db_select('drop_time_entry', 'e')
      ->condition('e.uid', $source->uid)
      ->countQuery()->execute()->fetchField();
    $this->assertEqual(1, (int) $source_count, 'Out-of-range entry remains with source user.');
  }

  /**
   * The reassign form shows "No time entries found" when no entries exist.
   */
  public function testReassignFormShowsEmptyMessage() {
    $this->backdropLogin($this->adminUser);
    $this->backdropGet('admin/drop/time/reassign');
    $this->assertText('No time entries found.');
  }
}
