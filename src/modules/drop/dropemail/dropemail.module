<?php
/**
 * @file
 * Drop Email — outgoing email for CRM contacts and support tickets.
 *
 * From any CRM contact page (if a primary email exists), an authorised user
 * can compose and send an email that is immediately logged as a CRM activity.
 *
 * From any ticket page, a user can send an email to the client contact linked
 * to that ticket's project. The sent message is recorded in drop_email_log and
 * as a CRM activity on the contact.
 *
 * The default From address is configurable (drop/admin/dropemail). Senders may
 * override it per-send; when they do, the default support address becomes the
 * Reply-To so replies still land in the support inbox.
 */

// ---------------------------------------------------------------------------
// Core hooks
// ---------------------------------------------------------------------------

/**
 * Implements hook_config_info().
 */
function dropemail_config_info() {
  return array(
    'dropemail.settings' => array(
      'label'  => t('Drop Email settings'),
      'group'  => t('Configuration'),
    ),
  );
}

/**
 * Implements hook_permission().
 */
function dropemail_permission() {
  return array(
    'send dropemail' => array(
      'title'       => t('Send emails via Drop Email'),
      'description' => t('Allows composing and sending outgoing emails from contact and ticket pages.'),
    ),
    'administer dropemail' => array(
      'title'       => t('Administer Drop Email'),
      'description' => t('Configure the default From address and name.'),
    ),
  );
}

/**
 * Implements hook_menu().
 */
function dropemail_menu() {
  $items = array();

  // Compose form: contact page.
  $items['drop/crm/contact/%crm_contact/email'] = array(
    'title'            => 'Send email',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('dropemail_contact_form', 3),
    'access callback'  => '_dropemail_contact_access',
    'access arguments' => array(3),
    'type'             => MENU_CALLBACK,
    'file'             => 'dropemail.pages.inc',
  );

  // Compose form: ticket page.
  $items['drop/tickets/%drop_ticket/email'] = array(
    'title'            => 'Send email to client',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('dropemail_ticket_form', 2),
    'access callback'  => '_dropemail_ticket_access',
    'access arguments' => array(2),
    'type'             => MENU_CALLBACK,
    'file'             => 'dropemail.pages.inc',
  );

  // Settings page.
  $items['drop/admin/dropemail'] = array(
    'title'            => 'Drop Email settings',
    'description'      => 'Configure the default From address and name for outgoing emails.',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('dropemail_settings_form'),
    'access arguments' => array('administer dropemail'),
    'type'             => MENU_NORMAL_ITEM,
    'file'             => 'dropemail.admin.inc',
  );

  return $items;
}

/**
 * Implements hook_mail().
 *
 * Populates the mail message array from $params. Reply-To is set when the
 * sender uses a personal From rather than the default support address.
 */
function dropemail_mail($key, &$message, $params) {
  $message['subject'] = $params['subject'];
  $message['body'][]  = $params['body'];
  if (!empty($params['reply_to'])) {
    $message['headers']['Reply-To'] = $params['reply_to'];
  }
}

// ---------------------------------------------------------------------------
// Access callbacks
// ---------------------------------------------------------------------------

/**
 * Access callback for the contact email form.
 */
function _dropemail_contact_access($contact) {
  if (!user_access('send dropemail')) {
    return FALSE;
  }
  return (bool) dropemail_get_contact_primary_email($contact);
}

/**
 * Access callback for the ticket email form.
 */
function _dropemail_ticket_access($ticket) {
  return user_access('send dropemail');
}

// ---------------------------------------------------------------------------
// Integration: CRM contact hero actions
// ---------------------------------------------------------------------------

/**
 * Implements hook_dropcrm_contact_hero_actions_alter().
 *
 * Appends a "Send email" link to the contact hero action buttons when the
 * contact has a primary email address.
 */
function dropemail_dropcrm_contact_hero_actions_alter(&$actions, $contact) {
  if (!user_access('send dropemail')) {
    return;
  }
  $email = dropemail_get_contact_primary_email($contact);
  if ($email) {
    $actions[] = l(t('Send email'), 'drop/crm/contact/' . $contact->cid . '/email');
  }
}

// ---------------------------------------------------------------------------
// Integration: ticket view
// ---------------------------------------------------------------------------

/**
 * Implements hook_droptickets_ticket_view_alter().
 *
 * Adds a "Send email to client" action and an email correspondence log to
 * the ticket view page.
 */
function dropemail_droptickets_ticket_view_alter(&$output, $ticket) {
  // Show the send button whenever the user has permission — they can add any
  // contact as a recipient on the form itself.
  if (user_access('send dropemail')) {
    $output['dropemail_action'] = array(
      '#markup' => '<div class="dropemail-ticket-action">'
        . l(t('Send email'), 'drop/tickets/' . $ticket->tid . '/email',
            array('attributes' => array('class' => array('dropemail-send-btn'))))
        . '</div>',
      '#weight' => -8,
    );
  }

  // Correspondence section — shown even when $email is missing so old logs are
  // still visible if the contact email was later removed.
  $logs = dropemail_load_ticket_emails($ticket->tid);
  if ($logs) {
    $rows = array();
    foreach ($logs as $log) {
      $sender = db_select('users', 'u')
        ->fields('u', array('name'))
        ->condition('u.uid', $log->uid)
        ->execute()
        ->fetchField();
      $rows[] = array(
        format_date($log->sent_at, 'custom', 'M j, Y g:ia'),
        check_plain($log->from_email),
        check_plain($log->subject),
        check_plain($sender ?: t('Unknown')),
        $log->status === 'sent'
          ? '<span class="dropemail-status dropemail-status--sent">' . t('Sent') . '</span>'
          : '<span class="dropemail-status dropemail-status--failed">' . t('Failed') . '</span>',
      );
    }
    $output['dropemail_correspondence'] = array(
      '#weight' => 10,
      '#prefix' => '<div class="dropemail-correspondence">',
      '#suffix' => '</div>',
      '#attached' => array(
        'css' => array(backdrop_get_path('module', 'dropemail') . '/dropemail.css'),
      ),
      'heading' => array(
        '#markup' => drop_base_section_header(t('Email Correspondence')),
        '#weight' => -5,
      ),
      'table' => array(
        '#theme'  => 'table',
        '#header' => array(t('Sent'), t('From'), t('Subject'), t('By'), t('Status')),
        '#rows'   => $rows,
      ),
    );
  }
}

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

/**
 * Returns the configured default From address and name.
 *
 * @return array
 *   Keys: 'address' and 'name'.
 */
function dropemail_get_default_from() {
  return array(
    'address' => config_get('dropemail.settings', 'from_address') ?: 'support@triplo.co',
    'name'    => config_get('dropemail.settings', 'from_name') ?: 'Support',
  );
}

/**
 * Returns the primary email address for a CRM contact, or NULL.
 *
 * @param object $contact
 *   CrmContact entity.
 *
 * @return string|NULL
 */
function dropemail_get_contact_primary_email($contact) {
  $value = db_select('crm_contact_method', 'cm')
    ->fields('cm', array('value'))
    ->condition('cm.cid', $contact->cid)
    ->condition('cm.type', 'email')
    ->condition('cm.is_primary', 1)
    ->range(0, 1)
    ->execute()
    ->fetchField();
  return $value ?: NULL;
}

/**
 * Returns the primary email for the client contact linked to a ticket.
 *
 * Path: ticket → project → contact → primary email.
 *
 * @param object $ticket
 *   DropTicket entity.
 *
 * @return string|NULL
 */
function dropemail_get_ticket_client_email($ticket) {
  // For inbound tickets, the sender's address is always available.
  if (!empty($ticket->inbound_email)) {
    return $ticket->inbound_email;
  }

  if (empty($ticket->pid)) {
    return NULL;
  }
  $cid = db_select('drop_project', 'p')
    ->fields('p', array('cid'))
    ->condition('p.pid', $ticket->pid)
    ->execute()
    ->fetchField();
  if (!$cid) {
    return NULL;
  }
  $contact = crm_contact_load($cid);
  if (!$contact) {
    return NULL;
  }

  // Try the contact's own primary email first.
  $email = dropemail_get_contact_primary_email($contact);
  if ($email) {
    return $email;
  }

  // For organizations, fall back to the first affiliated person with an email.
  if ($contact->bundle() === 'crm_organization') {
    $affiliated = _dropcrm_load_org_contacts($cid);
    foreach ($affiliated as $person) {
      $person_email = dropemail_get_contact_primary_email($person);
      if ($person_email) {
        return $person_email;
      }
    }
  }

  return NULL;
}

/**
 * Returns the CRM contact linked to a ticket via its project, or NULL.
 *
 * @param object $ticket
 *   DropTicket entity.
 *
 * @return object|NULL
 *   CrmContact entity, or NULL.
 */
function dropemail_get_ticket_client_contact($ticket) {
  if (empty($ticket->pid)) {
    return NULL;
  }
  $cid = db_select('drop_project', 'p')
    ->fields('p', array('cid'))
    ->condition('p.pid', $ticket->pid)
    ->execute()
    ->fetchField();
  return $cid ? crm_contact_load($cid) : NULL;
}

/**
 * Sends an email and writes a log row.
 *
 * @param array $params
 *   Keys: to, from_email, subject, body, cid (optional), tid (optional),
 *   skip_activity (optional bool — skip activity creation, used when the
 *   caller will create a shared multi-contact activity instead).
 *
 * @return int|FALSE
 *   The new eid on success, or FALSE on failure.
 */
function dropemail_send_and_log(array $params) {
  global $user;

  $default    = dropemail_get_default_from();
  $from_email = trim($params['from_email']);
  $from_name  = $default['name'];

  // Build the RFC 5321 From string.
  $from_header = $from_name
    ? '"' . addslashes($from_name) . '" <' . $from_email . '>'
    : $from_email;

  // Reply-To: only set when sender is NOT the default support address.
  $reply_to = ($from_email !== $default['address']) ? $default['address'] : '';

  $mail_params = array(
    'subject'  => $params['subject'],
    'body'     => $params['body'],
    'reply_to' => $reply_to,
  );

  $result = backdrop_mail(
    'dropemail',
    'compose',
    $params['to'],
    language_default(),
    $mail_params,
    $from_header
  );

  $status = (!empty($result['result']) && $result['result'] === TRUE) ? 'sent' : 'failed';

  watchdog('dropemail', '@status: to=%to from=%from subject=%subject',
    array(
      '@status'  => drupal_strtoupper($status),
      '%to'      => $params['to'],
      '%from'    => $from_email,
      '%subject' => $params['subject'],
    ),
    $status === 'sent' ? WATCHDOG_INFO : WATCHDOG_ERROR
  );

  // Log to drop_email_log.
  $eid = db_insert('drop_email_log')
    ->fields(array(
      'uid'        => $user->uid,
      'sent_at'    => REQUEST_TIME,
      'to_email'   => $params['to'],
      'from_email' => $from_email,
      'reply_to'   => $reply_to,
      'subject'    => $params['subject'],
      'body'       => $params['body'],
      'status'     => $status,
      'cid'        => isset($params['cid']) ? $params['cid'] : NULL,
      'tid'        => isset($params['tid']) ? $params['tid'] : NULL,
    ))
    ->execute();

  if ($status !== 'sent') {
    return FALSE;
  }

  // Create a CRM activity for the contact (skipped when caller handles it).
  if (!empty($params['skip_activity'])) {
    return $eid;
  }

  $cid = isset($params['cid']) ? $params['cid'] : NULL;
  if (!$cid && !empty($params['tid'])) {
    // Ticket flow: resolve contact from ticket's project.
    $cid = db_select('drop_project', 'p')
      ->fields('p', array('cid'))
      ->condition('p.pid', db_select('drop_ticket', 't')
        ->fields('t', array('pid'))
        ->condition('t.tid', $params['tid']))
      ->execute()
      ->fetchField();
  }

  $aid = NULL;
  if ($cid) {
    $contact = crm_contact_load($cid);
    if ($contact) {
      $lang = LANGUAGE_NONE;
      $activity = entity_create('crm_activity', array(
        'type'          => 'email',
        'subject'       => $params['subject'],
        'status'        => 'completed',
        'direction'     => 'outbound',
        'activity_date' => REQUEST_TIME,
        'created'       => REQUEST_TIME,
        'uid'           => $user->uid,
      ));
      $activity->field_crm_contacts[$lang][] = array('target_id' => $cid);
      $activity->field_crm_meeting_notes[$lang][] = array(
        'value'  => $params['body'],
        'format' => 'plain_text',
      );
      try {
        $activity->save();
        $aid = $activity->aid;
      }
      catch (Exception $e) {
        watchdog('dropemail', 'Failed to create activity for email eid=%eid: %msg',
          array('%eid' => $eid, '%msg' => $e->getMessage()), WATCHDOG_WARNING);
      }
    }
  }

  // Update log row with the activity ID.
  if ($aid) {
    db_update('drop_email_log')
      ->fields(array('aid' => $aid))
      ->condition('eid', $eid)
      ->execute();
  }

  return $eid;
}

/**
 * Loads email log entries for a ticket, newest first.
 *
 * @param int $tid
 *   Ticket ID.
 *
 * @return array
 *   Array of stdClass log row objects.
 */
function dropemail_load_ticket_emails($tid) {
  return db_select('drop_email_log', 'e')
    ->fields('e')
    ->condition('e.tid', $tid)
    ->orderBy('e.sent_at', 'DESC')
    ->execute()
    ->fetchAll();
}
