function droptasks_update_1003() {
  db_create_table('drop_task_completion', array(
    'description' => 'Logs each completion of a recurring task.',
    'fields' => array(
      'cid' => array(
        'description' => 'Primary key.',
        'type'        => 'serial',
        'unsigned'    => TRUE,
        'not null'    => TRUE,
      ),
      'tid' => array(
        'description' => 'The {drop_task}.tid that was completed.',
        'type'        => 'int',
        'unsigned'    => TRUE,
        'not null'    => TRUE,
        'default'     => 0,
      ),
      'uid' => array(
        'description' => 'The {users}.uid who completed the task.',
        'type'        => 'int',
        'unsigned'    => TRUE,
        'not null'    => TRUE,
        'default'     => 0,
      ),
      'completed' => array(
        'description' => 'Unix timestamp when the task was completed.',
        'type'        => 'int',
        'not null'    => TRUE,
        'default'     => 0,
      ),
    ),
    'primary key' => array('cid'),
    'indexes' => array(
      'tid' => array('tid'),
      'uid' => array('uid'),
    ),
  ));
}

/**
 * Add recurrence columns to drop_task.
 */
function droptasks_update_1002() {
  db_add_field('drop_task', 'recurrence', array(
    'description' => 'Recurrence frequency: empty, daily, weekly, or monthly.',
    'type'        => 'varchar',
    'length'      => 20,
    'not null'    => TRUE,
    'default'     => '',
  ));
  db_add_field('drop_task', 'recurrence_days', array(
    'description' => 'Comma-separated day numbers (0=Sun…6=Sat) for weekly recurrence.',
    'type'        => 'varchar',
    'length'      => 20,
    'not null'    => TRUE,
    'default'     => '',
  ));
  db_add_field('drop_task', 'recurrence_month_type', array(
    'description' => 'Monthly recurrence type: day_of_month or nth_weekday.',
    'type'        => 'varchar',
    'length'      => 20,
    'not null'    => TRUE,
    'default'     => 'day_of_month',
  ));
  db_add_field('drop_task', 'recurrence_month_week', array(
    'description' => 'Which week of the month (1–4 or -1 for last) for nth_weekday monthly.',
    'type'        => 'int',
    'size'        => 'tiny',
    'not null'    => TRUE,
    'default'     => 1,
  ));
  db_add_field('drop_task', 'recurrence_month_weekday', array(
    'description' => 'Day of week (0=Sun…6=Sat) for nth_weekday monthly recurrence.',
    'type'        => 'int',
    'size'        => 'tiny',
    'not null'    => TRUE,
    'default'     => 1,
  ));
}

/**
 * Add contact_id and source_activity_id columns to drop_task.
 */
function droptasks_update_1000() {
  db_add_field('drop_task', 'contact_id', array(
    'description' => 'Optional CRM contact this task is linked to.',
    'type'        => 'int',
    'unsigned'    => TRUE,
    'not null'    => FALSE,
    'default'     => NULL,
  ));
  db_add_field('drop_task', 'source_activity_id', array(
    'description' => 'Optional CRM activity that spawned this task.',
    'type'        => 'int',
    'unsigned'    => TRUE,
    'not null'    => FALSE,
    'default'     => NULL,
  ));
  db_add_index('drop_task', 'contact_id', array('contact_id'));
}
