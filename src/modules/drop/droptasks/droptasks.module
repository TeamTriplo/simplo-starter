/**
 * Implements hook_theme().
 */
function droptasks_theme() {
  return array(
    'droptasks_task_list' => array(
      'variables' => array('tasks' => array(), 'filter' => 'active', 'tag_filter' => ''),
      'file'      => 'droptasks.pages.inc',
    ),
  );
}

/**
 * Implements hook_drop_nav_links().
 */
function droptasks_drop_nav_links() {
  return array(
    array(
      'title'      => t('Tasks'),
      'path'       => 'drop/tasks',
      'permission' => 'access tasks',
      'weight'     => 20,
    ),
  );
}

/**
 * Implements hook_menu_local_tasks_alter().
 *
 * On the main Tasks page, strips all local tasks except admin-only ones.
 * Operational navigation lives in the Drop Section Navigation block.
 */
function droptasks_menu_local_tasks_alter(&$data, $router_item, $root_path) {
  if ($root_path !== 'drop/tasks') {
    return;
  }
  $admin_paths = array('drop/tasks/configure');
  if (!empty($data['tabs'][0]['output'])) {
    foreach ($data['tabs'][0]['output'] as $key => $tab) {
      $href = isset($tab['#link']['href']) ? $tab['#link']['href'] : '';
      if (!in_array($href, $admin_paths)) {
        unset($data['tabs'][0]['output'][$key]);
      }
    }
  }
}

/**
 * Implements hook_drop_section_links().
 */
function droptasks_drop_section_links($section) {
  if ($section !== 'tasks') {
    return array();
  }

  $links = array();

  $links['active'] = array(
    'title'        => t('Active'),
    'href'         => 'drop/tasks',
    'weight'       => -10,
    'active_paths' => array('drop/tasks', 'drop/tasks/active'),
  );

  $links['today'] = array(
    'title'  => t('Today'),
    'href'   => 'drop/tasks/today',
    'weight' => 0,
  );

  $links['upcoming'] = array(
    'title'  => t('Upcoming'),
    'href'   => 'drop/tasks/upcoming',
    'weight' => 10,
  );

  $links['completed'] = array(
    'title'  => t('Completed'),
    'href'   => 'drop/tasks/completed',
    'weight' => 20,
  );

  return $links;
}
