        'id'    => 'gid',
        'label' => 'label',
      ),
      'view modes' => array(
        'full' => array('label' => t('Full'), 'custom settings' => FALSE),
      ),
      'uri callback'    => 'entity_class_uri',
      'access callback' => 'dropgoals_goal_access',
      'module'          => 'dropgoals',
    ),
  );
}

// ---------------------------------------------------------------------------
// Permissions
// ---------------------------------------------------------------------------

/**
 * Implements hook_permission().
 */
function dropgoals_permission() {
  return array(
    'administer goals' => array(
      'title'       => t('Administer goals'),
      'description' => t('Full access to all goals regardless of ownership.'),
    ),
    'access goals' => array(
      'title'       => t('Access goals'),
      'description' => t('View own goals and daily dashboard.'),
    ),
    'manage goals' => array(
      'title'       => t('Manage goals'),
      'description' => t('Create, edit, and delete own goals.'),
    ),
  );
}

// ---------------------------------------------------------------------------
// Access
// ---------------------------------------------------------------------------

/**
 * Access callback for drop_goal entities.
 *
 * @param string $op
 *   One of 'view', 'create', 'update', 'delete'.
 * @param DropGoal|null $goal
 *   The goal entity, or NULL for create checks.
 * @param object|null $account
 *   The user account, or NULL for the current user.
 *
 * @return bool
 */
function dropgoals_goal_access($op, $goal = NULL, $account = NULL) {
  global $user;
  if (!$account) {
    $account = $user;
  }

  if (user_access('administer goals', $account)) {
    return TRUE;
  }

  switch ($op) {
    case 'view':
      return user_access('access goals', $account)
        && (!$goal || $goal->uid == $account->uid);

    case 'create':
      return user_access('manage goals', $account);

    case 'update':
    case 'delete':
      return user_access('manage goals', $account)
        && $goal && $goal->uid == $account->uid;
  }

  return FALSE;
}

// ---------------------------------------------------------------------------
// Menu loader
// ---------------------------------------------------------------------------

/**
 * Menu loader: load a goal by gid.
 *
 * @param int $gid
 *   The goal ID.
 *
 * @return DropGoal|false
 */
function drop_goal_load($gid) {
  $goals = entity_load('drop_goal', array($gid));
  return $goals ? reset($goals) : FALSE;
}

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------

/**
 * Implements hook_menu().
 */
function dropgoals_menu() {
  $items = array();

  // Daily dashboard.
  $items['admin/drop/goals'] = array(
    'title'            => 'Personal Goals',
    'page callback'    => 'dropgoals_dashboard',
    'access callback'  => 'user_access',
    'access arguments' => array('access goals'),
    'file'             => 'dropgoals.pages.inc',
    'type'             => MENU_NORMAL_ITEM,
  );

  // Dashboard as default local task.
  $items['admin/drop/goals/today'] = array(
    'title'            => 'Today',
    'page callback'    => 'dropgoals_dashboard',
    'access callback'  => 'user_access',
    'access arguments' => array('access goals'),
    'file'             => 'dropgoals.pages.inc',
    'type'             => MENU_DEFAULT_LOCAL_TASK,
    'weight'           => 0,
  );

  // Manage goals list.
  $items['admin/drop/goals/manage'] = array(
    'title'            => 'Manage goals',
    'page callback'    => 'dropgoals_goal_manage_list',
    'access callback'  => 'user_access',
    'access arguments' => array('manage goals'),
    'file'             => 'dropgoals.admin.inc',
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 10,
  );

  // Add goal (local action on the manage list).
  $items['admin/drop/goals/manage/add'] = array(
    'title'            => 'Add goal',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('dropgoals_goal_form', NULL),
    'access callback'  => 'dropgoals_goal_access',
    'access arguments' => array('create'),
    'file'             => 'dropgoals.admin.inc',
    'type'             => MENU_LOCAL_ACTION,
  );

  // View goal / history. %drop_goal is at arg position 3.
  $items['admin/drop/goals/manage/%drop_goal'] = array(
    'title callback'   => 'entity_label',
    'title arguments'  => array('drop_goal', 4),
    'page callback'    => 'dropgoals_goal_history',
    'page arguments'   => array(4),
    'access callback'  => 'dropgoals_goal_access',
    'access arguments' => array('view', 4),
    'file'             => 'dropgoals.pages.inc',
  );
  $items['admin/drop/goals/manage/%drop_goal/view'] = array(
    'title'  => 'View',
    'type'   => MENU_DEFAULT_LOCAL_TASK,
    'weight' => 0,
  );

  // Edit goal.
  $items['admin/drop/goals/manage/%drop_goal/edit'] = array(
    'title'            => 'Edit',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('dropgoals_goal_form', 4),
    'access callback'  => 'dropgoals_goal_access',
    'access arguments' => array('update', 4),
    'file'             => 'dropgoals.admin.inc',
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 1,
  );

  // Delete goal.
  $items['admin/drop/goals/manage/%drop_goal/delete'] = array(
    'title'            => 'Delete',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('dropgoals_goal_delete_form', 4),
    'access callback'  => 'dropgoals_goal_access',
    'access arguments' => array('delete', 4),
    'file'             => 'dropgoals.admin.inc',
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 2,
  );

  // Toggle today's completion. %drop_goal at arg position 4.
  $items['admin/drop/goals/toggle/%drop_goal'] = array(
    'title'            => 'Toggle goal',
    'page callback'    => 'dropgoals_toggle_today',
    'page arguments'   => array(4),
    'access callback'  => 'dropgoals_goal_access',
    'access arguments' => array('update', 4),
    'file'             => 'dropgoals.pages.inc',
    'type'             => MENU_CALLBACK,
  );

  // Toggle a specific date's completion (for retroactive logging).
  // %drop_goal at arg 4, date string at arg 5.
  $items['admin/drop/goals/toggle/%drop_goal/%'] = array(
    'title'            => 'Toggle goal date',
    'page callback'    => 'dropgoals_toggle_date',
    'page arguments'   => array(4, 5),
    'access callback'  => 'dropgoals_goal_access',
    'access arguments' => array('update', 4),
    'file'             => 'dropgoals.pages.inc',
    'type'             => MENU_CALLBACK,
  );

  return $items;
}

// ---------------------------------------------------------------------------
// Frequency helpers
// ---------------------------------------------------------------------------

/**
 * Returns human-readable labels for goal frequency options.
 *
 * @return array
 *   Keyed by frequency machine name.
 */
function dropgoals_frequency_labels() {
  return array(
    'daily'         => t('Every day'),
    'weekly'        => t('Once a week'),
    'specific_days' => t('Specific days of the week'),
  );
}

/**
 * Returns TRUE if the goal is due on the given date.
 *
 * For 'specific_days' goals, checks whether the date falls on a selected day.
 * For all other frequencies, returns TRUE (dashboard filtering handles them).
 *
 * @param DropGoal $goal
 * @param string $date
 *   Date string in 'Y-m-d' format.
 *
 * @return bool
 */
function dropgoals_goal_is_due(DropGoal $goal, $date) {
  $frequency = isset($goal->frequency) ? $goal->frequency : 'daily';

  if ($frequency === 'specific_days') {
    $days = !empty($goal->days_of_week) ? explode(',', $goal->days_of_week) : array();
    if (empty($days)) {
      return TRUE; // No days configured yet — show every day as fallback.
    }
    $dow = date('N', strtotime($date)); // 1=Mon, 7=Sun
    return in_array($dow, $days);
  }

  return TRUE;
}

