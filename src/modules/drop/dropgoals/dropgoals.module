  return array(
    'drop_goal' => array(
      'label'            => t('Goal'),
      'plural label'     => t('Goals'),
      'description'      => t('A daily goal definition.'),
      'entity class'     => 'DropGoal',
      'controller class' => 'DropGoalController',
      'base table'       => 'drop_goal',
      'fieldable'        => TRUE,
