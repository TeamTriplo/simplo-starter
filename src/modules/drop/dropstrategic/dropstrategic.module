  return $items;
}

/**
 * Implements hook_menu_alter().
 */
function dropstrategic_menu_alter(&$items) {
  // Push the delete tab to the end.
  if (isset($items['admin/drop/strategic/%drop_goal_strategic/delete'])) {
    $items['admin/drop/strategic/%drop_goal_strategic/delete']['weight'] = 20;
  }
}

/**
 * Entity loader for %drop_goal_strategic wildcard.
 */
function drop_goal_strategic_load($gid) {
  $goals = entity_load('drop_goal_strategic', array($gid));
  return $goals ? reset($goals) : FALSE;
}

/**
 * Title callback for the goal view/edit pages.
 */
function dropstrategic_goal_title(DropGoalStrategic $goal) {
  return $goal->title;
}

/**
 * Access callback for strategic goal operations.
 */
function dropstrategic_goal_access($op, $goal = NULL, $account = NULL) {
  global $user;
  if (!$account) {
    $account = $user;
  }
  if (user_access('administer dropstrategic', $account)) {
    return TRUE;
  }
  if ($op === 'view') {
    return user_access('view strategic goals', $account);
  }
  if ($op === 'create') {
    return user_access('create strategic goals', $account);
  }
  if (($op === 'edit' || $op === 'delete') && $goal) {
    // Owners can edit/delete their own goals.
    return user_access('create strategic goals', $account)
      && (int) $goal->owner_uid === (int) $account->uid;
  }
  return FALSE;
}

// ---------------------------------------------------------------------------
// Key results helpers
// ---------------------------------------------------------------------------

/**
 * Loads all key results for a goal, ordered by weight.
 *
 * @param int $gid
 * @return array
 */
function dropstrategic_key_results_load($gid) {
  return db_select('drop_strategic_key_result', 'kr')
    ->fields('kr')
    ->condition('kr.gid', $gid)
    ->orderBy('kr.weight')
    ->orderBy('kr.krid')
    ->execute()->fetchAll();
}

/**
 * Saves key results for a goal, replacing existing records.
 *
 * @param int $gid
 * @param array $key_results
 *   Array of arrays with keys: title, target, current_value, done, weight.
 */
function dropstrategic_key_results_save($gid, array $key_results) {
  db_delete('drop_strategic_key_result')->condition('gid', $gid)->execute();
  foreach ($key_results as $weight => $kr) {
    $title = trim($kr['title']);
    if ($title === '') {
      continue;
    }
    db_insert('drop_strategic_key_result')->fields(array(
      'gid'           => $gid,
      'title'         => $title,
      'target'        => isset($kr['target']) ? trim($kr['target']) : NULL,
      'current_value' => isset($kr['current_value']) ? trim($kr['current_value']) : NULL,
      'done'          => !empty($kr['done']) ? 1 : 0,
      'weight'        => (int) $weight,
    ))->execute();
  }
}

/**
 * Calculates overall progress percentage from an array of key result objects.
 *
 * For KRs with a numeric target, progress = min(100, current/target * 100).
 * For checkbox-only KRs, progress = 100 if done, 0 if not.
 * Returns the average across all KRs, or 0 if there are none.
 *
 * @param array $key_results
 *   Array of key result objects from dropstrategic_key_results_load().
 * @return int
 *   Progress percentage 0–100.
 */
function dropstrategic_calculate_progress(array $key_results) {
  if (empty($key_results)) {
    return 0;
  }
  $total = 0;
  foreach ($key_results as $kr) {
    if (!empty($kr->target) && is_numeric($kr->target) && (float) $kr->target > 0) {
      $current = !empty($kr->current_value) && is_numeric($kr->current_value)
        ? (float) $kr->current_value : 0;
      $total += min(100, round($current / (float) $kr->target * 100));
    }
    else {
      $total += $kr->done ? 100 : 0;
    }
  }
  return (int) round($total / count($key_results));
}

