}

// ---------------------------------------------------------------------------
// AJAX: key result toggle
// ---------------------------------------------------------------------------

/**
 * Page callback: toggle a key result done/not-done.
 */
function dropstrategic_kr_toggle($krid) {
  backdrop_add_http_header('Content-Type', 'application/json');

  $token = isset($_GET['token']) ? $_GET['token'] : '';
  if (!backdrop_valid_token($token, 'kr-toggle')) {
    print backdrop_json_encode(array('error' => 'invalid token'));
    exit();
  }

  $krid = (int) $krid;
  $kr = db_select('drop_strategic_key_result', 'kr')
    ->fields('kr')
    ->condition('kr.krid', $krid)
    ->execute()->fetchObject();

  if (!$kr) {
    print backdrop_json_encode(array('error' => 'not found'));
    exit();
  }

  // Only admin or goal owner can toggle.
  $goals = entity_load('drop_goal_strategic', array($kr->gid));
  $goal  = $goals ? reset($goals) : NULL;
  if (!$goal || !dropstrategic_goal_access('edit', $goal)) {
    print backdrop_json_encode(array('error' => 'access denied'));
    exit();
  }

  $new_done = $kr->done ? 0 : 1;
  db_update('drop_strategic_key_result')
    ->fields(array('done' => $new_done))
    ->condition('krid', $krid)
    ->execute();

  // Recalculate progress so the JS can update the bar without a page reload.
  $key_results = dropstrategic_key_results_load($kr->gid);
  $progress = dropstrategic_calculate_progress($key_results);

  print backdrop_json_encode(array('krid' => $krid, 'done' => $new_done, 'progress' => $progress));
  exit();
}

