  $items['admin/drop/strategic/%drop_goal_strategic'] = array(
    'title callback'   => 'dropstrategic_goal_title',
    'title arguments'  => array(3),
    'page callback'    => 'dropstrategic_goal_view',
    'page arguments'   => array(3),
    'access arguments' => array('view strategic goals'),
    'load arguments'   => array(3),
    'file'             => 'dropstrategic.pages.inc',
  );

  $items['admin/drop/strategic/%drop_goal_strategic/view'] = array(
    'title'  => 'View',
    'type'   => MENU_DEFAULT_LOCAL_TASK,
    'weight' => 0,
  );

  $items['admin/drop/strategic/%drop_goal_strategic/edit'] = array(
    'title'            => 'Edit',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('dropstrategic_goal_form', 3),
    'access callback'  => 'dropstrategic_goal_access',
    'access arguments' => array('edit', 3),
    'load arguments'   => array(3),
    'file'             => 'dropstrategic.admin.inc',
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 2,
  );

  $items['admin/drop/strategic/%drop_goal_strategic/delete'] = array(
    'title'            => 'Delete',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('dropstrategic_goal_delete_form', 3),
    'access callback'  => 'dropstrategic_goal_access',
    'access arguments' => array('delete', 3),
    'load arguments'   => array(3),
    'file'             => 'dropstrategic.admin.inc',
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 10,
  );

  // Key result toggle (AJAX).
  $items['admin/drop/strategic/kr/%/toggle'] = array(
    'page callback'    => 'dropstrategic_kr_toggle',
    'page arguments'   => array(4),
    'access arguments' => array('view strategic goals'),
    'type'             => MENU_CALLBACK,
