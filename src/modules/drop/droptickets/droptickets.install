/**
 * Ensures the shared drop_tags vocabulary, field base, and drop_ticket
 * field instance all exist. Safe to call on fresh installs and updates.
 */
function _droptickets_ensure_tags_field() {
  // Vocabulary.
  $vocab = taxonomy_vocabulary_machine_name_load('drop_tags');
  if (!$vocab) {
    $vocab = new TaxonomyVocabulary(array(
      'name'         => 'Drop Tags',
      'machine_name' => 'drop_tags',
      'description'  => 'Shared tags used across Drop Suite entities.',
    ));
    taxonomy_vocabulary_save($vocab);
  }

  // Base field (shared with droptasks, dropcrm, etc.).
  if (!field_info_field('field_drop_tags')) {
    field_create_field(array(
      'field_name'  => 'field_drop_tags',
      'type'        => 'taxonomy_term_reference',
      'settings'    => array(
        'allowed_values' => array(
          array('vocabulary' => 'drop_tags', 'parent' => 0),
        ),
      ),
      'cardinality' => FIELD_CARDINALITY_UNLIMITED,
    ));
  }

  // Instance on drop_ticket.
  if (!field_info_instance('drop_ticket', 'field_drop_tags', 'drop_ticket')) {
    field_create_instance(array(
      'field_name'  => 'field_drop_tags',
      'entity_type' => 'drop_ticket',
      'bundle'      => 'drop_ticket',
      'label'       => 'Tags',
      'required'    => FALSE,
      'description' => 'Optional tags. Separate multiple tags with commas.',
      'widget'      => array(
        'type'     => 'taxonomy_autocomplete',
        'settings' => array('size' => 60),
        'weight'   => 21,
      ),
      'display' => array(
        'default' => array(
          'label'  => 'above',
          'type'   => 'taxonomy_term_reference_plain',
          'weight' => 21,
        ),
      ),
    ));
  }
}

/**
 * Implements hook_install().
 *
 * Adds prefix and ticket_counter columns to drop_project, and creates the
 * Team Member role.
 */
function droptickets_install() {
  // Add prefix column to drop_project (may already exist if dropcrm installed).
  if (!db_field_exists('drop_project', 'prefix')) {
    db_add_field('drop_project', 'prefix', array(
      'description' => 'Short prefix for ticket numbers, e.g. TRIP for TRIP-42.',
      'type'        => 'varchar',
      'length'      => 10,
      'not null'    => FALSE,
      'default'     => NULL,
    ));
  }

  // Add ticket_counter column to drop_project.
  if (!db_field_exists('drop_project', 'ticket_counter')) {
    db_add_field('drop_project', 'ticket_counter', array(
      'description' => 'Last ticket number issued for this project.',
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => TRUE,
      'default'     => 0,
    ));
  }

  // Ensure the shared drop_tags vocabulary and field_drop_tags field exist,
  // then attach the field to drop_ticket entities.
  _droptickets_ensure_tags_field();

  // Create the Team Member role if it doesn't already exist.
  $role = user_role_load_by_name('team_member');
  if (!$role) {
    $role = new stdClass();
    $role->name   = 'team_member';
    $role->label  = 'Team Member';
    $role->weight = 3;
    user_role_save($role);
    $role = user_role_load_by_name('team_member');
  }

  // Grant permissions to the Team Member role.
  if ($role) {
    $permissions = array(
      'access droptickets',
      'access droptasks',
      'access droptime',
      'access dropbridge',
    );
    user_role_grant_permissions($role->rid, $permissions);
  }
}

/**
 * Add drop_ticket_relationship table for related tickets.
 */
function droptickets_update_1002() {
  if (!db_table_exists('drop_ticket_relationship')) {
    $schema = array(
      'description' => 'Relationships between tickets.',
      'fields' => array(
        'trid' => array(
          'type'     => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ),
        'tid_a' => array(
          'type'     => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ),
        'tid_b' => array(
          'type'     => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ),
        'type' => array(
          'type'     => 'varchar',
          'length'   => 20,
          'not null' => TRUE,
          'default'  => 'relates_to',
        ),
      ),
      'primary key' => array('trid'),
      'unique keys' => array(
        'pair' => array('tid_a', 'tid_b'),
      ),
      'indexes' => array(
        'tid_a' => array('tid_a'),
        'tid_b' => array('tid_b'),
      ),
    );
    db_create_table('drop_ticket_relationship', $schema);
  }
}

/**
 * Add watcher and notification tables.
 */
function droptickets_update_1003() {
  if (!db_table_exists('drop_ticket_watcher')) {
    $schema = array(
      'description' => 'Users watching a ticket for notifications.',
      'fields' => array(
        'tid' => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'uid' => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
      ),
      'primary key' => array('tid', 'uid'),
      'indexes' => array('uid' => array('uid')),
    );
    db_create_table('drop_ticket_watcher', $schema);
  }
  if (!db_table_exists('drop_notification')) {
    $schema = array(
      'description' => 'Notifications for team members about ticket activity.',
      'fields' => array(
        'nid'       => array('type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE),
        'uid'       => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'tid'       => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'tcid'      => array('type' => 'int', 'unsigned' => TRUE, 'not null' => FALSE, 'default' => NULL),
        'actor_uid' => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'type'      => array('type' => 'varchar', 'length' => 20, 'not null' => TRUE, 'default' => ''),
        'is_read'   => array('type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 0),
        'created'   => array('type' => 'int', 'not null' => TRUE, 'default' => 0),
      ),
      'primary key' => array('nid'),
      'indexes' => array(
        'uid_read' => array('uid', 'is_read'),
        'tid'      => array('tid'),
      ),
    );
    db_create_table('drop_notification', $schema);
  }
}

/**
 * Make drop_ticket entities fieldable (EntityPlus).
 */
function droptickets_update_1001() {
  // No schema changes required — fieldability is declared in hook_entity_info().
  // Flush caches so the updated entity info and Field UI paths are registered.
  backdrop_flush_all_caches();
}

/**
 * Add owner_uid and assignee_mode columns to drop_ticket.
 */
function droptickets_update_1004() {
  if (!db_field_exists('drop_ticket', 'owner_uid')) {
    db_add_field('drop_ticket', 'owner_uid', array(
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => FALSE,
      'default'     => NULL,
      'description' => 'UID of the person responsible for driving the ticket forward.',
    ));
    db_add_index('drop_ticket', 'owner_uid', array('owner_uid'));
  }
  if (!db_field_exists('drop_ticket', 'assignee_mode')) {
    db_add_field('drop_ticket', 'assignee_mode', array(
      'type'        => 'varchar',
      'length'      => 10,
      'not null'    => TRUE,
      'default'     => 'user',
      'description' => 'user, on_hold, or team.',
    ));
  }
}

