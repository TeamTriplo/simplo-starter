/**
 * Add import_id column to drop_ticket and create drop_ticket_import table.
 */
function droptickets_update_1005() {
  if (!db_field_exists('drop_ticket', 'import_id')) {
    db_add_field('drop_ticket', 'import_id', array(
      'type'     => 'varchar',
      'length'   => 64,
      'not null' => FALSE,
      'default'  => NULL,
      'description' => 'Import batch ID if this ticket was created via CSV import.',
    ));
    db_add_index('drop_ticket', 'import_id', array('import_id'));
  }
  if (!db_table_exists('drop_ticket_import')) {
    $schema = array(
      'description' => 'Tracks batches of tickets imported from external sources.',
      'fields' => array(
        'import_id'    => array('type' => 'varchar', 'length' => 64, 'not null' => TRUE, 'default' => ''),
        'pid'          => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'uid'          => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'ticket_count' => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'created'      => array('type' => 'int', 'not null' => TRUE, 'default' => 0),
      ),
      'primary key' => array('import_id'),
      'indexes'     => array('pid' => array('pid')),
    );
    db_create_table('drop_ticket_import', $schema);
  }
}

/**
 * Add field_ticket_files managed-file field to drop_ticket entities.
 */
function droptickets_update_1008() {
  // Create the field if it doesn't exist.
  if (!field_info_field('field_ticket_files')) {
    $field = array(
      'field_name'  => 'field_ticket_files',
      'type'        => 'file',
      'cardinality' => FIELD_CARDINALITY_UNLIMITED,
      'settings'    => array(
        'uri_scheme'        => 'private',
        'display_field'     => FALSE,
        'display_default'   => FALSE,
      ),
    );
    field_create_field($field);
  }

  // Create the instance on drop_ticket if it doesn't exist.
  if (!field_info_instance('drop_ticket', 'field_ticket_files', 'drop_ticket')) {
    $instance = array(
      'field_name'  => 'field_ticket_files',
      'entity_type' => 'drop_ticket',
      'bundle'      => 'drop_ticket',
      'label'       => t('Attachments'),
      'required'    => FALSE,
      'settings'    => array(
        'file_extensions'  => 'pdf doc docx xls xlsx csv txt png jpg jpeg gif zip',
        'file_directory'   => 'tickets',
        'max_filesize'     => '10 MB',
        'description_field' => TRUE,
      ),
      'widget'      => array(
        'type'     => 'file_generic',
        'settings' => array(
          'progress_indicator' => 'throbber',
        ),
        'weight'   => 20,
      ),
      'display'     => array(
        'default' => array(
          'label'  => 'above',
          'type'   => 'file_default',
          'weight' => 20,
        ),
      ),
    );
    field_create_instance($instance);
  }
}

/**
 * Switch field_drop_tags display to taxonomy_term_reference_plain on all entities.
 *
 * The _link formatter assumes $item['taxonomy_term'] is always populated, which
 * fails when field_attach_prepare_view() hasn't been called first. The _plain
 * formatter is used as a fallback; our custom views render tags manually anyway.
 */
/**
 * Create the project_manager role and grant it flag droptickets permission.
 */
/**
 * Migrate priority values from 3-level (0=low,1=normal,2=high) to
 * 5-level (0=none,1=low,2=normal,3=high,4=critical) scale.
 *
 * Old 2 (High) → New 3 (High)
 * Old 1 (Normal) → New 2 (Normal)
 * Old 0 (Low) → New 1 (Low)
 * Must update in descending order to avoid value collisions.
 */
/**
 * Grant flag/close/delete droptickets permissions to the administrator role.
 */
/**
 * Add parent_tid column to drop_ticket for one-level parent/child hierarchy.
 */
/**
 * Add goal_id column to drop_ticket to link tickets to strategic goals.
 */
function droptickets_update_1021() {
  if (!db_field_exists('drop_ticket', 'goal_id')) {
    db_add_field('drop_ticket', 'goal_id', array(
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => TRUE,
      'default'     => 0,
      'description' => 'Linked strategic goal ID, or 0.',
    ));
    db_add_index('drop_ticket', 'goal_id', array('goal_id'));
  }
}

function droptickets_update_1020() {
  if (!db_field_exists('drop_ticket', 'parent_tid')) {
    db_add_field('drop_ticket', 'parent_tid', array(
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => TRUE,
      'default'     => 0,
      'description' => 'Parent ticket ID, or 0 for top-level tickets.',
    ));
    db_add_index('drop_ticket', 'parent_tid', array('parent_tid'));
  }
}

/**
 * Grant 'done droptickets' permission to authenticated users so team members
 * can mark tickets Done independently of the Close (PM-only) action.
 */
function droptickets_update_1019() {
  user_role_grant_permissions('authenticated', array('done droptickets'));
  user_role_grant_permissions('administrator', array('done droptickets'));
}

function droptickets_update_1018() {
  // Create the drop_boards vocabulary (Kanban board definitions).
  if (!taxonomy_vocabulary_load('drop_boards')) {
    $vocab = new TaxonomyVocabulary(array(
      'machine_name' => 'drop_boards',
      'name'         => 'Kanban Boards',
      'description'  => 'Defines which Kanban board(s) a ticket appears on. Tickets with no board assigned appear on the General board automatically.',
    ));
    taxonomy_vocabulary_save($vocab);

    // Create the default "General" board term.
    $term = new TaxonomyTerm(array(
      'name'       => 'General',
      'vocabulary' => 'drop_boards',
    ));
    taxonomy_term_save($term);
  }

  // Create the field_drop_board term-reference field.
  if (!field_info_field('field_drop_board')) {
    field_create_field(array(
      'field_name'  => 'field_drop_board',
      'type'        => 'taxonomy_term_reference',
      'settings'    => array(
        'allowed_values' => array(
          array('vocabulary' => 'drop_boards', 'parent' => 0),
        ),
      ),
      'cardinality' => FIELD_CARDINALITY_UNLIMITED,
    ));
  }

  // Attach instance to drop_ticket.
  if (!field_info_instance('drop_ticket', 'field_drop_board', 'drop_ticket')) {
    field_create_instance(array(
      'field_name'  => 'field_drop_board',
      'entity_type' => 'drop_ticket',
      'bundle'      => 'drop_ticket',
      'label'       => 'Kanban Boards',
      'required'    => FALSE,
      'description' => 'Select which Kanban board(s) this ticket appears on. Leave empty to show on the General board by default.',
      'widget'      => array(
        'type'   => 'options_buttons',
        'weight' => 22,
      ),
      'display' => array(
        'default' => array(
          'label'  => 'hidden',
          'type'   => 'hidden',
          'weight' => 22,
        ),
      ),
    ));
  }
}

function droptickets_update_1017() {
  user_role_grant_permissions('administrator', array(
    'flag droptickets',
    'close droptickets',
    'delete droptickets',
  ));
}

function droptickets_update_1016() {
  db_update('drop_ticket')->fields(array('priority' => 3))->condition('priority', 2)->execute();
  db_update('drop_ticket')->fields(array('priority' => 2))->condition('priority', 1)->execute();
  db_update('drop_ticket')->fields(array('priority' => 1))->condition('priority', 0)->execute();
}

function droptickets_update_1015() {
  if (!user_role_load('project_manager')) {
    $role        = new stdClass();
    $role->name  = 'project_manager';
    $role->label = 'Project Manager';
    $role->weight = 3;
    user_role_save($role);
  }
  user_role_grant_permissions('project_manager', array(
    'access droptickets',
    'flag droptickets',
  ));
}

/**
 * Revert reaction table to utf8mb3 — store ASCII codes, not emoji characters.
 */
function droptickets_update_1014() {
  db_query('ALTER TABLE {drop_ticket_reaction} CONVERT TO CHARACTER SET utf8 COLLATE utf8_general_ci');
}

/**
 * Convert drop_ticket_reaction.emoji column to utf8mb4 for emoji support.
 * (Superseded by 1014 which reverts to ASCII codes instead.)
 */
function droptickets_update_1013() {
  db_query('ALTER TABLE {drop_ticket_reaction} CONVERT TO CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci');
}

/**
 * Add drop_ticket_reaction table and reactions_enabled config.
 */
function droptickets_update_1012() {
  if (!db_table_exists('drop_ticket_reaction')) {
    db_create_table('drop_ticket_reaction', array(
      'description' => 'Emoji reactions on tickets and comments.',
      'fields' => array(
        'rid'     => array('type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE),
        'tid'     => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'tcid'    => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'uid'     => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'emoji'   => array('type' => 'varchar', 'length' => 16, 'not null' => TRUE, 'default' => ''),
        'created' => array('type' => 'int', 'not null' => TRUE, 'default' => 0),
      ),
      'primary key' => array('rid'),
      'unique keys' => array(
        'uid_entity_emoji' => array('uid', 'tid', 'tcid', 'emoji'),
      ),
      'indexes' => array(
        'tid' => array('tid'),
      ),
    ));
  }
  $config = config('droptickets.settings');
  if ($config->get('reactions_enabled') === NULL) {
    $config->set('reactions_enabled', TRUE);
    $config->save();
  }
}

function droptickets_update_1011() {
  foreach (array('drop_ticket', 'drop_task') as $entity_type) {
    $instance = field_info_instance($entity_type, 'field_drop_tags', $entity_type);
    if ($instance) {
      $instance['display']['default']['type'] = 'taxonomy_term_reference_plain';
      field_update_instance($instance);
    }
  }
}

/**
 * Add .md to the allowed file extensions for ticket attachments.
 */
function droptickets_update_1010() {
  $instance = field_info_instance('drop_ticket', 'field_ticket_files', 'drop_ticket');
  if ($instance) {
    $exts = $instance['settings']['file_extensions'];
    if (strpos($exts, 'md') === FALSE) {
      $instance['settings']['file_extensions'] = $exts . ' md';
      field_update_instance($instance);
    }
  }
}

/**
 * Attach the shared field_drop_tags field to drop_ticket entities.
 */
function droptickets_update_1009() {
  if (!field_info_instance('drop_ticket', 'field_drop_tags', 'drop_ticket')) {
    field_create_instance(array(
      'field_name'  => 'field_drop_tags',
      'entity_type' => 'drop_ticket',
      'bundle'      => 'drop_ticket',
      'label'       => 'Tags',
      'required'    => FALSE,
      'description' => 'Optional tags. Separate multiple tags with commas.',
      'widget'      => array(
        'type'     => 'taxonomy_autocomplete',
        'settings' => array('size' => 60),
        'weight'   => 21,
      ),
      'display' => array(
        'default' => array(
          'label'  => 'above',
          'type'   => 'taxonomy_term_reference_link',
          'weight' => 21,
        ),
      ),
    ));
  }
}

/**
 * Implements hook_uninstall().
 */
function droptickets_uninstall() {
  if (db_field_exists('drop_project', 'prefix')) {
    db_drop_field('drop_project', 'prefix');
  }
  if (db_field_exists('drop_project', 'ticket_counter')) {
    db_drop_field('drop_project', 'ticket_counter');
  }
  if (db_table_exists('drop_ticket_relationship')) {
    db_drop_table('drop_ticket_relationship');
  }
  if (db_table_exists('drop_ticket_watcher')) {
    db_drop_table('drop_ticket_watcher');
  }
  if (db_table_exists('drop_notification')) {
    db_drop_table('drop_notification');
  }
  if (db_table_exists('drop_ticket_import')) {
    db_drop_table('drop_ticket_import');
  }
  if (db_table_exists('drop_ticket_flag')) {
    db_drop_table('drop_ticket_flag');
  }
}
