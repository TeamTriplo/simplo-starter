        'description' => 'user, on_hold, or team.',
      ),
      'due_date' => array(
        'type'     => 'int',
        'not null' => FALSE,
        'default'  => NULL,
        'description' => 'Optional due date as a Unix timestamp.',
      ),
      'uid' => array(
        'type'     => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default'  => 0,
        'description' => 'UID of the reporter (creator).',
      ),
      'created' => array('type' => 'int', 'not null' => TRUE, 'default' => 0),
      'changed'  => array('type' => 'int', 'not null' => TRUE, 'default' => 0),
      'import_id' => array(
        'type'        => 'varchar',
        'length'      => 64,
        'not null'    => FALSE,
        'default'     => NULL,
        'description' => 'Import batch ID if this ticket was created via CSV import.',
      ),
      'external_link' => array(
        'type'        => 'varchar',
        'length'      => 512,
        'not null'    => FALSE,
        'default'     => NULL,
        'description' => 'Optional external URL, e.g. original JIRA issue link.',
      ),
      'parent_tid' => array(
        'type'        => 'int',
        'unsigned'    => TRUE,
        'not null'    => TRUE,
        'default'     => 0,
        'description' => 'Parent ticket ID, or 0 for top-level tickets.',
      ),
      'goal_id' => array(
        'type'        => 'int',
        'unsigned'    => TRUE,
        'not null'    => TRUE,
