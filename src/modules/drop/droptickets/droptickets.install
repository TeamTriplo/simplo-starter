      'ticket_number' => array(
        'type'        => 'int',
        'unsigned'    => TRUE,
        'not null'    => TRUE,
        'default'     => 0,
        'description' => 'Per-project sequential ticket number.',
      ),
      'title' => array(
        'type'     => 'varchar',
        'length'   => 255,
        'not null' => TRUE,
        'default'  => '',
      ),
      'body' => array(
        'type'     => 'text',
        'size'     => 'big',
        'not null' => TRUE,
      ),
      'body_format' => array(
        'type'     => 'varchar',
        'length'   => 255,
        'not null' => TRUE,
        'default'  => 'filtered_html',
      ),
      'type' => array(
        'type'     => 'varchar',
        'length'   => 20,
        'not null' => TRUE,
        'default'  => 'task',
        'description' => 'bug, feature, task, improvement.',
      ),
      'status' => array(
        'type'     => 'varchar',
        'length'   => 20,
        'not null' => TRUE,
        'default'  => 'open',
        'description' => 'open, in_progress, in_review, blocked, done.',
      ),
      'priority' => array(
        'type'     => 'int',
        'size'     => 'tiny',
        'not null' => TRUE,
        'default'  => 1,
        'description' => '0=Low, 1=Normal, 2=High.',
      ),
      'owner_uid' => array(
        'type'        => 'int',
        'unsigned'    => TRUE,
        'not null'    => FALSE,
