        ),
      ),
      'uri callback'    => 'entity_class_uri',
      'access callback' => 'droptickets_ticket_access',
      'module'          => 'droptickets',
    ),
    'drop_ticket_comment' => array(
      'label'            => t('Ticket comment'),
      'plural label'     => t('Ticket comments'),
      'description'      => t('A comment on a ticket.'),
      'entity class'     => 'DropTicketComment',
      'controller class' => 'DropTicketCommentController',
      'base table'       => 'drop_ticket_comment',
      'fieldable'        => FALSE,
      'entity keys'      => array('id' => 'tcid'),
      'uri callback'     => 'entity_class_uri',
      'access callback'  => 'droptickets_comment_access',
      'module'           => 'droptickets',
    ),
  );
}

