/**
 * Implements hook_permission().
 */
function droptickets_permission() {
  return array(
    'administer droptickets' => array(
      'title'       => t('Administer DropTickets'),
      'description' => t('Full access to all tickets and projects.'),
    ),
    'access droptickets' => array(
      'title'       => t('Access DropTickets'),
      'description' => t('View and create tickets.'),
    ),
    'flag droptickets' => array(
      'title'       => t('Flag DropTickets'),
      'description' => t('Flag and unflag tickets as priority (Project Manager action).'),
    ),
    'done droptickets' => array(
      'title'       => t('Mark DropTickets as Done'),
      'description' => t('Set a ticket status to Done, indicating work is complete. Can be granted to all team members.'),
    ),
    'close droptickets' => array(
      'title'       => t('Close DropTickets'),
      'description' => t('Permanently close tickets (final PM step after Done). Intended for Project Managers only.'),
    ),
    'delete droptickets' => array(
      'title'       => t('Delete DropTickets'),
      'description' => t('Permanently delete tickets. Intended for Project Managers only.'),
    ),
  );
}

// ---------------------------------------------------------------------------
// Access callbacks
// ---------------------------------------------------------------------------

/**
 * Access callback for drop_ticket entities.
 */
function droptickets_ticket_access($op, $ticket = NULL, $account = NULL) {
  global $user;
  if (!$account) {
    $account = $user;
  }
  if (user_access('administer droptickets', $account)) {
    return TRUE;
  }
  if (!user_access('access droptickets', $account)) {
    return FALSE;
  }
  if (in_array($op, array('view', 'create'))) {
    return TRUE;
  }
  // delete requires explicit permission.
  if ($op === 'delete') {
    return user_access('delete droptickets', $account);
  }
  // update: any authenticated team member with access.
  if ($op === 'update') {
    return TRUE;
  }
  return FALSE;
}

/**
 * Access callback for closing (marking done) a ticket.
 */
function droptickets_done_access($ticket = NULL, $account = NULL) {
  global $user;
  if (!$account) {
    $account = $user;
  }
  // Close permission implies done permission.
  return user_access('administer droptickets', $account)
    || user_access('done droptickets', $account)
    || user_access('close droptickets', $account);
}

function droptickets_close_access($ticket = NULL, $account = NULL) {
  global $user;
  if (!$account) {
    $account = $user;
  }
  return user_access('administer droptickets', $account) || user_access('close droptickets', $account);
}

/**
 * Access callback for drop_ticket_comment entities.
 */
function droptickets_comment_access($op, $comment = NULL, $account = NULL) {
  global $user;
  if (!$account) {
    $account = $user;
  }
  if (user_access('administer droptickets', $account)) {
    return TRUE;
  }
  if (!user_access('access droptickets', $account)) {
    return FALSE;
  }
  if (in_array($op, array('view', 'create'))) {
    return TRUE;
  }
  return $comment && $comment->uid == $account->uid;
}

// ---------------------------------------------------------------------------
// Menu loaders
// ---------------------------------------------------------------------------

/**
 * Menu loader: load a ticket by tid.
 */
function drop_ticket_load($tid) {
  $tickets = entity_load('drop_ticket', array($tid));
  return $tickets ? reset($tickets) : FALSE;
}

/**
 * Menu loader: load a ticket comment by tcid.
 */
function drop_ticket_comment_load($tcid) {
  $comments = entity_load('drop_ticket_comment', array($tcid));
  return $comments ? reset($comments) : FALSE;
}

