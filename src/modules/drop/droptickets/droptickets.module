      'access callback'  => 'user_access',
      'access arguments' => array('administer droptickets'),
      'default_pin'      => FALSE,
    ),
  );
}

/**
 * Implements hook_menu_local_tasks_alter().
 *
 * - Adds a count badge to the Flagged tab when there are flagged tickets.
 * - Adds a CSS class to admin-only tabs so they can be visually de-emphasised.
 */
function droptickets_menu_local_tasks_alter(&$data, $router_item, $root_path) {
  if ($root_path !== 'admin/drop/tickets') {
    return;
  }
  if (empty($data['tabs'][0]['output'])) {
    return;
  }

  $admin_paths = array(
    'admin/drop/tickets/import',
    'admin/drop/tickets/manage/fields',
    'admin/drop/tickets/manage/display',
  );

  $flagged_count = NULL;

  foreach ($data['tabs'][0]['output'] as &$tab) {
    $href = isset($tab['#link']['href']) ? $tab['#link']['href'] : '';

    // Add count badge to the Flagged tab.
    if ($href === 'admin/drop/tickets/flagged') {
      if ($flagged_count === NULL) {
        $flagged_count = (int) db_select('drop_ticket_flag', 'f')->countQuery()->execute()->fetchField();
      }
      if ($flagged_count > 0) {
        $tab['#link']['title'] = check_plain($tab['#link']['title'])
          . ' <span class="droptickets-tab-count">' . $flagged_count . '</span>';
        $tab['#link']['localized_options']['html'] = TRUE;
      }
    }

    // Mark admin-only tabs for CSS de-emphasis.
    if (in_array($href, $admin_paths)) {
      $tab['#link']['localized_options']['attributes']['class'][] = 'droptickets-tab-admin';
    }
  }
}

// ---------------------------------------------------------------------------
// Assignee display helper
// ---------------------------------------------------------------------------

/**
 * Returns the display label for a ticket's assignee.
 *
 * Handles the three assignee modes: a specific user, on_hold, or team.
 *
 * @param object $ticket
 *   The ticket object.
 * @param array $accounts
 *   Preloaded user accounts keyed by uid (optional).
 *
 * @return string
 *   A plain-text or simple HTML label.
 */
function droptickets_assignee_label($ticket, $accounts = array()) {
  $mode = isset($ticket->assignee_mode) ? $ticket->assignee_mode : 'user';
  if ($mode === 'team') {
    return '<span class="droptickets-assignee-mode droptickets-assignee-mode--team">' . t('The Team') . '</span>';
  }
  if ($mode === 'on_hold') {
    return '<span class="droptickets-assignee-mode droptickets-assignee-mode--on-hold">' . t('On Hold') . '</span>';
  }
  if (!empty($ticket->assignee_uid)) {
    if (isset($accounts[$ticket->assignee_uid])) {
      return check_plain($accounts[$ticket->assignee_uid]->name);
    }
    $account = user_load($ticket->assignee_uid);
    return $account ? check_plain($account->name) : '—';
  }
  return '—';
}

// ---------------------------------------------------------------------------
// Cron
// ---------------------------------------------------------------------------

/**
 * Implements hook_cron().
 *
 * Purges old notifications based on the configured lifetime.
 */
function droptickets_cron() {
  // Purge old notifications.
  $days = (int) config_get('droptickets.settings', 'notification_lifetime');
  if ($days > 0) {
    $cutoff = REQUEST_TIME - ($days * 86400);
    db_delete('drop_notification')
      ->condition('created', $cutoff, '<')
      ->execute();
  }

  // Auto-close Done tickets after the configured number of days.
  $auto_close_days = (int) config_get('droptickets.settings', 'auto_close_days');
  if ($auto_close_days > 0) {
    $cutoff = REQUEST_TIME - ($auto_close_days * 86400);
    $tids = db_select('drop_ticket', 't')
      ->fields('t', array('tid'))
      ->condition('t.status', 'done')
      ->condition('t.changed', $cutoff, '<')
      ->execute()
      ->fetchCol();
    if ($tids) {
      db_update('drop_ticket')
        ->fields(array('status' => 'closed', 'changed' => REQUEST_TIME))
        ->condition('tid', $tids, 'IN')
        ->execute();
      watchdog('droptickets', 'Auto-closed @count Done tickets older than @days days.', array(
        '@count' => count($tids),
        '@days'  => $auto_close_days,
      ), WATCHDOG_INFO);
    }
  }
}

// ---------------------------------------------------------------------------
// Watchers and notifications
// ---------------------------------------------------------------------------

/**
 * Returns an array of UIDs watching a ticket.
 */
function droptickets_watchers_get($tid) {
  return db_select('drop_ticket_watcher', 'w')
    ->fields('w', array('uid'))
    ->condition('w.tid', $tid)
    ->execute()
    ->fetchCol();
}

/**
 * Adds a user as a watcher on a ticket (idempotent).
 */
function droptickets_watcher_add($tid, $uid) {
  db_merge('drop_ticket_watcher')
    ->key(array('tid' => $tid, 'uid' => $uid))
    ->fields(array('tid' => $tid, 'uid' => $uid))
    ->execute();
}

/**
 * Removes a user as a watcher on a ticket.
 */
function droptickets_watcher_remove($tid, $uid) {
  db_delete('drop_ticket_watcher')
    ->condition('tid', $tid)
    ->condition('uid', $uid)
    ->execute();
}

/**
 * Creates a single notification record.
 */
function droptickets_notify_create($uid, $tid, $tcid, $type, $actor_uid) {
  db_insert('drop_notification')
    ->fields(array(
      'uid'       => $uid,
      'tid'       => $tid,
      'tcid'      => $tcid,
      'actor_uid' => $actor_uid,
      'type'      => $type,
      'is_read'   => 0,
      'created'   => REQUEST_TIME,
    ))
    ->execute();
}

/**
 * Notifies all watchers of a ticket, skipping the actor.
 */
function droptickets_notify_watchers($tid, $type, $actor_uid, $tcid = NULL) {
  $watchers = droptickets_watchers_get($tid);
  foreach ($watchers as $uid) {
    if ($uid != $actor_uid) {
      droptickets_notify_create($uid, $tid, $tcid, $type, $actor_uid);
    }
  }
}

/**
 * Returns the allowed reactions as code => emoji character.
 *
 * Codes are stored in the DB (ASCII-safe); characters are for display only.
 */
function droptickets_reaction_emojis() {
  return array(
    'thumbsup' => '👍',
    'heart'    => '❤️',
    'tada'     => '🎉',
    'eyes'     => '👀',
  );
}

/**
 * Returns reactions for a ticket or comment, keyed by reaction code then uid.
 *
 * @param int $tid
 *   Ticket ID.
 * @param int $tcid
 *   Comment ID (0 = ticket-level reactions).
 * @return array
 *   Array keyed by reaction code, each value an array of uids.
 */
function droptickets_reactions_get($tid, $tcid = 0) {
  $rows = db_select('drop_ticket_reaction', 'r')
    ->fields('r', array('uid', 'emoji'))
    ->condition('r.tid', $tid)
    ->condition('r.tcid', $tcid)
    ->execute()
    ->fetchAll();

  $by_code = array();
  foreach (array_keys(droptickets_reaction_emojis()) as $code) {
    $by_code[$code] = array();
  }
  foreach ($rows as $row) {
    if (isset($by_code[$row->emoji])) {
      $by_code[$row->emoji][] = (int) $row->uid;
    }
  }
  return $by_code;
}

/**
 * Returns the unread notification count for a user.
 */
function droptickets_unread_count($uid) {
  return (int) db_select('drop_notification', 'n')
    ->condition('n.uid', $uid)
    ->condition('n.is_read', 0)
    ->countQuery()
    ->execute()
    ->fetchField();
}

// ---------------------------------------------------------------------------
// Review / triage helpers
// ---------------------------------------------------------------------------

/**
 * Returns the set of tids the current user has marked as reviewed.
 *
 * @param int $uid
 *
 * @return array
 *   Flat array of integer ticket IDs.
 */
function droptickets_review_get($uid) {
  $all = state_get('droptickets.reviewed', array());
  return isset($all[$uid]) && is_array($all[$uid]) ? $all[$uid] : array();
}

/**
 * Toggles the reviewed state of a ticket for a user.
 *
 * @param int $uid
 * @param int $tid
 *
 * @return bool
 *   TRUE if the ticket is now reviewed, FALSE if it was unmarked.
 */
function droptickets_review_toggle_state($uid, $tid) {
  $all  = state_get('droptickets.reviewed', array());
  $pins = isset($all[$uid]) && is_array($all[$uid]) ? $all[$uid] : array();
  if (in_array($tid, $pins)) {
    $pins = array_values(array_diff($pins, array($tid)));
    $reviewed = FALSE;
  }
  else {
    $pins[]   = $tid;
    $reviewed = TRUE;
  }
  $all[$uid] = $pins;
  state_set('droptickets.reviewed', $all);
  return $reviewed;
}

/**
 * Clears all reviewed flags for a user.
 *
 * @param int $uid
 */
function droptickets_review_clear_all($uid) {
  $all = state_get('droptickets.reviewed', array());
  unset($all[$uid]);
  state_set('droptickets.reviewed', $all);
}

/**
 * Returns the review mode state for a user, or FALSE if not active.
 *
 * @param int $uid
 * @return array|false  Array with keys 'active', 'pid', 'tag', or FALSE.
 */
function droptickets_review_mode_get($uid) {
  $state = state_get('droptickets.review_mode.' . $uid, array());
  if (empty($state['active'])) {
    return FALSE;
  }
  return $state;
}

/**
 * Activates review mode for a user, saving optional filter values.
 *
 * @param int $uid
 * @param int $pid  Project ID filter (0 = all).
 * @param int $tag  Tag term ID filter (0 = all).
 */
function droptickets_review_mode_set($uid, $pid = 0, $tag = 0, $status = '') {
  state_set('droptickets.review_mode.' . $uid, array(
    'active' => TRUE,
    'pid'    => (int) $pid,
    'tag'    => (int) $tag,
    'status' => (string) $status,
  ));
}

/**
 * Deactivates review mode for a user.
 *
 * @param int $uid
 */
function droptickets_review_mode_clear($uid) {
  state_del('droptickets.review_mode.' . $uid);
}

/**
 * Page callback: marks all of the current user's notifications as read.
 */
function droptickets_mark_all_read() {
  global $user;
  if (!backdrop_valid_token($_GET['token'], 'mark-all-read')) {
    return MENU_ACCESS_DENIED;
  }
  db_update('drop_notification')
    ->fields(array('is_read' => 1))
    ->condition('uid', $user->uid)
    ->condition('is_read', 0)
    ->execute();
  backdrop_set_message(t('All notifications marked as read.'));
  backdrop_goto('admin/drop/notifications');
}

/**
 * Marks all unread notifications for a ticket+user as read.
 */
function droptickets_mark_read_for_ticket($tid, $uid) {
  db_update('drop_notification')
    ->fields(array('is_read' => 1))
    ->condition('tid', $tid)
    ->condition('uid', $uid)
    ->condition('is_read', 0)
    ->execute();
}

/**
 * Implements hook_entity_insert().
 *
 * Auto-adds the assignee as a watcher on ticket creation.
 */
function droptickets_entity_insert($entity, $type) {
  global $user;
  if ($type !== 'drop_ticket') {
    return;
  }
  if (!empty($entity->assignee_uid)) {
    droptickets_watcher_add($entity->tid, $entity->assignee_uid);
  }
  droptickets_track_inline_images($entity);
  droptickets_slack_notify_new_ticket($entity);
}

/**
 * Implements hook_entity_delete().
 *
 * Removes file usage records when a ticket is deleted.
 */
function droptickets_entity_delete($entity, $type) {
  if ($type !== 'drop_ticket') {
    return;
  }
  droptickets_untrack_inline_images($entity->tid);
}

/**
 * Registers file usage for all inline images embedded in a ticket body.
 *
 * Converts absolute public file URLs to stream wrapper URIs, looks up the
 * corresponding fids, marks each file permanent, and adds a usage record so
 * cron will not delete them.
 *
 * @param object $entity
 *   The drop_ticket entity (must have a valid tid).
 */
function droptickets_track_inline_images($entity) {
  if (empty($entity->body) || empty($entity->tid)) {
    return;
  }

  // Build the public files URL prefix (e.g. "https://example.com/files/").
  $public_url = rtrim(file_create_url('public://'), '/') . '/';

  // Extract all img src values from the body HTML.
  preg_match_all('/<img[^>]+src="([^"]+)"/i', $entity->body, $matches);
  $src_list = !empty($matches[1]) ? $matches[1] : array();

  $uris = array();
  foreach ($src_list as $src) {
    if (strpos($src, $public_url) === 0) {
      $uris[] = 'public://' . substr($src, strlen($public_url));
    }
  }

  if (empty($uris)) {
    return;
  }

  $fids = db_select('file_managed', 'f')
    ->fields('f', array('fid'))
    ->condition('f.uri', $uris, 'IN')
    ->execute()
    ->fetchCol();

  foreach ($fids as $fid) {
    $file = file_load($fid);
    if (!$file) {
      continue;
    }
    // Ensure the file is permanent so cron won't garbage-collect it.
    if ($file->status != FILE_STATUS_PERMANENT) {
      $file->status = FILE_STATUS_PERMANENT;
      file_save($file);
    }
    file_usage_add($file, 'droptickets', 'drop_ticket', $entity->tid);
  }
}

/**
 * Removes all inline-image file usage records for the given ticket.
 *
 * Called before re-tracking on update, and on delete. Decrementing usage via
 * file_usage_delete() allows Backdrop's cron to clean up unreferenced files.
 *
 * @param int $tid
 *   The drop_ticket entity ID.
 */
function droptickets_untrack_inline_images($tid) {
  $fids = db_select('file_usage', 'fu')
    ->fields('fu', array('fid'))
    ->condition('fu.module', 'droptickets')
    ->condition('fu.type', 'drop_ticket')
    ->condition('fu.id', $tid)
    ->execute()
    ->fetchCol();

  foreach ($fids as $fid) {
    $file = file_load($fid);
    if ($file) {
      file_usage_delete($file, 'droptickets', 'drop_ticket', $tid);
    }
  }
}

/**
 * Posts a Slack notification when a new ticket is created.
 *
 * @param object $ticket
 *   The newly created drop_ticket entity.
 */
function droptickets_slack_notify_new_ticket($ticket) {
  global $user;

  $webhook_url = config_get('droptickets.settings', 'slack_webhook_url');
  if (empty($webhook_url)) {
    return;
  }

  $silence = &drupal_static('droptickets_silence_slack', FALSE);
  if ($silence) {
    return;
  }

  // Build the ticket label (e.g. "DRP-42").
  $projects = entity_load('drop_project', array($ticket->pid));
  $project  = $projects ? reset($projects) : NULL;
  $label    = droptickets_ticket_label($ticket, $project);
  $proj_name = $project ? $project->name : t('Unknown project');

  $ticket_url = url('admin/drop/tickets/' . $ticket->tid, array('absolute' => TRUE));
  $creator    = check_plain($user->name);

  // Resolve assignee label.
  $mode = isset($ticket->assignee_mode) ? $ticket->assignee_mode : 'user';
  if ($mode === 'team') {
    $assignee_name = t('The Team');
  }
  elseif ($mode === 'on_hold') {
    $assignee_name = t('On Hold');
  }
  elseif (!empty($ticket->assignee_uid)) {
    $assignee_account = user_load($ticket->assignee_uid);
    $assignee_name = $assignee_account ? check_plain($assignee_account->name) : NULL;
  }
  else {
    $assignee_name = NULL;
  }

  $meta = 'Created by ' . $creator . ' · Project: ' . check_plain($proj_name);
  if ($assignee_name) {
    $meta .= ' · Assigned to ' . $assignee_name;
  }

  $text = '*New ticket <' . $ticket_url . '|' . check_plain($label) . '>* — ' . check_plain($ticket->title)
    . "\n" . $meta;

  $payload = backdrop_json_encode(array('text' => $text));

  drupal_http_request($webhook_url, array(
    'method'  => 'POST',
    'data'    => $payload,
    'headers' => array('Content-Type' => 'application/json'),
    'timeout' => 5,
  ));
}

/**
 * Posts a Slack notification when a ticket is assigned or reassigned.
 *
 * @param object $ticket
 *   The updated drop_ticket entity.
 * @param object|null $original
 *   The previous entity state, or NULL if this is a new ticket.
 */
function droptickets_slack_notify_assignment($ticket, $original) {
  global $user;

  $webhook_url = config_get('droptickets.settings', 'slack_webhook_url');
  if (empty($webhook_url)) {
    return;
  }

  $projects  = entity_load('drop_project', array($ticket->pid));
  $project   = $projects ? reset($projects) : NULL;
  $label     = droptickets_ticket_label($ticket, $project);
  $ticket_url = url('admin/drop/tickets/' . $ticket->tid, array('absolute' => TRUE));

  // Resolve the new assignee label.
  $mode = isset($ticket->assignee_mode) ? $ticket->assignee_mode : 'user';
  if ($mode === 'team') {
    $assignee_name = t('The Team');
  }
  elseif ($mode === 'on_hold') {
    $assignee_name = t('On Hold');
  }
  elseif (!empty($ticket->assignee_uid)) {
    $assignee_account = user_load($ticket->assignee_uid);
    $assignee_name = $assignee_account ? check_plain($assignee_account->name) : t('someone');
  }
  else {
    // Unassigned — not worth a Slack ping.
    return;
  }

  $verb = $original ? t('reassigned') : t('assigned');
  $text = '<' . $ticket_url . '|' . check_plain($label) . '> *' . $verb . '* to ' . $assignee_name
    . ' — ' . check_plain($ticket->title)
    . "\nBy " . check_plain($user->name);

  drupal_http_request($webhook_url, array(
    'method'  => 'POST',
    'data'    => backdrop_json_encode(array('text' => $text)),
    'headers' => array('Content-Type' => 'application/json'),
    'timeout' => 5,
  ));
}

/**
 * Implements hook_entity_update().
 *
 * Triggers notifications on assignment change, status/priority change.
 */
function droptickets_entity_update($entity, $type) {
  global $user;
  if ($type !== 'drop_ticket') {
    return;
  }
  // Refresh file usage tracking whenever the body is saved.
  droptickets_untrack_inline_images($entity->tid);
  droptickets_track_inline_images($entity);
  $original = isset($entity->original) ? $entity->original : NULL;

  // Assignee changed — auto-watch new assignee and notify them.
  $assignee_changed = $original && (
    $entity->assignee_uid != $original->assignee_uid ||
    (isset($entity->assignee_mode) && isset($original->assignee_mode) && $entity->assignee_mode !== $original->assignee_mode)
  );
  if ($assignee_changed) {
    if (!empty($entity->assignee_uid)) {
      droptickets_watcher_add($entity->tid, $entity->assignee_uid);
      if ($entity->assignee_uid != $user->uid) {
        droptickets_notify_create($entity->assignee_uid, $entity->tid, NULL, 'assigned', $user->uid);
      }
    }
    droptickets_slack_notify_assignment($entity, $original);
  }

  // Status or priority changed — notify all watchers.
  $status_changed   = $original && $entity->status !== $original->status;
  $priority_changed = $original && $entity->priority != $original->priority;
  if ($status_changed || $priority_changed) {
    droptickets_notify_watchers($entity->tid, 'updated', $user->uid);
  }
}

/**
 * Implements hook_drop_nav_extras().
 *
 * Adds the notification bell to the Drop nav bar.
 */
function droptickets_drop_nav_extras() {
  global $user;
  if (!$user->uid || !user_access('access droptickets')) {
    return array();
  }
  $count = droptickets_unread_count($user->uid);
  $bell  = icon('bell', array('attributes' => array('width' => 18, 'height' => 18)));
  $badge = $count > 0
    ? ' <span class="drop-nav-bell-count">' . (int) $count . '</span>'
    : '';
  $class = 'drop-nav-bell' . ($count > 0 ? ' drop-nav-bell--active' : '');
  return array(
    '<a href="' . url('admin/drop/notifications') . '" class="' . $class . '" title="' . t('Notifications') . '">' . $bell . $badge . '</a>',
  );
}

// ---------------------------------------------------------------------------
// Schema alter — add prefix and ticket_counter to drop_project
// ---------------------------------------------------------------------------

/**
 * Implements hook_schema_alter().
 */
function droptickets_schema_alter(&$schema) {
  if (isset($schema['drop_project'])) {
    $schema['drop_project']['fields']['prefix'] = array(
      'description' => 'Short ticket prefix, e.g. TRIP for TRIP-42.',
      'type'        => 'varchar',
      'length'      => 10,
      'not null'    => FALSE,
      'default'     => NULL,
    );
    $schema['drop_project']['fields']['ticket_counter'] = array(
      'description' => 'Last ticket number issued for this project.',
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => TRUE,
      'default'     => 0,
    );
  }
}

// ---------------------------------------------------------------------------
// Project form integration
// ---------------------------------------------------------------------------

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Adds prefix field to the DropCRM project form.
 */
function droptickets_form_dropcrm_project_form_alter(&$form, &$form_state) {
  $project = isset($form_state['build_info']['args'][0]) ? $form_state['build_info']['args'][0] : NULL;

  $default_prefix = '';
  if ($project && !empty($project->prefix)) {
    $default_prefix = $project->prefix;
  }
  elseif (!$project && !empty($form_state['values']['name'])) {
    $default_prefix = droptickets_suggest_prefix($form_state['values']['name']);
  }

  $form['prefix'] = array(
    '#type'          => 'textfield',
    '#title'         => t('Ticket prefix'),
    '#default_value' => $default_prefix,
    '#size'          => 8,
    '#maxlength'     => 10,
    '#description'   => t('Short uppercase identifier for ticket numbers, e.g. <em>TRIP</em> → TRIP-1, TRIP-2. Leave blank to auto-generate.'),
    '#weight'        => 6,
    '#attributes'    => array('style' => 'text-transform:uppercase;'),
  );

  if (empty($form['#submit'])) {
    $form['#submit'] = array('dropcrm_project_form_submit');
  }
  array_unshift($form['#submit'], 'droptickets_project_form_pre_submit');
}

/**
 * Pre-submit handler: cache the prefix for hook_drop_project_presave().
 */
function droptickets_project_form_pre_submit($form, &$form_state) {
  $raw = strtoupper(trim($form_state['values']['prefix']));

  // Auto-generate from project name if blank.
  if (empty($raw) && !empty($form_state['values']['name'])) {
    $raw = droptickets_suggest_prefix($form_state['values']['name']);
  }

  $pending = &backdrop_static('droptickets_pending_prefix', FALSE);
  $pending = $raw ?: NULL;
}

/**
 * Implements hook_drop_project_presave().
 */
function droptickets_drop_project_presave($project) {
  $pending = &backdrop_static('droptickets_pending_prefix', FALSE);
  if ($pending !== FALSE) {
    $project->prefix = $pending;
    $pending = FALSE;
  }
}

// ---------------------------------------------------------------------------
// Project list integration
// ---------------------------------------------------------------------------

// Note: project list header/row alters are no longer needed — the Prefix
// column is rendered directly in dropcrm_project_list() which now owns
// the project admin UI.

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

/**
 * Suggests a project prefix from the project name.
 *
 * Takes the first letter of each word, uppercased, up to 4 characters.
 * E.g. "Triplo Website" → "TW", "National Parks Traveler" → "NPT".
 *
 * @param string $name
 * @return string
 */
function droptickets_suggest_prefix($name) {
  $words = preg_split('/\s+/', trim($name));
  $prefix = '';
  foreach ($words as $word) {
    if ($word !== '') {
      $prefix .= strtoupper(substr($word, 0, 1));
    }
    if (strlen($prefix) >= 4) {
      break;
    }
  }
  return $prefix;
}

/**
 * Returns the human-readable ticket label, e.g. "TRIP-42" or "#42".
 *
 * @param object $ticket
 *   The ticket entity.
 * @param object|null $project
 *   The loaded drop_project entity, or NULL.
 *
 * @return string
 */
function droptickets_ticket_label($ticket, $project = NULL) {
  if (!$project && !empty($ticket->pid)) {
    $projects = entity_load('drop_project', array($ticket->pid));
    $project  = $projects ? reset($projects) : NULL;
  }
  $prefix = ($project && !empty($project->prefix)) ? $project->prefix : '';
  return $prefix ? $prefix . '-' . $ticket->ticket_number : '#' . $ticket->ticket_number;
}

/**
 * Title callback for the ticket edit page.
 *
 * @param object $ticket
 *   The loaded DropTicket entity.
 *
 * @return string
 */
function droptickets_edit_title(DropTicket $ticket) {
  $label = droptickets_ticket_label($ticket);
  return t('Edit: !label: !title', array('!label' => $label, '!title' => $ticket->title));
}

/**
 * Returns relationship type options.
 */
function droptickets_relationship_type_options() {
  return array(
    'relates_to' => t('Relates to'),
    'blocks'     => t('Blocks'),
    'duplicates' => t('Duplicates'),
  );
}

/**
 * Returns related tickets for a given tid.
 *
 * Each result is a stdClass with: trid, related_tid, type, rel_label.
 *
 * @param int $tid
 * @return array
 */
function droptickets_get_related($tid) {
  $rows = db_select('drop_ticket_relationship', 'r')
    ->fields('r')
    ->condition(db_or()
      ->condition('r.tid_a', $tid)
      ->condition('r.tid_b', $tid)
    )
    ->execute()
    ->fetchAll();

  $type_options = droptickets_relationship_type_options();
  $results = array();
  foreach ($rows as $row) {
    $is_a = ($row->tid_a == $tid);
    $related_tid = $is_a ? $row->tid_b : $row->tid_a;

    if ($row->type === 'blocks') {
      $label = $is_a ? t('Blocks') : t('Blocked by');
    }
    else {
      $label = isset($type_options[$row->type]) ? $type_options[$row->type] : $row->type;
    }

    $results[] = (object) array(
      'trid'        => $row->trid,
      'related_tid' => $related_tid,
      'type'        => $row->type,
      'rel_label'   => $label,
    );
  }
  return $results;
}

/**
 * Autocomplete callback: search tickets by label or title.
 *
 * Returns suggestions in the format "PREFIX-N: Title [tid]".
 *
 * @param string $string
 */
function droptickets_ticket_autocomplete($string) {
  $matches = array();
  if (strlen($string) < 1) {
    backdrop_json_output($matches);
    return;
  }

  // Load all projects for label building.
  $projects = entity_load('drop_project', FALSE);
  $prefix_map = array(); // pid => prefix
  foreach ($projects as $pid => $project) {
    $prefix_map[$pid] = !empty($project->prefix) ? $project->prefix : '';
  }

  $query = db_select('drop_ticket', 't')
    ->fields('t', array('tid', 'pid', 'ticket_number', 'title'))
    ->range(0, 10);

  // Match on title, or on PREFIX-N format if the string looks like one.
  if (preg_match('/^([A-Za-z]+)-?(\d*)$/', $string, $m)) {
    $prefix = strtoupper($m[1]);
    $num    = $m[2];
    // Find pids with this prefix.
    $pids_with_prefix = array();
    foreach ($prefix_map as $pid => $p) {
      if (strtoupper($p) === $prefix) {
        $pids_with_prefix[] = $pid;
      }
    }
    if ($pids_with_prefix) {
      $or = db_or()->condition('t.title', '%' . db_like($string) . '%', 'LIKE');
      $cond = db_and()->condition('t.pid', $pids_with_prefix, 'IN');
      if ($num !== '') {
        $cond->condition('t.ticket_number', (int) $num);
      }
      $or->condition($cond);
      $query->condition($or);
    }
    else {
      $query->condition('t.title', '%' . db_like($string) . '%', 'LIKE');
    }
  }
  else {
    $query->condition('t.title', '%' . db_like($string) . '%', 'LIKE');
  }

  $tickets = $query->execute()->fetchAll();

  foreach ($tickets as $ticket) {
    $prefix = isset($prefix_map[$ticket->pid]) ? $prefix_map[$ticket->pid] : '';
    $label  = $prefix ? $prefix . '-' . $ticket->ticket_number : '#' . $ticket->ticket_number;
    $display = $label . ': ' . $ticket->title . ' [' . $ticket->tid . ']';
    $matches[$display] = $display;
  }

  backdrop_json_output($matches);
}

/**
 * Returns ticket type options.
 */
function droptickets_type_options() {
  return array(
    'bug'         => t('Bug'),
    'feature'     => t('Feature'),
    'task'        => t('Task'),
    'improvement' => t('Improvement'),
  );
}

/**
 * Returns ticket status options.
 */
function droptickets_status_options() {
  return array(
    'icebox'      => t('Icebox'),
    'open'        => t('Open'),
    'todo'        => t('To Do'),
    'in_progress' => t('In Progress'),
    'in_review'   => t('In Review'),
    'blocked'     => t('Blocked'),
    'done'        => t('Done'),
    'closed'      => t('Closed'),
  );
}

/**
 * Returns statuses considered "active" — everything except Icebox and Closed.
 */
function droptickets_active_statuses() {
  return array('open', 'todo', 'in_progress', 'in_review', 'blocked', 'done');
}

/**
 * Returns the statuses shown on the Kanban board (in column order).
 */
function droptickets_kanban_statuses() {
  return array(
    'todo'        => t('To Do'),
    'in_progress' => t('In Progress'),
    'in_review'   => t('In Review'),
    'blocked'     => t('Blocked'),
    'done'        => t('Done'),
  );
}

/**
 * Returns users eligible to be assigned tickets, as uid => display name.
 */
function droptickets_assignee_options() {
  // Backdrop stores roles as machine-name strings in users_roles.role.
  $role_names = array_keys(user_roles(TRUE, 'access droptickets'));
  $admin_names = array_keys(user_roles(TRUE, 'administer droptickets'));
  $roles = array_unique(array_merge($role_names, $admin_names));

  if (empty($roles)) {
    return array();
  }

  $uids = db_select('users_roles', 'ur')
    ->fields('ur', array('uid'))
    ->condition('ur.role', $roles, 'IN')
    ->execute()
    ->fetchCol();

  // Include user 1 (superadmin).
  $uids[] = 1;
  $uids = array_unique($uids);

  $accounts = user_load_multiple($uids);
  $options  = array();
  foreach ($accounts as $account) {
    if ($account->status) {
      $options[$account->uid] = check_plain($account->name);
    }
  }
  asort($options);
  return $options;
}

/**
 * Implements hook_dropcrm_contact_view_alter().
 *
 * Adds a Tickets section to the CRM contact view page, showing open tickets
 * on projects linked to this contact.
 */
function droptickets_dropcrm_contact_view_alter(&$output, $contact) {
  if (!module_exists('droptime_crm')) {
    return;
  }

  // Find project IDs linked to this contact.
  $pids = db_select('drop_project', 'p')
    ->fields('p', array('pid'))
    ->condition('p.cid', $contact->cid)
    ->execute()
    ->fetchCol();

  if (empty($pids)) {
    $rows = array();
  }
  else {
    $tickets = db_select('drop_ticket', 't')
      ->fields('t')
      ->condition('t.pid', $pids, 'IN')
      ->condition('t.status', 'done', '<>')
      ->orderBy('t.priority', 'DESC')
      ->orderBy('t.created', 'ASC')
      ->execute()
      ->fetchAll();

    $projects = entity_load('drop_project', $pids);
    $status_options = droptickets_status_options();
    $rows = array();
    foreach ($tickets as $ticket) {
      $project = isset($projects[$ticket->pid]) ? $projects[$ticket->pid] : NULL;
      $label   = droptickets_ticket_label($ticket, $project);
      $status_label = isset($status_options[$ticket->status]) ? $status_options[$ticket->status] : $ticket->status;
      $rows[] = array(
        array('data' => '<span class="droptickets-ticket-id">' . check_plain($label) . '</span>'),
        l(check_plain($ticket->title), 'admin/drop/tickets/' . $ticket->tid),
        $project ? check_plain($project->name) : '—',
        '<span class="droptickets-status droptickets-status--' . check_plain($ticket->status) . '">' . check_plain($status_label) . '</span>',
      );
    }
  }

  $output['tickets'] = array(
    '#type'   => 'container',
    '#weight' => 30,
    '#attached' => array(
      'css' => array(backdrop_get_path('module', 'droptickets') . '/droptickets.css'),
    ),
  );
  $output['tickets']['heading'] = array(
    '#markup' => drop_base_section_header(
      t('Open Tickets'),
      l(t('+ Add ticket'), 'admin/drop/tickets/add', array('attributes' => array('class' => array('drop-section-add'))))
    ),
    '#weight' => -5,
  );
  $output['tickets']['table'] = array(
    '#theme'  => 'table',
    '#header' => array(t('ID'), t('Title'), t('Project'), t('Status')),
    '#rows'   => $rows,
    '#empty'  => t('No open tickets on projects linked to this contact.'),
  );
}

/**
 * Implements hook_drop_nav_links().
 */
function droptickets_drop_nav_links() {
  return array(
    array(
      'title'      => t('Tickets'),
      'path'       => 'admin/drop/tickets',
      'permission' => 'access droptickets',
      'weight'     => 30,
    ),
  );
}
