/**
 * Implements hook_menu_alter().
 *
 * Pushes Field UI tabs (Manage fields, Manage displays) after the operational
 * tabs by increasing their weight.
 */
function droptickets_menu_alter(&$items) {
  // Push developer/admin tabs to the end so PM tabs stay visible.
  if (isset($items['admin/drop/tickets/manage/fields'])) {
    $items['admin/drop/tickets/manage/fields']['weight'] = 70;
  }
  if (isset($items['admin/drop/tickets/manage/display'])) {
    $items['admin/drop/tickets/manage/display']['weight'] = 71;
  }
}

