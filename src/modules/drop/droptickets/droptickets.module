    'DropTicket'                  => 'droptickets.entity.inc',
    'DropTicketController'        => 'droptickets.entity.inc',
    'DropTicketComment'           => 'droptickets.entity.inc',
    'DropTicketCommentController' => 'droptickets.entity.inc',
  );
}

