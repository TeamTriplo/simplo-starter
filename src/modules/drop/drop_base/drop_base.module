}

/**
 * Implements hook_drop_nav_links().
 */
function drop_base_drop_nav_links() {
  return array(
    array(
      'title'      => t('Team'),
      'path'       => 'drop/team',
      'permission' => 'access drop team',
      'weight'     => 90,
    ),
  );
}

/**
 * Page callback: Team directory.
 *
 * Displays all active team members with their last-seen time.
 */
function drop_base_team_page() {
  backdrop_set_title(t('Team'));

  $accounts = db_select('users', 'u')
    ->fields('u', array('uid', 'name', 'access'))
    ->condition('u.status', 1)
    ->condition('u.uid', 0, '>')
    ->orderBy('u.access', 'DESC')
    ->execute()
    ->fetchAll();

  $can_see_tickets = module_exists('droptickets') && user_access('access droptickets');

  $rows = array();
  foreach ($accounts as $account) {
    $last_seen = $account->access
      ? t('@time ago', array('@time' => format_interval(REQUEST_TIME - $account->access)))
      : t('Never');
    $name = $can_see_tickets
      ? l($account->name, 'drop/tickets/member/' . $account->uid)
      : check_plain($account->name);
    $rows[] = array($name, $last_seen);
  }

  return array(
    '#theme'  => 'table',
    '#header' => array(t('Name'), t('Last online')),
    '#rows'   => $rows,
    '#attributes' => array('class' => array('drop-team-table')),
  );
}

// ---------------------------------------------------------------------------
// Drop Suite permissions page
// ---------------------------------------------------------------------------

/**
 * Page callback: filtered permissions form showing only Drop Suite modules.
 */
function drop_base_permissions_page() {
  module_load_include('inc', 'user', 'user.admin');
  return backdrop_get_form('user_admin_permissions');
}

/**
 * Implements hook_form_user_admin_permissions_alter().
 *
 * When rendering at admin/drop/permissions, strips all non-Drop-Suite
 * permissions so only Drop module rows remain.
 */
function drop_base_form_user_admin_permissions_alter(&$form, &$form_state, $form_id) {
  if (current_path() !== 'admin/drop/permissions') {
    return;
  }

  $drop_modules = array(
    'drop_base',
    'dropcrm',
    'droptasks',
    'dropgoals',
    'dropbridge',
    'droptime',
    'droptickets',
    'dropdocs',
    'dropstrategic',
  );

  // Collect all permission keys that belong to Drop Suite modules.
  $drop_perms = array();
  foreach ($drop_modules as $module) {
    if (module_exists($module)) {
      $perms = module_invoke($module, 'permission');
      if ($perms) {
        foreach (array_keys($perms) as $perm_key) {
          $drop_perms[$perm_key] = TRUE;
        }
      }
    }
  }

  // Remove non-Drop rows from the permission list (module headers and perms).
  foreach (array_keys($form['permission']) as $key) {
    if (is_numeric($key)) {
      // Module header row — keep only Drop Suite module headers.
      if (!in_array($form['permission'][$key]['#id'], $drop_modules)) {
        unset($form['permission'][$key]);
      }
    }
    elseif (!isset($drop_perms[$key])) {
      // Permission row not in Drop Suite — remove it.
      unset($form['permission'][$key]);
    }
  }

  // Filter checkbox options to only Drop Suite permissions.
  foreach (array_keys($form['checkboxes']) as $role_name) {
    $form['checkboxes'][$role_name]['#options'] = array_intersect_key(
      $form['checkboxes'][$role_name]['#options'],
      $drop_perms
    );
    $form['checkboxes'][$role_name]['#default_value'] = array_values(array_intersect(
      $form['checkboxes'][$role_name]['#default_value'],
      array_keys($drop_perms)
    ));
  }
}
