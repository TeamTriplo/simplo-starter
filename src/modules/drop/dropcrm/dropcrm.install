<?php
/**
 * @file
 * Install, update, and uninstall functions for the DropCRM module.
 */

/**
 * Implements hook_schema().
 */
function dropcrm_schema() {
  $schema = array();

  $schema['drop_project'] = array(
    'description' => 'Projects that can be linked to contacts and used for time tracking.',
    'fields' => array(
      'pid' => array(
        'type'     => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'name' => array(
        'type'     => 'varchar',
        'length'   => 255,
        'not null' => TRUE,
        'default'  => '',
        'description' => 'Project name.',
      ),
      'color' => array(
        'type'     => 'varchar',
        'length'   => 7,
        'not null' => TRUE,
        'default'  => '#1565c0',
        'description' => 'Display color as a CSS hex value.',
      ),
      'active' => array(
        'type'     => 'int',
        'size'     => 'tiny',
        'not null' => TRUE,
        'default'  => 1,
        'description' => '1 = active, 0 = archived.',
      ),
      'cid' => array(
        'description' => 'Optional linked DropCRM contact ID.',
        'type'        => 'int',
        'unsigned'    => TRUE,
        'not null'    => FALSE,
        'default'     => NULL,
      ),
      'prefix' => array(
        'description' => 'Short prefix for ticket numbers, e.g. TRIP for TRIP-42.',
        'type'        => 'varchar',
        'length'      => 10,
        'not null'    => FALSE,
        'default'     => NULL,
      ),
      'ticket_counter' => array(
        'description' => 'Auto-incrementing counter for ticket labels within this project.',
        'type'        => 'int',
        'unsigned'    => TRUE,
        'not null'    => TRUE,
        'default'     => 0,
      ),
      'uid' => array(
        'type'     => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default'  => 0,
      ),
      'created' => array('type' => 'int', 'not null' => TRUE, 'default' => 0),
      'changed' => array('type' => 'int', 'not null' => TRUE, 'default' => 0),
    ),
    'primary key' => array('pid'),
    'indexes' => array(
      'uid'    => array('uid'),
      'active' => array('active'),
      'cid'    => array('cid'),
    ),
  );

  $schema['crm_contact'] = array(
    'description' => 'Base table for CRM contacts (persons, organizations, households).',
    'fields' => array(
      'cid' => array(
        'description' => 'Primary key.',
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'type' => array(
        'description' => 'Bundle: crm_person, crm_organization, or crm_household.',
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
      ),
      'name' => array(
        'description' => 'Display name. Computed from first/last for persons; set directly for orgs and households.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ),
      'status' => array(
        'description' => 'Active status: 1 = active, 0 = inactive.',
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 1,
      ),
      'uid' => array(
        'description' => 'User ID of the person who created this contact.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ),
      'created' => array(
        'description' => 'Unix timestamp when the contact was created.',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ),
      'changed' => array(
        'description' => 'Unix timestamp when the contact was last modified.',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ),
    ),
    'primary key' => array('cid'),
    'indexes' => array(
      'type' => array('type'),
      'name' => array('name'),
      'status' => array('status'),
      'uid' => array('uid'),
    ),
  );

  $schema['crm_contact_method'] = array(
    'description' => 'Base table for CRM contact methods: email, telephone, and address.',
    'fields' => array(
      'cmid' => array(
        'description' => 'Primary key.',
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'type' => array(
        'description' => 'Bundle: email, telephone, or address.',
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
      ),
      'cid' => array(
        'description' => 'Foreign key to crm_contact.cid.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ),
      'label' => array(
        'description' => 'Human label for this method, e.g. Work, Home, Mobile.',
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
      ),
      'value' => array(
        'description' => 'The contact method value: email address, phone number, or formatted address.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ),
      'is_primary' => array(
        'description' => 'Whether this is the primary method of this type for the contact.',
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 0,
      ),
      'created' => array(
        'description' => 'Unix timestamp when the contact method was created.',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ),
      'changed' => array(
        'description' => 'Unix timestamp when the contact method was last modified.',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ),
    ),
    'primary key' => array('cmid'),
    'indexes' => array(
      'cid' => array('cid'),
      'type' => array('type'),
      'is_primary' => array('is_primary'),
    ),
  );

  $schema['crm_activity'] = array(
    'description' => 'Base table for CRM activities: logged interactions and planned tasks.',
    'fields' => array(
      'aid' => array(
        'description' => 'Primary key.',
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'type' => array(
        'description' => 'Activity type: call, email, meeting, note, task.',
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => 'note',
      ),
      'subject' => array(
        'description' => 'Short subject or title of the activity.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ),
      'status' => array(
        'description' => 'Activity status: completed or planned.',
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => 'completed',
      ),
      'priority' => array(
        'description' => 'Priority: 0 = normal, 1 = high.',
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 0,
      ),
      'direction' => array(
        'description' => 'Direction for calls and emails: inbound or outbound. Empty for other types.',
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => '',
      ),
      'activity_date' => array(
        'description' => 'Date the activity occurred (Unix timestamp).',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ),
      'due_date' => array(
        'description' => 'Optional due date for planned activities (Unix timestamp). NULL if not set.',
        'type' => 'int',
        'not null' => FALSE,
        'default' => NULL,
      ),
      'is_outreach' => array(
        'description' => 'Whether this activity counts toward the outreach goal: 1 = yes, 0 = no.',
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 0,
      ),
      'uid' => array(
        'description' => 'User ID of the person who created this activity.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ),
      'created' => array(
        'description' => 'Unix timestamp when the activity was created.',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ),
      'changed' => array(
        'description' => 'Unix timestamp when the activity was last modified.',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ),
    ),
    'primary key' => array('aid'),
    'indexes' => array(
      'type' => array('type'),
      'status' => array('status'),
      'priority' => array('priority'),
      'activity_date' => array('activity_date'),
      'uid' => array('uid'),
    ),
  );

  $schema['crm_relationship'] = array(
    'description' => 'Stores person-to-person relationships between CRM contacts.',
    'fields' => array(
      'rid' => array(
        'description' => 'Primary key.',
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'cid_a' => array(
        'description' => 'Foreign key to crm_contact.cid for the first contact.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ),
      'cid_b' => array(
        'description' => 'Foreign key to crm_contact.cid for the second contact.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ),
      'type' => array(
        'description' => 'Relationship type key, e.g. spouse, colleague.',
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
      ),
      'notes' => array(
        'description' => 'Optional notes about this relationship.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ),
      'created' => array(
        'description' => 'Unix timestamp when the relationship was created.',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ),
    ),
    'primary key' => array('rid'),
    'indexes' => array(
      'cid_a' => array('cid_a'),
      'cid_b' => array('cid_b'),
      'type'  => array('type'),
    ),
