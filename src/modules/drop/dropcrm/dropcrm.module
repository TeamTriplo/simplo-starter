/**
 * Implements hook_entity_info().
 */
function dropcrm_entity_info() {
  $info = array();

  // --- crm_contact ---
  $info['crm_contact'] = array(
    'label'         => t('CRM Contact'),
    'plural label'  => t('CRM Contacts'),
    'description'   => t('A person, organization, or household tracked by the CRM.'),
    'entity class'  => 'CrmContact',
    'controller class' => 'CrmContactController',
    'base table'    => 'crm_contact',
    'fieldable'     => TRUE,
    'entity keys'   => array(
      'id'     => 'cid',
      'bundle' => 'type',
      'label'  => 'name',
    ),
    'bundle keys'   => array('bundle' => 'type'),
    'bundles'       => array(
      'crm_person' => array(
        'label' => t('Person'),
        'admin' => array(
          'path'             => 'drop/crm/contacts/manage/crm_person',
          'access arguments' => array('administer crm'),
        ),
      ),
      'crm_organization' => array(
        'label' => t('Organization'),
        'admin' => array(
          'path'             => 'drop/crm/contacts/manage/crm_organization',
          'access arguments' => array('administer crm'),
        ),
      ),
      'crm_household' => array(
        'label' => t('Household'),
        'admin' => array(
          'path'             => 'drop/crm/contacts/manage/crm_household',
          'access arguments' => array('administer crm'),
        ),
      ),
    ),
    'view modes'    => array(
      'full'   => array('label' => t('Full'),   'custom settings' => FALSE),
      'teaser' => array('label' => t('Teaser'), 'custom settings' => TRUE),
    ),
    'uri callback'  => 'entity_class_uri',
    'access callback' => 'dropcrm_contact_access',
    'inline entity form' => array(
      'controller' => 'CrmContactInlineEntityFormController',
