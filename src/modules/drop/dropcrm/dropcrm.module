    'file'             => 'dropcrm.admin.inc',
  );

  // Reports section.
  $items['drop/crm/reports'] = array(
    'title'            => 'Reports',
    'page callback'    => 'dropcrm_reports_page',
    'access arguments' => array('access crm'),
    'file'             => 'dropcrm.admin.inc',
    'type'             => MENU_CALLBACK,
  );
  $items['drop/crm/reports/last-contact'] = array(
    'title'            => 'People by Last Contact',
    'page callback'    => 'dropcrm_report_last_contact',
    'access arguments' => array('access crm'),
    'file'             => 'dropcrm.admin.inc',
    'type'             => MENU_CALLBACK,
  );
  $items['drop/crm/reports/outreach-goal'] = array(
    'title'            => 'Outreach Goal',
    'page callback'    => 'dropcrm_report_outreach_goal',
    'access arguments' => array('access crm'),
