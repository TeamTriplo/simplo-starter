/**
 * Implements hook_menu_alter().
 *
 * The entity_ui admin paths for contacts and activities are registered as
 * normal menu items. Promote them to local tasks so they appear as tabs on
 * the drop/crm parent page.
 */
function dropcrm_menu_alter(&$items) {
  // drop/crm/contacts is registered by entity_ui for CRUD (add/edit/delete).
  // Keep it accessible but remove it from tabs — per-bundle tabs replace it.
  if (isset($items['drop/crm/contacts'])) {
    $items['drop/crm/contacts']['type'] = MENU_NORMAL_ITEM;
  }
  if (isset($items['drop/crm/activities'])) {
    $items['drop/crm/activities']['type']            = MENU_CALLBACK;
    $items['drop/crm/activities']['title']           = 'Activities';
    $items['drop/crm/activities']['page callback']   = 'dropcrm_activity_list_page';
    $items['drop/crm/activities']['page arguments']  = array();
    $items['drop/crm/activities']['file']            = 'dropcrm.admin.inc';
    $items['drop/crm/activities']['file path']       = backdrop_get_path('module', 'dropcrm');
  }
  if (isset($items['drop/crm/contact-methods'])) {
    $items['drop/crm/contact-methods']['type']   = MENU_CALLBACK;
    $items['drop/crm/contact-methods']['title']  = 'Contact Details';
  }
  // Redirect the entity_ui view path (contacts/N) to our custom view (contact/N).
  // This ensures the "View" tab on the edit form never lands on the wrong page.
  if (isset($items['drop/crm/contacts/%crm_contact'])) {
    $items['drop/crm/contacts/%crm_contact']['page callback']  = 'dropcrm_contact_view_redirect';
    $items['drop/crm/contacts/%crm_contact']['page arguments'] = array(3);
    $items['drop/crm/contacts/%crm_contact']['file']           = '';
  }
}

// ---------------------------------------------------------------------------
// Views integration
// ---------------------------------------------------------------------------

/**
 * Implements hook_form_alter().
 *
 * When arriving at the add-activity form via an "Add activity" link on a
 * contact page, the URL carries ?contact=CID. Pre-populate the
 * field_crm_contacts tags widget with that contact so the person doesn't
 * have to search for it manually.
 */
function dropcrm_form_alter(&$form, &$form_state, $form_id) {
  // Set breadcrumbs on CRM entity edit/add forms.
  // entity_ui generates form IDs like crm_contact_edit_{bundle}_form.
  if (strpos($form_id, 'crm_contact_edit_') === 0 || strpos($form_id, 'crm_contact_add_') === 0) {
    $entity = isset($form_state['entity']) ? $form_state['entity'] : NULL;
    $crumb = array(
      l(t('Home'), '<front>'),
      l(t('Drop Suite'), 'drop'),
      l(t('CRM'), 'drop/crm'),
      l(t('Contacts'), 'drop/crm/contacts'),
    );
    if ($entity && !empty($entity->cid)) {
      $crumb[] = l(entity_label('crm_contact', $entity), 'drop/crm/contact/' . $entity->cid);
    }
    backdrop_set_breadcrumb($crumb);

    // If a destination was passed in the URL, embed it as a hidden field so it
    // survives the POST and is available in the submit handler.
    if (!empty($_GET['destination'])) {
      $dest = $_GET['destination'];
      if (strpos($dest, '://') === FALSE && strpos($dest, '//') !== 0) {
        $form['crm_destination'] = array(
          '#type'  => 'hidden',
          '#value' => $dest,
        );
      }
    }
  }
  elseif (strpos($form_id, 'crm_activity_edit_') === 0 || strpos($form_id, 'crm_activity_add_') === 0 || $form_id === 'crm_activity_form') {
    $entity = isset($form_state['entity']) ? $form_state['entity'] : NULL;
    $crumb = array(
      l(t('Home'), '<front>'),
      l(t('Drop Suite'), 'drop'),
      l(t('CRM'), 'drop/crm'),
      l(t('Activities'), 'drop/crm/activities'),
    );
    if ($entity && !empty($entity->aid)) {
      $crumb[] = l(entity_label('crm_activity', $entity), 'drop/crm/activity/' . $entity->aid);
    }
    backdrop_set_breadcrumb($crumb);
  }
  elseif (strpos($form_id, 'crm_contact_method_edit_') === 0 || strpos($form_id, 'crm_contact_method_add_') === 0) {
    $entity = isset($form_state['entity']) ? $form_state['entity'] : NULL;
    $crumb = array(
      l(t('Home'), '<front>'),
      l(t('Drop Suite'), 'drop'),
      l(t('CRM'), 'drop/crm'),
    );
    if ($entity && !empty($entity->cid)) {
      $contact = crm_contact_load($entity->cid);
      if ($contact) {
        $crumb[] = l(t('Contacts'), 'drop/crm/contacts');
        $crumb[] = l(entity_label('crm_contact', $contact), 'drop/crm/contact/' . $entity->cid);
      }
    }
    backdrop_set_breadcrumb($crumb);
  }

  // Pre-populate Organization field when adding a person from an org page.
  if ($form_id === 'crm_contact_form') {
    $org_cid = isset($_GET['org']) ? (int) $_GET['org'] : 0;
    if ($org_cid) {
      $org = crm_contact_load($org_cid);
      if ($org && $org->bundle() === 'crm_organization') {
        $lang = LANGUAGE_NONE;
        if (isset($form['field_crm_employer'][$lang][0]['target_id'])) {
          $label = entity_label('crm_contact', $org);
          $form['field_crm_employer'][$lang][0]['target_id']['#default_value'] = check_plain($label) . ' (' . $org_cid . ')';
        }
      }
    }
    return;
  }

  if ($form_id !== 'crm_activity_form') {
    return;
  }

  // Pre-populate contact when arriving via "Add activity" link on a contact page.
  $cid = isset($_GET['contact']) ? (int) $_GET['contact'] : 0;
  if ($cid) {
    $contact = crm_contact_load($cid);
    if ($contact) {
      $lang = LANGUAGE_NONE;
      if (isset($form['field_crm_contacts'][$lang])) {
        $label = entity_label('crm_contact', $contact);
        $form['field_crm_contacts'][$lang]['#default_value'] = check_plain($label) . ' (' . $cid . ')';
      }
    }
  }

  // Pre-set status to "planned" when arriving via the To Do "Add task" link.
  if (isset($_GET['status']) && $_GET['status'] === 'planned') {
    $form['status']['#default_value'] = 'planned';
  }
}

/**
 * Implements hook_views_api().
 */
function dropcrm_views_api() {
  return array(
    'api'  => 3,
    'path' => backdrop_get_path('module', 'dropcrm'),
  );
}

// ---------------------------------------------------------------------------
// Helper functions
