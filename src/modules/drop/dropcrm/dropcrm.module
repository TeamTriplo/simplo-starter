    'module'        => 'dropcrm',
    'admin ui'      => array(
      'path'             => 'drop/crm/contacts',
      'file'             => 'dropcrm.admin.inc',
      'controller class' => 'CrmContactUIController',
      'menu wildcard'    => '%crm_contact',
    ),
  );

  // --- crm_contact_method ---
  $info['crm_contact_method'] = array(
    'label'         => t('Contact Details'),
    'plural label'  => t('Contact Details'),
    'description'   => t('An email address, telephone number, postal address, or website/social URL for a contact.'),
    'entity class'  => 'CrmContactMethod',
    'controller class' => 'CrmContactMethodController',
    'base table'    => 'crm_contact_method',
    'fieldable'     => TRUE,
    'entity keys'   => array(
      'id'     => 'cmid',
      'bundle' => 'type',
      'label'  => 'value',
    ),
    'bundle keys'   => array('bundle' => 'type'),
    'bundles'       => array(
      'email'     => array('label' => t('Email')),
      'telephone' => array('label' => t('Telephone')),
      'address'   => array('label' => t('Address')),
      'url'       => array('label' => t('Website / Social')),
    ),
    'uri callback'  => 'entity_class_uri',
    'access callback' => 'dropcrm_contact_method_access',
    'module'        => 'dropcrm',
    'admin ui'      => array(
      'path'             => 'drop/crm/contact-methods',
      'file'             => 'dropcrm.admin.inc',
      'controller class' => 'CrmContactMethodUIController',
      'menu wildcard'    => '%crm_contact_method',
    ),
  );

  // --- crm_activity ---
  // Single implicit bundle (same name as entity type). Activity type is a
  // base-table field, not a bundle, so all activities share the same fields.
