<?php
/**
 * @file
 * DropCRM — A lightweight CRM for Backdrop CMS.
 *
 * Provides three entity types:
 *  - crm_contact: persons, organizations, and households
 *  - crm_contact_method: email, telephone, and address records
 *  - crm_activity: logged interactions and planned tasks
 */

// ---------------------------------------------------------------------------
// Autoload
// ---------------------------------------------------------------------------

/**
 * Implements hook_autoload_info().
 */
function dropcrm_autoload_info() {
  return array(
    'CrmContact'                    => 'dropcrm.entity.inc',
    'CrmContactController'          => 'dropcrm.entity.inc',
    'CrmContactUIController'        => 'dropcrm.entity.inc',
    'CrmContactMethod'              => 'dropcrm.entity.inc',
    'CrmContactMethodController'    => 'dropcrm.entity.inc',
    'CrmContactMethodUIController'  => 'dropcrm.entity.inc',
    'CrmActivity'                   => 'dropcrm.entity.inc',
    'CrmActivityController'         => 'dropcrm.entity.inc',
    'CrmActivityUIController'       => 'dropcrm.entity.inc',
    'CrmContactInlineEntityFormController'                   => 'dropcrm.inline_entity_form.inc',
    'EntityReferenceSelectionHandlerGeneric_crm_contact'     => 'dropcrm.entity.inc',
    'DropProject'           => 'dropcrm.entity.inc',
    'DropProjectController' => 'dropcrm.entity.inc',
  );
}

// ---------------------------------------------------------------------------
// Entity info
