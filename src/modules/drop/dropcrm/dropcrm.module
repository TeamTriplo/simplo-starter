/**
 * Returns label options for a given contact method type.
 *
 * @param string $type
 *   One of: email, telephone, address.
 *
 * @return array
 */
function _dropcrm_contact_method_label_options($type) {
  $labels = config_get('dropcrm.settings', 'contact_method_labels');
  $options = array();
  if (!empty($labels[$type])) {
    foreach ($labels[$type] as $label) {
      $options[$label] = t($label);
    }
  }
  return $options;
}

/**
 * Builds a formatted address string from a contact method address entity.
 *
 * @param object $method
 *   A crm_contact_method entity with bundle 'address'.
 *
 * @return string
 *   A single-line formatted address.
 */
function _dropcrm_format_address($method) {
  try {
    $wrapper = entity_metadata_wrapper('crm_contact_method', $method);
    $parts = array_filter(array(
      $wrapper->field_crm_street->value(),
      $wrapper->field_crm_city->value(),
      $wrapper->field_crm_state_province->value(),
      $wrapper->field_crm_postal_code->value(),
      $wrapper->field_crm_country->value(),
    ));
    return implode(', ', $parts);
  }
  catch (EntityMetadataWrapperException $e) {
    return '';
  }
}

// ---------------------------------------------------------------------------
// Autocomplete callbacks
// ---------------------------------------------------------------------------

/**
 * Autocomplete callback: search CRM contacts by name.
 *
 * Returns JSON suggestions in the format "Contact Name [cid:N]" which the
 * contact method form submit handler parses to extract the CID.
 *
 * @param string $string
 *   The partial string typed by the person.
 */
function dropcrm_contact_autocomplete($string = '') {
  $matches = array();
  if (strlen($string) >= 1) {
    $needle = '%' . db_like($string) . '%';

    // Search the computed name column (covers org/household names and the
    // pre-computed "First Last" string for persons).
    $query = db_select('crm_contact', 'c')
      ->fields('c', array('cid', 'name'))
      ->condition('name', $needle, 'LIKE')
      ->orderBy('name')
      ->range(0, 10);

    $result = $query->execute();
    foreach ($result as $row) {
      $key = $row->name . ' [cid:' . $row->cid . ']';
      $matches[$key] = check_plain($row->name);
    }

    // Also search first and last name fields separately so typing a last name
    // (e.g. "Whitney") finds "Julia Whitney".
    if (count($matches) < 10) {
      $remaining = 10 - count($matches);
      $found_cids = array_map(function($k) {
        preg_match('/\[cid:(\d+)\]/', $k, $m);
        return isset($m[1]) ? (int) $m[1] : 0;
      }, array_keys($matches));

      $subquery = db_select('field_data_field_crm_first_name', 'fn');
      $subquery->join('crm_contact', 'c', 'c.cid = fn.entity_id');
      $subquery->leftJoin('field_data_field_crm_last_name', 'ln', 'ln.entity_id = fn.entity_id');
      $subquery->fields('c', array('cid', 'name'));
      $or = db_or()
        ->condition('fn.field_crm_first_name_value', $needle, 'LIKE')
        ->condition('ln.field_crm_last_name_value', $needle, 'LIKE');
      $subquery->condition($or);
      if ($found_cids) {
        $subquery->condition('c.cid', $found_cids, 'NOT IN');
      }
      $subquery->orderBy('c.name')->range(0, $remaining);

      foreach ($subquery->execute() as $row) {
        $key = $row->name . ' [cid:' . $row->cid . ']';
        $matches[$key] = check_plain($row->name);
      }
    }
  }
  backdrop_json_output($matches);
}

/**
 * Autocomplete callback: organizations only, entityreference-compatible format.
 *
 * Returns results as "Name (id)" so entityreference validation extracts the id
 * correctly. No arbitrary 10-result cap — returns up to 50 matches so all
 * organizations are reachable when typing a partial name.
 *
 * @param string $string
 *   The partial string typed by the person.
 */
function dropcrm_org_autocomplete($string = '') {
  $matches = array();
  if (strlen($string) >= 1) {
    $needle = '%' . db_like($string) . '%';
    $result = db_select('crm_contact', 'c')
      ->fields('c', array('cid', 'name'))
      ->condition('type', 'crm_organization')
      ->condition('name', $needle, 'LIKE')
      ->orderBy('name')
      ->range(0, 50)
      ->execute();
    foreach ($result as $row) {
      // entityreference validates with /.+\((\d+)\)/ so format must be "Name (id)".
      $key = check_plain($row->name) . ' (' . $row->cid . ')';
      $matches[$key] = check_plain($row->name);
    }
  }
  return $matches;
}

/**
 * Page callback: entityreference-compatible autocomplete for ALL contact types.
 *
 * Used by the field_crm_contacts widget on activity forms so that people,
 * organisations and households all appear in the suggestions list.
 *
 * Returns JSON with keys and values in "Name (id)" format, which is the
 * format the entityreference_autocomplete_tags widget expects.
 *
 * @param string $string
 *   The search string typed by the user.
 *
 * @return array
 *   Associative array of "Name (id)" => "Name" suggestions.
 */
function dropcrm_all_contacts_autocomplete($string = '') {
  $matches = array();
  if (strlen($string) >= 1) {
    $needle = '%' . db_like($string) . '%';

    // Primary search: name column (covers org names and "First Last" for people).
    $result = db_select('crm_contact', 'c')
      ->fields('c', array('cid', 'name'))
      ->condition('name', $needle, 'LIKE')
      ->orderBy('name')
      ->range(0, 50)
      ->execute();
    foreach ($result as $row) {
      // entityreference validates with /.+\((\d+)\)/ — format must be "Name (id)".
      $key = check_plain($row->name) . ' (' . $row->cid . ')';
      $matches[$key] = check_plain($row->name);
    }

    // Also search first/last name fields separately so "Whitney" finds "Julia Whitney".
    if (count($matches) < 50) {
      $remaining = 50 - count($matches);
      $found_cids = array();
      foreach (array_keys($matches) as $k) {
        if (preg_match('/\((\d+)\)$/', $k, $m)) {
          $found_cids[] = (int) $m[1];
        }
      }
      $subquery = db_select('field_data_field_crm_first_name', 'fn');
      $subquery->join('crm_contact', 'c', 'c.cid = fn.entity_id');
      $subquery->leftJoin('field_data_field_crm_last_name', 'ln', 'ln.entity_id = fn.entity_id');
      $subquery->fields('c', array('cid', 'name'));
      $or = db_or()
        ->condition('fn.field_crm_first_name_value', $needle, 'LIKE')
        ->condition('ln.field_crm_last_name_value', $needle, 'LIKE');
      $subquery->condition($or);
      if ($found_cids) {
        $subquery->condition('c.cid', $found_cids, 'NOT IN');
      }
      $subquery->orderBy('c.name')->range(0, $remaining);
      foreach ($subquery->execute() as $row) {
        $key = check_plain($row->name) . ' (' . $row->cid . ')';
        $matches[$key] = check_plain($row->name);
      }
    }
  }
  return $matches;
}

/**
 * Implements hook_menu_local_tasks_alter().
 *
 * When a contact view page is loaded with a ?destination= parameter (e.g.
 * from the Clients report), propagate that destination onto the Edit local
 * task URL so that saving the edit form returns to the original report.
 */
function dropcrm_menu_local_tasks_alter(&$data, $router_item, $root_path) {
  // On the main CRM page, strip all local tasks except admin-only ones.
  // Operational navigation lives in the Drop Section Navigation block.
  if ($root_path === 'drop/crm') {
    $admin_paths = array('drop/crm/settings');
    if (!empty($data['tabs'][0]['output'])) {
      foreach ($data['tabs'][0]['output'] as $key => $tab) {
        $href = isset($tab['#link']['href']) ? $tab['#link']['href'] : '';
        if (!in_array($href, $admin_paths)) {
          unset($data['tabs'][0]['output'][$key]);
        }
      }
    }
  }

  // Propagate ?destination onto contact edit tabs so saving returns to the
  // originating report.
  if (empty($_GET['destination'])) {
    return;
  }
  // Only apply on the contact view page.
  if ($root_path !== 'drop/crm/contact/%') {
    return;
  }
  $dest = $_GET['destination'];
  // Guard against external URLs.
  if (strpos($dest, '://') !== FALSE || strpos($dest, '//') === 0) {
    return;
  }
  // Add the destination to every local task that contains '/edit'.
  foreach ($data['tabs'] as &$tab_level) {
    foreach ($tab_level['output'] as &$tab) {
      if (!empty($tab['#link']['href']) && strpos($tab['#link']['href'], '/edit') !== FALSE) {
        $tab['#link']['localized_options']['query']['destination'] = $dest;
      }
    }
  }
}

/**
 * Implements hook_drop_reports().
 */
function dropcrm_drop_reports() {
  return array(
    'dropcrm_last_contact' => array(
      'title'              => t('Last Contact'),
      'path'               => 'drop/crm/reports/last-contact',
