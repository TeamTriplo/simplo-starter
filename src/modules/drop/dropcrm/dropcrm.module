  );

  // Contact name autocomplete.
  $items['drop/crm/autocomplete/contacts'] = array(
    'title'          => 'Contact autocomplete',
    'page callback'  => 'dropcrm_contact_autocomplete',
    'access arguments' => array('access crm'),
