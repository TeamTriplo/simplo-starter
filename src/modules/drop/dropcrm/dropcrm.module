  if (config_get('dropcrm.settings', 'enable_households')) {
    $items['drop/crm/households'] = array(
      'title'            => 'Households',
      'page callback'    => 'dropcrm_contact_list_page',
      'page arguments'   => array('crm_household'),
      'access arguments' => array('access crm'),
