// ---------------------------------------------------------------------------
// Permissions and access
// ---------------------------------------------------------------------------

/**
 * Implements hook_permission().
 */
function dropcrm_permission() {
  return array(
    'administer crm' => array(
      'title'       => t('Administer CRM'),
      'description' => t('Manage CRM settings, field configuration, and all records.'),
      'restrict access' => TRUE,
    ),
    'access crm' => array(
      'title'       => t('Access CRM'),
      'description' => t('View contacts, activities, and contact methods.'),
    ),
    'access crm projects' => array(
      'title'       => t('Access CRM Projects'),
      'description' => t('View the project list and individual project pages (without full CRM access). Useful for team members who only need to see which tickets belong to a project.'),
    ),
    'create crm contacts' => array(
      'title'       => t('Create CRM contacts'),
    ),
    'edit crm contacts' => array(
      'title'       => t('Edit CRM contacts'),
    ),
    'delete crm contacts' => array(
      'title'       => t('Delete CRM contacts'),
    ),
    'create crm activities' => array(
      'title'       => t('Create CRM activities'),
    ),
    'edit crm activities' => array(
      'title'       => t('Edit CRM activities'),
    ),
    'delete crm activities' => array(
      'title'       => t('Delete CRM activities'),
    ),
    'import crm contacts' => array(
      'title'       => t('Import CRM contacts'),
      'description' => t('Upload a CSV file to bulk import contacts.'),
    ),
    'export crm contacts' => array(
      'title'       => t('Export CRM contacts'),
      'description' => t('Download contacts as a CSV file.'),
    ),
  );
}

/**
 * Access callback for crm_contact entities.
 *
 * @param string $op
 *   One of: 'view', 'create', 'update', 'delete'.
 * @param object|null $entity
 *   The entity, or NULL for 'create'.
 * @param object|null $account
 *   The user account. Defaults to current user.
 *
 * @return bool
 */
function dropcrm_contact_access($op, $entity = NULL, $account = NULL) {
  if (user_access('administer crm', $account)) {
    return TRUE;
  }
  switch ($op) {
    case 'view':
      return user_access('access crm', $account);
    case 'create':
      return user_access('create crm contacts', $account);
    case 'update':
      return user_access('edit crm contacts', $account);
    case 'delete':
      return user_access('delete crm contacts', $account);
  }
  return FALSE;
}

/**
 * Access callback for crm_contact_method entities.
 */
function dropcrm_contact_method_access($op, $entity = NULL, $account = NULL) {
  if (user_access('administer crm', $account)) {
    return TRUE;
  }
  switch ($op) {
    case 'view':
      return user_access('access crm', $account);
    case 'create':
    case 'update':
      return user_access('edit crm contacts', $account);
    case 'delete':
      return user_access('delete crm contacts', $account);
  }
  return FALSE;
}

/**
 * Access callback for crm_activity entities.
 */
function dropcrm_activity_access($op, $entity = NULL, $account = NULL) {
  if (user_access('administer crm', $account)) {
    return TRUE;
  }
  switch ($op) {
    case 'view':
      return user_access('access crm', $account);
    case 'create':
      return user_access('create crm activities', $account);
    case 'update':
      return user_access('edit crm activities', $account);
    case 'delete':
      return user_access('delete crm activities', $account);
  }
  return FALSE;
}

// ---------------------------------------------------------------------------
// Entity load helpers
// ---------------------------------------------------------------------------

/**
 * Loads a single CRM contact by ID.
 *
 * @param int $cid
 *   Contact ID.
 *
 * @return CrmContact|FALSE
 */
function crm_contact_load($cid) {
  $contacts = crm_contact_load_multiple(array($cid));
  return $contacts ? reset($contacts) : FALSE;
}

/**
 * Loads multiple CRM contacts.
 *
 * @param array $cids
 *   Array of contact IDs, or empty to load all.
 * @param array $conditions
 *   Additional conditions for EntityFieldQuery.
 * @param bool $reset
 *   Whether to reset the entity cache.
 *
 * @return array
 */
function crm_contact_load_multiple($cids = array(), $conditions = array(), $reset = FALSE) {
  return entity_load('crm_contact', $cids, $conditions, $reset);
}

/**
 * Loads a single CRM contact method by ID.
 *
 * @param int $cmid
 *   Contact method ID.
 *
 * @return CrmContactMethod|FALSE
 */
function crm_contact_method_load($cmid) {
  $methods = crm_contact_method_load_multiple(array($cmid));
  return $methods ? reset($methods) : FALSE;
}

/**
 * Loads multiple CRM contact methods.
 */
function crm_contact_method_load_multiple($cmids = array(), $conditions = array(), $reset = FALSE) {
  return entity_load('crm_contact_method', $cmids, $conditions, $reset);
}

/**
 * Loads a single CRM activity by ID.
 *
 * @param int $aid
 *   Activity ID.
 *
 * @return CrmActivity|FALSE
 */
function crm_activity_load($aid) {
  $activities = crm_activity_load_multiple(array($aid));
  return $activities ? reset($activities) : FALSE;
}

/**
 * Loads multiple CRM activities.
 */
function crm_activity_load_multiple($aids = array(), $conditions = array(), $reset = FALSE) {
  return entity_load('crm_activity', $aids, $conditions, $reset);
}

/**
 * Loads a single CRM relationship by ID.
 *
 * @param int $rid
 *   Relationship ID.
 *
 * @return stdClass|FALSE
 *   The relationship object, or FALSE if not found.
 */
function crm_relationship_load($rid) {
  return db_select('crm_relationship', 'r')
    ->fields('r')
    ->condition('rid', (int) $rid)
    ->execute()
    ->fetchObject();
}

/**
 * Menu loader: load a project by pid.
 */
function drop_project_load($pid) {
  $projects = entity_load('drop_project', array((int) $pid));
  return $projects ? reset($projects) : FALSE;
}

/**
 * Access callback: view/list project pages.
 *
 * Grants access to users with either 'access crm' or 'access crm projects'.
 */
function dropcrm_project_view_access() {
  return user_access('administer crm')
    || user_access('access crm')
    || user_access('access crm projects');
}

/**
 * Access callback for drop_project entities.
 */
function dropcrm_project_access($op, $project = NULL, $account = NULL) {
  global $user;
  if (!$account) {
    $account = $user;
  }
  if (user_access('administer crm', $account)) {
    return TRUE;
  }
  // View access: either full CRM access or the lighter projects-only permission.
  if ($op === 'view') {
    return user_access('access crm', $account)
      || user_access('access crm projects', $account);
  }
  if (!user_access('access crm', $account)) {
    return FALSE;
  }
  if ($op === 'create') {
    return TRUE;
  }
  return $project && $project->uid == $account->uid;
}

/**
 * Returns the available project color options.
 *
 * @return array
 *   Hex code => label.
 */
function dropcrm_color_options() {
  return array(
    '#1565c0' => t('Blue'),
    '#2e7d32' => t('Green'),
    '#e65100' => t('Orange'),
    '#7b1fa2' => t('Purple'),
    '#c62828' => t('Red'),
    '#00838f' => t('Teal'),
    '#f57c00' => t('Amber'),
    '#37474f' => t('Slate'),
    '#558b2f' => t('Olive'),
    '#ad1457' => t('Pink'),
  );
}

/**
 * Returns active projects as pid => name options array.
 *
 * @param int $uid
 *   Optional user ID to filter by owner. Pass 0 for all projects.
 *
 * @return array
 */
function dropcrm_project_options($uid = 0) {
  $query = db_select('drop_project', 'p')
    ->fields('p', array('pid', 'name'))
    ->condition('p.active', 1)
    ->orderBy('p.name', 'ASC');
  if ($uid) {
    $query->condition('p.uid', $uid);
  }
  return $query->execute()->fetchAllKeyed();
}

// ---------------------------------------------------------------------------
// Entity presave hooks
// ---------------------------------------------------------------------------

/**
 * Implements hook_crm_contact_presave().
 *
 * Sets timestamps and uid, then computes the display name for Person contacts
 * from first + last name field API fields.
 */
function dropcrm_crm_contact_presave($contact) {
  if (empty($contact->created)) {
    $contact->created = REQUEST_TIME;
  }
  $contact->changed = REQUEST_TIME;
  if (!isset($contact->uid)) {
    $contact->uid = $GLOBALS['user']->uid;
  }
  if (!isset($contact->status)) {
    $contact->status = 1;
  }

  if ($contact->type !== 'crm_person') {
    return;
  }
  try {
    $wrapper = entity_metadata_wrapper('crm_contact', $contact);
    $first  = $wrapper->field_crm_first_name->value();
    $last   = $wrapper->field_crm_last_name->value();
    $name   = trim($first . ' ' . $last);
    $contact->name = $name !== '' ? $name : t('(No name)');
  }
  catch (EntityMetadataWrapperException $e) {
    // Fields not yet available (e.g. during install).
  }
}

/**
 * Implements hook_crm_contact_method_presave().
 *
 * Sets timestamps and builds the formatted address value for address records.
 */
function dropcrm_crm_contact_method_presave($method) {
  if (empty($method->created)) {
    $method->created = REQUEST_TIME;
  }
  $method->changed = REQUEST_TIME;

  if ($method->type === 'address') {
    $method->value = _dropcrm_format_address($method);
  }
}

/**
 * Implements hook_crm_activity_presave().
 *
 * Sets timestamps, uid, and default activity_date.
 */
/**
 * Page callback: extend an activity's due date by a fixed period.
 *
 * @param CrmActivity $activity
 *   The activity to update.
 * @param string $period
 *   One of: 'day', 'week', 'month'.
 */
function dropcrm_activity_extend(CrmActivity $activity, $period) {
  $allowed = array('day' => '+1 day', 'week' => '+1 week', 'month' => '+1 month');
  if (!isset($allowed[$period])) {
    return MENU_NOT_FOUND;
  }
  $base = !empty($activity->due_date) ? $activity->due_date : REQUEST_TIME;
  $activity->due_date = strtotime($allowed[$period], $base);
  $activity->save();
  backdrop_set_message(t('Due date extended by 1 @period.', array('@period' => $period)));
  backdrop_goto('drop/crm/activity/' . $activity->aid);
}


function dropcrm_crm_activity_presave($activity) {
  if (empty($activity->created)) {
    $activity->created = REQUEST_TIME;
  }
  $activity->changed = REQUEST_TIME;
  if (!isset($activity->uid)) {
    $activity->uid = $GLOBALS['user']->uid;
  }
  if (empty($activity->activity_date)) {
    $activity->activity_date = REQUEST_TIME;
  }
  if (empty($activity->subject)) {
    $activity->subject = _dropcrm_generate_activity_subject($activity);
  }
}

/**
 * Generates an activity subject from type, linked contacts, and date.
 *
 * Used when the subject field is left blank on the activity form.
 *
 * @param CrmActivity $activity
 *   The activity entity (field values must already be populated).
 *
 * @return string
 *   A generated subject string.
 */
function _dropcrm_generate_activity_subject(CrmActivity $activity) {
  $type_options = _dropcrm_activity_type_options();
  $type_label = isset($type_options[$activity->type])
    ? $type_options[$activity->type]
    : ucfirst($activity->type);

  $ts = !empty($activity->activity_date) ? $activity->activity_date : REQUEST_TIME;
  $date_label = format_date($ts, 'custom', 'M j, Y');

  // Read contact names from field values directly (entity may not be saved yet).
  $contact_names = array();
  $lang = LANGUAGE_NONE;
  if (!empty($activity->field_crm_contacts[$lang])) {
    foreach ($activity->field_crm_contacts[$lang] as $item) {
      if (!empty($item['target_id'])) {
        $contact = crm_contact_load((int) $item['target_id']);
        if ($contact) {
          $contact_names[] = entity_label('crm_contact', $contact);
        }
      }
    }
  }

  if ($contact_names) {
    return $type_label . ' with ' . implode(', ', $contact_names) . ' — ' . $date_label;
  }
  return $type_label . ' — ' . $date_label;
}

