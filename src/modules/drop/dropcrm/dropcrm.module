/**
 * Returns options list for activity types from config.
 *
 * @return array
 */
function _dropcrm_activity_type_options() {
  $types = config_get('dropcrm.settings', 'activity_types');
  $options = array();
  if ($types) {
    foreach ($types as $key => $info) {
      $options[$key] = t($info['label']);
    }
  }
  return $options;
}

/**
 * Returns options list for activity statuses.
 *
 * @return array
 */
function _dropcrm_activity_status_options() {
  return array(
    'completed' => t('Completed'),
    'planned'   => t('Planned'),
  );
}

/**
 * Returns options list for activity priorities.
 *
 * @return array
 */
/**
 * Renders a 1–3 star rating as filled/empty star characters.
 *
 * @param int $value
 *   The rating value (1, 2, or 3). 0 or empty returns ''.
 * @param int $max
 *   Maximum stars (default 3).
 *
 * @return string
 *   HTML string of star characters, or empty string if unrated.
 */
function _dropcrm_render_stars($value, $max = 5) {
  $value = (int) $value;
  if ($value < 1 || $value > $max) {
    return '';
  }
  $filled = str_repeat('★', $value);
  $empty  = str_repeat('☆', $max - $value);
  return '<span class="crm-stars" title="' . format_plural($value, '1 star', '@count stars') . '">'
    . '<span class="crm-stars-filled">' . $filled . '</span>'
    . '<span class="crm-stars-empty">' . $empty . '</span>'
    . '</span>';
}

function _dropcrm_activity_priority_options() {
  return array(
    2 => t('High'),
    1 => t('Normal'),
    0 => t('Low'),
  );
}

/**
 * Returns options list for activity direction.
