/**
 * Implements hook_menu().
 */
function dropcrm_menu() {
  $items = array();

  // CRM overview — parent page for all tabs.
  $items['drop/crm'] = array(
    'title'            => 'CRM',
    'description'      => 'Manage contacts, activities, and CRM settings.',
    'page callback'    => 'dropcrm_admin_overview',
    'page arguments'   => array(),
    'access arguments' => array('access crm'),
    'file'             => 'dropcrm.admin.inc',
  );

  // "Overview" default tab — keeps the dashboard accessible as a tab when
  // the user navigates to a sibling tab (contacts, activities, settings).
  $items['drop/crm/overview'] = array(
    'title'            => 'Overview',
    'type'             => MENU_DEFAULT_LOCAL_TASK,
    'weight'           => -10,
  );

  // Contact view pages.
  $items['drop/crm/contact/%crm_contact'] = array(
    'title callback'   => 'entity_label',
    'title arguments'  => array('crm_contact', 3),
    'page callback'    => 'dropcrm_contact_view',
    'page arguments'   => array(3),
    'access callback'  => 'dropcrm_contact_access',
    'access arguments' => array('view', 3),
    'file'             => 'dropcrm.pages.inc',
  );

  // Activity view pages.
  $items['drop/crm/activity/%crm_activity'] = array(
    'title callback'   => 'entity_label',
    'title arguments'  => array('crm_activity', 3),
    'page callback'    => 'dropcrm_activity_view',
    'page arguments'   => array(3),
    'access callback'  => 'dropcrm_activity_access',
    'access arguments' => array('view', 3),
    'file'             => 'dropcrm.pages.inc',
  );

  // Activity due-date extend shortcuts.
  $items['drop/crm/activity/%crm_activity/extend/%'] = array(
    'page callback'    => 'dropcrm_activity_extend',
    'page arguments'   => array(3, 4),
    'access callback'  => 'dropcrm_activity_access',
    'access arguments' => array('edit', 3),
    'type'             => MENU_CALLBACK,
  );

  // Contact method pages.
  $items['drop/crm/contact-method/%crm_contact_method'] = array(
    'title callback'   => 'entity_label',
    'title arguments'  => array('crm_contact_method', 3),
