      'module'             => 'dropcrm',
      'default_pin'        => TRUE,
      'is_default_subtask' => TRUE,
    ),
    'dropcrm_outreach_goal' => array(
      'title'       => t('Outreach Goal'),
      'path'        => 'drop/crm/reports/outreach-goal',
      'root_path'   => 'drop/crm',
      'module'      => 'dropcrm',
      'default_pin' => FALSE,
    ),
    'dropcrm_clients' => array(
      'title'       => t('Clients'),
      'path'        => 'drop/crm/reports/clients',
      'root_path'   => 'drop/crm',
      'module'      => 'dropcrm',
      'default_pin' => FALSE,
    ),
    'dropcrm_tag_filter' => array(
      'title'       => t('Tag Filter'),
      'path'        => 'drop/crm/reports/tag-filter',
      'root_path'   => 'drop/crm',
      'module'      => 'dropcrm',
      'default_pin' => FALSE,
    ),
  );
}

/**
 * Implements hook_drop_nav_links().
 */
function dropcrm_drop_nav_links() {
  return array(
    array(
      'title'      => t('CRM'),
      'path'       => 'drop/crm',
      'permission' => 'access crm',
      'weight'     => 10,
    ),
  );
}

/**
 * Implements hook_drop_section_links().
 */
function dropcrm_drop_section_links($section) {
  if ($section !== 'crm') {
    return array();
  }

  $links = array();

  $links['people'] = array(
    'title'        => t('People'),
    'href'         => 'drop/crm/people',
    'weight'       => -20,
    'active_paths' => array('drop/crm/people', 'drop/crm/contact'),
  );

  $links['organizations'] = array(
    'title'  => t('Organizations'),
    'href'   => 'drop/crm/organizations',
    'weight' => -15,
  );

  if (config_get('dropcrm.settings', 'enable_households')) {
    $links['households'] = array(
      'title'  => t('Households'),
      'href'   => 'drop/crm/households',
      'weight' => -10,
    );
  }

  $links['todo'] = array(
    'title'  => t('To Do'),
    'href'   => 'drop/crm/todo',
    'weight' => -5,
  );

  $links['activities'] = array(
    'title'        => t('Activities'),
    'href'         => 'drop/crm/activities',
    'weight'       => 0,
    'active_paths' => array('drop/crm/activities', 'drop/crm/activity'),
  );

  if (user_access('access crm') || user_access('access crm projects')) {
    $links['projects'] = array(
      'title'        => t('Projects'),
      'href'         => 'drop/crm/projects',
      'weight'       => 10,
      'active_paths' => array('drop/crm/projects'),
    );
  }

  // Reports — flat links rather than a navigating "Reports" parent.
  $links['last_contact'] = array(
    'title'  => t('Last Contact'),
    'href'   => 'drop/crm/reports/last-contact',
    'weight' => 20,
  );

  $links['outreach_goal'] = array(
    'title'  => t('Outreach Goal'),
    'href'   => 'drop/crm/reports/outreach-goal',
    'weight' => 25,
  );

  $links['clients'] = array(
    'title'  => t('Clients'),
    'href'   => 'drop/crm/reports/clients',
    'weight' => 30,
  );

  $links['tag_filter'] = array(
    'title'  => t('Tag Filter'),
    'href'   => 'drop/crm/reports/tag-filter',
    'weight' => 35,
  );

  return $links;
}

/**
 * Page callback: redirects entity_ui's contacts/N path to our contact/N view.
 */
function dropcrm_contact_view_redirect($contact) {
  backdrop_goto('drop/crm/contact/' . $contact->cid);
}

// ---------------------------------------------------------------------------
// Contact view accordion helpers
// ---------------------------------------------------------------------------

/**
 * Returns the opening HTML for an accordion section on the contact view page.
 *
 * @param string $title
 *   Section title (plain text, will be escaped).
 * @param string $extra_html
 *   Optional HTML to append inside the <summary> (e.g. add-links).
 * @param bool $open
 *   Whether the section should be expanded by default.
 *
 * @return string
 */
function dropcrm_accordion_prefix($title, $extra_html = '', $open = FALSE) {
  $open_attr = $open ? ' open' : '';
  return '<details class="crm-section-accordion"' . $open_attr . '>'
    . '<summary class="crm-section-summary">'
    . '<span class="crm-section-title">' . check_plain($title) . '</span>'
    . ($extra_html ? $extra_html : '')
    . '</summary>'
    . '<div class="crm-section-body">';
}

/**
 * Returns the closing HTML for an accordion section on the contact view page.
 */
function dropcrm_accordion_suffix() {
  return '</div></details>';
}
