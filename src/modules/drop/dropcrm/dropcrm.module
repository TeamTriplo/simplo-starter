  );

  // Organization-only autocomplete (returns entityreference-compatible format).
  // Entityreference appends /{field_name}/{entity_type}/{bundle}/{entity_id}
  // to the configured path before storing it as #autocomplete_path (7 segments
  // total). backdrop_valid_path() checks that 7-segment path, so our route must
  // match it exactly. When the autocomplete JS fires, it appends the typed
  // string as the 8th segment — Backdrop's ancestor matching finds our 7-segment
  // route and passes the extra segment as the first function argument.
  $items['crm/autocomplete/organizations/%/%/%/%'] = array(
    'title'             => 'Organization autocomplete',
    'page callback'     => 'dropcrm_org_autocomplete',
    'access arguments'  => array('access crm'),
    'type'              => MENU_CALLBACK,
    'delivery callback' => 'backdrop_json_deliver',
  );

  // All-contacts autocomplete (returns entityreference-compatible format).
