    'page callback'    => 'dropcrm_report_clients',
    'access arguments' => array('access crm'),
    'file'             => 'dropcrm.admin.inc',
    'type'             => MENU_CALLBACK,
  );
  $items['drop/crm/reports/tag-filter'] = array(
    'title'            => 'Tag Filter',
    'page callback'    => 'dropcrm_report_tag_filter',
    'access arguments' => array('access crm'),
    'file'             => 'dropcrm.admin.inc',
    'type'             => MENU_CALLBACK,
  );

  // Per-bundle contact tabs.
  $items['drop/crm/people'] = array(
    'title'            => 'People',
    'page callback'    => 'dropcrm_contact_list_page',
    'page arguments'   => array('crm_person'),
