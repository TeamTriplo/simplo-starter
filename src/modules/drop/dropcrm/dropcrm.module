    'label'         => t('CRM Activity'),
    'plural label'  => t('CRM Activities'),
    'description'   => t('A logged interaction or planned task associated with one or more contacts.'),
    'entity class'  => 'CrmActivity',
    'controller class' => 'CrmActivityController',
    'base table'    => 'crm_activity',
    'fieldable'     => TRUE,
    'entity keys'   => array(
      'id'    => 'aid',
      'label' => 'subject',
    ),
    'view modes'    => array(
      'full' => array('label' => t('Full'), 'custom settings' => FALSE),
    ),
    'uri callback'  => 'entity_class_uri',
    'access callback' => 'dropcrm_activity_access',
    'module'        => 'dropcrm',
    'admin ui'      => array(
      'path'             => 'drop/crm/activities',
      'file'             => 'dropcrm.admin.inc',
      'controller class' => 'CrmActivityUIController',
      'menu wildcard'    => '%crm_activity',
    ),
  );

  // --- drop_project ---
  $info['drop_project'] = array(
    'label'            => t('Project'),
    'plural label'     => t('Projects'),
    'description'      => t('A project that can be linked to contacts and used for time tracking.'),
    'entity class'     => 'DropProject',
    'controller class' => 'DropProjectController',
    'base table'       => 'drop_project',
    'fieldable'        => TRUE,
    'entity keys'      => array(
      'id'    => 'pid',
      'label' => 'name',
    ),
    'uri callback'    => 'entity_class_uri',
    'access callback' => 'dropcrm_project_access',
    'module'          => 'dropcrm',
  );

  return $info;
}

