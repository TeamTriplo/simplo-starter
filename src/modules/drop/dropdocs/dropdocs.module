<?php
/**
 * @file
 * DropDocs — internal team documentation and wiki for the Drop Suite.
 *
 * Provides a 'doc' content type with parent-child hierarchy, tag taxonomy,
 * and a tree-navigation sidebar. Integrates with drop_base for the shared
 * navigation bar and page chrome.
 */

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------

/**
 * Implements hook_menu().
 */
function dropdocs_menu() {
  $items = array();

  // Index listing.
  $items['drop/docs'] = array(
    'title'            => 'Docs',
    'page callback'    => 'dropdocs_index_page',
    'access callback'  => 'user_access',
    'access arguments' => array('access dropdocs'),
    'file'             => 'dropdocs.pages.inc',
  );

  // Default local task on the index so the Reorder tab has a sibling.
  $items['drop/docs/list'] = array(
    'title'  => 'All docs',
    'type'   => MENU_DEFAULT_LOCAL_TASK,
    'weight' => -10,
  );

  // Reorder local task on the index.
  $items['drop/docs/reorder'] = array(
    'title'            => 'Reorder',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('dropdocs_reorder_form'),
    'access callback'  => 'user_access',
    'access arguments' => array('administer dropdocs'),
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 10,
    'file'             => 'dropdocs.pages.inc',
  );

  // Doc view page.
  $items['drop/doc/%node'] = array(
    'title callback'   => 'dropdocs_page_title',
    'title arguments'  => array(2),
    'page callback'    => 'dropdocs_doc_view',
    'page arguments'   => array(2),
    'access callback'  => 'node_access',
    'access arguments' => array('view', 2),
    'file'             => 'dropdocs.pages.inc',
  );

  // Default local task: View.
  $items['drop/doc/%node/view'] = array(
    'title' => 'View',
    'type'  => MENU_DEFAULT_LOCAL_TASK,
    'weight' => -10,
  );

  // Edit local task — renders the standard node form at our path.
  $items['drop/doc/%node/edit'] = array(
    'title'            => 'Edit',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('doc_node_form', 2),
    'access callback'  => 'node_access',
    'access arguments' => array('update', 2),
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 5,
    'file path'        => backdrop_get_path('module', 'node'),
    'file'             => 'node.pages.inc',
  );

  // Add child local task.
  $items['drop/doc/%node/add-child'] = array(
    'title'            => 'Add child page',
    'page callback'    => 'dropdocs_add_child_redirect',
    'page arguments'   => array(2),
    'access callback'  => 'node_access',
    'access arguments' => array('create', 'doc'),
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 10,
    'file'             => 'dropdocs.pages.inc',
  );

  return $items;
}

/**
 * Title callback for the doc view page.
 *
 * @param object $node
 *   The loaded doc node.
 *
 * @return string
 */
function dropdocs_page_title($node) {
  return $node->title;
}

// ---------------------------------------------------------------------------
// Permissions
// ---------------------------------------------------------------------------

/**
 * Implements hook_permission().
 */
function dropdocs_permission() {
  return array(
    'access dropdocs' => array(
      'title'       => t('Access Drop Docs'),
      'description' => t('View the internal documentation section.'),
    ),
    'administer dropdocs' => array(
      'title'       => t('Administer Drop Docs'),
      'description' => t('Manage documentation settings and structure.'),
    ),
  );
}

// ---------------------------------------------------------------------------
// Theme
// ---------------------------------------------------------------------------

/**
 * Implements hook_theme().
 */
function dropdocs_theme() {
  return array(
    'dropdocs_reorder_form' => array(
      'render element' => 'form',
      'file'           => 'dropdocs.pages.inc',
    ),
  );
}

// ---------------------------------------------------------------------------
// Drop Nav integration
// ---------------------------------------------------------------------------

/**
 * Implements hook_drop_nav_links().
 */
function dropdocs_drop_nav_links() {
  return array(
    array(
      'title'      => t('Docs'),
      'path'       => 'drop/docs',
      'permission' => 'access dropdocs',
      'weight'     => 50,
    ),
  );
}

/**
 * Implements hook_drop_section_links().
 */
function dropdocs_drop_section_links($section) {
  if ($section !== 'docs') {
    return array();
  }

  $links = array();

  $links['all'] = array(
    'title'        => t('All Docs'),
    'href'         => 'drop/docs',
    'weight'       => -10,
    'active_paths' => array('drop/docs', 'drop/docs/list', 'drop/doc'),
  );

  return $links;
}

// ---------------------------------------------------------------------------
// Node form integration
// ---------------------------------------------------------------------------

/**
 * Implements hook_form_BASE_FORM_ID_alter() for doc_node_form.
 *
 * Sets correct Drop Suite breadcrumbs on the add/edit form and redirects
 * back to our admin path after save.
 */
function dropdocs_form_doc_node_form_alter(&$form, &$form_state, $form_id) {
  $node    = $form['#node'];
  $is_edit = !empty($node->nid);

  // Breadcrumb.
  if ($is_edit) {
    $crumb = array(
      l(t('Home'), '<front>'),
      l(t('Drop Suite'), 'drop'),
      l(t('Docs'), 'drop/docs'),
    );
    $parents = dropdocs_get_ancestors($node->nid);
    foreach ($parents as $ancestor) {
      $crumb[] = l(check_plain($ancestor->title), 'drop/doc/' . $ancestor->nid);
    }
    $crumb[] = l(check_plain($node->title), 'drop/doc/' . $node->nid);
    backdrop_set_breadcrumb($crumb);
  }
  else {
    $crumb = array(
      l(t('Home'), '<front>'),
      l(t('Drop Suite'), 'drop'),
      l(t('Docs'), 'drop/docs'),
    );
    // Pre-fill parent field when arriving from "Add child page" tab.
    if (isset($_GET['parent'])) {
      $parent_nid = (int) $_GET['parent'];
      if ($parent_nid) {
        $parent = node_load($parent_nid);
        if ($parent && $parent->type === 'doc') {
          $lang = LANGUAGE_NONE;
          // entityreference_autocomplete expects "Title (nid)" format.
          $form['field_doc_parent'][$lang][0]['target_id']['#default_value'] =
            $parent->title . ' (' . $parent_nid . ')';
          $crumb[] = l(check_plain($parent->title), 'drop/doc/' . $parent_nid);
        }
      }
    }
    backdrop_set_breadcrumb($crumb);
  }

  // After save, redirect to our admin path instead of node/{nid}.
  $form['actions']['submit']['#submit'][] = 'dropdocs_node_form_redirect';
}

/**
 * Submit handler: redirect to the Drop Docs view path after saving a doc.
 */
function dropdocs_node_form_redirect($form, &$form_state) {
  if (!empty($form_state['nid'])) {
    $form_state['redirect'] = 'drop/doc/' . $form_state['nid'];
  }
}

// ---------------------------------------------------------------------------
// Tree helpers (used by pages.inc)
// ---------------------------------------------------------------------------

/**
 * Loads all published doc nodes and their parent relationships in one query.
 *
 * @return array
 *   Keyed by nid; each row has nid, title, parent_nid.
 */
function dropdocs_load_all() {
  $query = db_select('node', 'n')
    ->fields('n', array('nid', 'title'))
    ->condition('n.type', 'doc')
    ->condition('n.status', 1)
    ->orderBy('n.title', 'ASC');
  $query->leftJoin(
    'field_data_field_doc_parent', 'p',
    'p.entity_id = n.nid AND p.entity_type = :et',
    array(':et' => 'node')
  );
  $query->addField('p', 'field_doc_parent_target_id', 'parent_nid');
  $query->leftJoin('dropdocs_weight', 'w', 'w.nid = n.nid');
  $query->addField('w', 'weight', 'weight');
  return $query->execute()->fetchAllAssoc('nid');
}

/**
 * Builds a nested tree array from a flat list of doc rows.
 *
 * @param array  $docs       Flat list keyed by nid (from dropdocs_load_all()).
 * @param int    $parent_nid Parent nid to build children for (NULL = root).
 *
 * @return array
 *   Nested array of doc objects, each with a 'children' property.
 */
function dropdocs_build_tree(array $docs, $parent_nid = NULL) {
  $tree = array();
  foreach ($docs as $nid => $doc) {
    $doc_parent = $doc->parent_nid ? (int) $doc->parent_nid : NULL;
    if ($doc_parent === $parent_nid) {
      $doc->children = dropdocs_build_tree($docs, (int) $nid);
      $tree[]        = $doc;
    }
  }
  // Sort siblings by weight (NULL treated as 0), then title.
  usort($tree, function($a, $b) {
    $wa = ($a->weight !== NULL) ? (int) $a->weight : 0;
    $wb = ($b->weight !== NULL) ? (int) $b->weight : 0;
    return ($wa !== $wb) ? ($wa - $wb) : strcmp($a->title, $b->title);
  });
  return $tree;
}

/**
 * Returns ancestor doc nodes from root down to (but not including) $nid.
 *
 * @param int $nid  The starting doc nid.
 *
 * @return array  Ordered array of node objects, root first.
 */
function dropdocs_get_ancestors($nid) {
  $ancestors   = array();
  $current_nid = (int) $nid;
  // Walk up; cap at 10 levels to guard against corrupt data.
  for ($i = 0; $i < 10; $i++) {
    $parent_nid = db_query(
      'SELECT field_doc_parent_target_id
       FROM {field_data_field_doc_parent}
       WHERE entity_id = :nid AND entity_type = :et',
      array(':nid' => $current_nid, ':et' => 'node')
    )->fetchField();
    if (!$parent_nid) {
      break;
    }
    $parent = node_load((int) $parent_nid);
    if (!$parent || $parent->type !== 'doc') {
      break;
    }
    array_unshift($ancestors, $parent);
    $current_nid = (int) $parent_nid;
  }
  return $ancestors;
}

/**
 * Implements hook_preprocess_node() for doc nodes.
 *
 * Suppresses the submitted-by metadata on doc nodes when viewed via our
 * custom admin path, since that information isn't relevant in a wiki context.
 */
function dropdocs_preprocess_node(&$variables) {
  if ($variables['node']->type !== 'doc') {
    return;
  }
  $variables['display_submitted'] = FALSE;
  // Our custom path drop/doc/{nid} is not the canonical node URL, so
  // node_is_page() returns FALSE and the template renders a duplicate title.
  // Set $page = TRUE to suppress it; backdrop_set_title() handles the H1.
  $path = current_path();
  if (strpos($path, 'drop/doc/') === 0) {
    $variables['page'] = TRUE;
  }
}

/**
 * Renders a nested doc tree as an HTML <ul> list.
 *
 * @param array $tree        Nested tree from dropdocs_build_tree().
 * @param int   $active_nid  Currently viewed nid (highlighted in the tree).
 *
 * @return string  HTML markup.
 */
function dropdocs_render_tree(array $tree, $active_nid = NULL) {
  if (empty($tree)) {
    return '';
  }
  $output = '<ul class="dropdocs-tree">';
  foreach ($tree as $doc) {
    $is_active    = ($active_nid && (int) $doc->nid === (int) $active_nid);
    $has_children = !empty($doc->children);
    $classes      = array();
    if ($is_active) {
      $classes[] = 'dropdocs-tree-active';
    }
    if ($has_children) {
      $classes[] = 'dropdocs-has-children';
    }
    $class_attr = $classes ? ' class="' . implode(' ', $classes) . '"' : '';
    $output .= '<li' . $class_attr . ' data-nid="' . (int) $doc->nid . '">';
    if ($has_children) {
      $output .= '<span class="dropdocs-tree-item">'
        . '<button class="dropdocs-toggle" aria-expanded="true" aria-label="' . t('Toggle') . '"></button>'
        . l(check_plain($doc->title), 'drop/doc/' . $doc->nid)
        . '</span>';
      $output .= dropdocs_render_tree($doc->children, $active_nid);
    }
    else {
      $output .= l(check_plain($doc->title), 'drop/doc/' . $doc->nid);
    }
    $output .= '</li>';
  }
  $output .= '</ul>';
  return $output;
}
