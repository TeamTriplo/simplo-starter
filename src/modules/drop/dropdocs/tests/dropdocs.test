<?php
/**
 * @file
 * Tests for the DropDocs module.
 */

/**
 * Shared base class: helpers for creating doc nodes.
 */
abstract class DropDocsTestBase extends BackdropWebTestCase {

  /** @var object User with full admin access to docs. */
  protected $adminUser;

  /** @var object User who can view and create docs. */
  protected $editorUser;

  /** @var object User who can only view docs. */
  protected $viewerUser;

  /**
   * Creates and saves a doc node.
   *
   * @param string   $title
   * @param int|null $parent_nid  NID of parent doc, or NULL for root.
   * @param string   $body        Body text.
   * @param int|null $uid         Author UID (defaults to adminUser).
   *
   * @return object  Saved node.
   */
  protected function createTestDoc($title, $parent_nid = NULL, $body = 'Test content.', $uid = NULL) {
    $node         = new Node();
    $node->type   = 'doc';
    $node->title  = $title;
    $node->status = 1;
    $node->uid    = $uid ?: $this->adminUser->uid;
    $node->body[LANGUAGE_NONE][0] = array(
      'value'  => $body,
      'format' => filter_default_format(),
    );
    if ($parent_nid) {
      $node->field_doc_parent[LANGUAGE_NONE][0]['target_id'] = (int) $parent_nid;
    }
    node_save($node);
    return $node;
  }
}

// ---------------------------------------------------------------------------
// Tree builder unit tests
// ---------------------------------------------------------------------------

/**
 * Tests dropdocs_build_tree() with in-memory data (no DB required).
 */
class DropDocsTreeTest extends BackdropWebTestCase {

  public static function getInfo() {
    return array(
      'name'        => 'DropDocs Tree Builder',
      'description' => 'Verifies dropdocs_build_tree() builds and sorts nested trees correctly.',
      'group'       => 'DropDocs',
    );
  }

  public function setUp() {
    parent::setUp('drop_base', 'entityreference', 'dropdocs');
  }

  /**
   * Constructs a minimal doc row object for passing to dropdocs_build_tree().
   */
  protected function makeDoc($nid, $title, $parent_nid = NULL, $weight = NULL) {
    return (object) array(
      'nid'        => $nid,
      'title'      => $title,
      'parent_nid' => $parent_nid,
      'weight'     => $weight,
    );
  }

  /**
   * Empty doc list returns an empty tree array.
   */
  public function testEmptyDocListReturnsEmptyTree() {
    $result = dropdocs_build_tree(array());
    $this->assertEqual(array(), $result, 'Empty doc list returns empty tree.');
  }

  /**
   * A single root doc appears at the top level with no children.
   */
  public function testSingleRootDocAppearsInTree() {
    $docs = array(1 => $this->makeDoc(1, 'Getting Started'));
    $tree = dropdocs_build_tree($docs);
    $this->assertEqual(1, count($tree), 'One root doc in tree.');
    $this->assertEqual('Getting Started', $tree[0]->title);
    $this->assertEqual(0, count($tree[0]->children), 'Root doc has no children.');
  }

  /**
   * A child doc is nested under its parent, not at the top level.
   */
  public function testChildDocNestedUnderParent() {
    $docs = array(
      1 => $this->makeDoc(1, 'Parent Doc'),
      2 => $this->makeDoc(2, 'Child Doc', 1),
    );
    $tree = dropdocs_build_tree($docs);
    $this->assertEqual(1, count($tree), 'Only one root-level item.');
    $this->assertEqual('Parent Doc', $tree[0]->title);
    $this->assertEqual(1, count($tree[0]->children), 'Parent has one child.');
    $this->assertEqual('Child Doc', $tree[0]->children[0]->title);
  }

  /**
   * Three levels of nesting are built correctly.
   */
  public function testMultipleLevelsOfNesting() {
    $docs = array(
      1 => $this->makeDoc(1, 'Root'),
      2 => $this->makeDoc(2, 'Level 2', 1),
      3 => $this->makeDoc(3, 'Level 3', 2),
    );
    $tree   = dropdocs_build_tree($docs);
    $level2 = $tree[0]->children;
    $level3 = $level2[0]->children;
    $this->assertEqual(1, count($tree), 'One root.');
    $this->assertEqual(1, count($level2), 'One level-2 item.');
    $this->assertEqual(1, count($level3), 'One level-3 item.');
    $this->assertEqual('Level 3', $level3[0]->title);
  }

  /**
   * Multiple root docs are all returned at the top level.
   */
  public function testMultipleRootDocsAllAtTopLevel() {
    $docs = array(
      1 => $this->makeDoc(1, 'Alpha'),
      2 => $this->makeDoc(2, 'Beta'),
      3 => $this->makeDoc(3, 'Gamma'),
    );
    $tree = dropdocs_build_tree($docs);
    $this->assertEqual(3, count($tree), 'Three root docs at top level.');
  }

  /**
   * Siblings with different weights are ordered lowest weight first.
   */
  public function testSiblingsOrderedByWeight() {
    $docs = array(
      1 => $this->makeDoc(1, 'Heavy', NULL, 10),
      2 => $this->makeDoc(2, 'Light', NULL, -5),
      3 => $this->makeDoc(3, 'Middle', NULL, 0),
    );
    $tree = dropdocs_build_tree($docs);
    $this->assertEqual('Light', $tree[0]->title, 'Lowest weight comes first.');
    $this->assertEqual('Middle', $tree[1]->title);
    $this->assertEqual('Heavy', $tree[2]->title, 'Highest weight comes last.');
  }

  /**
   * Siblings with the same weight are ordered alphabetically by title.
   */
  public function testSiblingsWithSameWeightOrderedAlphabetically() {
    $docs = array(
      1 => $this->makeDoc(1, 'Zebra', NULL, 0),
      2 => $this->makeDoc(2, 'Apple', NULL, 0),
      3 => $this->makeDoc(3, 'Mango', NULL, 0),
    );
    $tree = dropdocs_build_tree($docs);
    $this->assertEqual('Apple', $tree[0]->title);
    $this->assertEqual('Mango', $tree[1]->title);
    $this->assertEqual('Zebra', $tree[2]->title);
  }

  /**
   * Weight sorts before title: a lower weight doc beats an alphabetically
   * earlier doc with higher weight.
   */
  public function testWeightTakesPrecedenceOverTitle() {
    $docs = array(
      1 => $this->makeDoc(1, 'Apple', NULL, 10),
      2 => $this->makeDoc(2, 'Zebra', NULL, 0),
    );
    $tree = dropdocs_build_tree($docs);
    $this->assertEqual('Zebra', $tree[0]->title, 'Lower weight beats alphabetical order.');
    $this->assertEqual('Apple', $tree[1]->title);
  }

  /**
   * Docs with NULL weight are treated as weight 0.
   */
  public function testNullWeightTreatedAsZero() {
    $docs = array(
      1 => $this->makeDoc(1, 'Null weight doc', NULL, NULL),
      2 => $this->makeDoc(2, 'Zero weight doc', NULL, 0),
    );
    $tree = dropdocs_build_tree($docs);
    // Both have effective weight 0, so alphabetical: Null < Zero.
    $this->assertEqual('Null weight doc', $tree[0]->title);
    $this->assertEqual('Zero weight doc', $tree[1]->title);
  }
}

// ---------------------------------------------------------------------------
// Access control tests
// ---------------------------------------------------------------------------

/**
 * Tests that DropDocs pages respect the access dropdocs and administer
 * dropdocs permissions.
 */
class DropDocsAccessTest extends DropDocsTestBase {

  public static function getInfo() {
    return array(
      'name'        => 'DropDocs Access Control',
      'description' => 'Verifies that permissions gate the docs index, view, and reorder pages.',
      'group'       => 'DropDocs',
    );
  }

  public function setUp() {
    parent::setUp('drop_base', 'entityreference', 'dropdocs');

    $this->adminUser = $this->backdropCreateUser(array(
      'access dropdocs',
      'administer dropdocs',
      'create doc content',
      'edit any doc content',
      'delete any doc content',
    ));
    $this->editorUser = $this->backdropCreateUser(array(
      'access dropdocs',
      'create doc content',
      'edit own doc content',
    ));
    $this->viewerUser = $this->backdropCreateUser(array(
      'access dropdocs',
    ));
  }

  /**
   * Anonymous users cannot access the docs index.
   */
  public function testAnonymousCannotAccessIndex() {
    $this->backdropGet('drop/docs');
    $this->assertResponse(403);
  }

  /**
   * A user without 'access dropdocs' is denied the index.
   */
  public function testUserWithoutPermissionDeniedIndex() {
    $noAccess = $this->backdropCreateUser(array());
    $this->backdropLogin($noAccess);
    $this->backdropGet('drop/docs');
    $this->assertResponse(403);
  }

  /**
   * A user with 'access dropdocs' can view the index.
   */
  public function testViewerCanAccessIndex() {
    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/docs');
    $this->assertResponse(200);
  }

  /**
   * A user with 'access dropdocs' can view a doc node.
   */
  public function testViewerCanViewDoc() {
    $doc = $this->createTestDoc('Viewer Doc Test');

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/doc/' . $doc->nid);
    $this->assertResponse(200);
    $this->assertText('Viewer Doc Test');
  }

  /**
   * The Reorder tab requires 'administer dropdocs'.
   */
  public function testReorderRequiresAdminPermission() {
    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/docs/reorder');
    $this->assertResponse(403);

    $this->backdropLogin($this->adminUser);
    $this->backdropGet('drop/docs/reorder');
    $this->assertResponse(200);
  }

  /**
   * A user with 'create doc content' sees the Add doc action button.
   */
  public function testEditorSeesAddButton() {
    $this->backdropLogin($this->editorUser);
    $this->backdropGet('drop/docs');
    $this->assertText('Add doc');
  }

  /**
   * A user without 'create doc content' does not see the Add doc button.
   */
  public function testViewerDoesNotSeeAddButton() {
    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/docs');
    $this->assertNoText('Add doc');
  }
}

// ---------------------------------------------------------------------------
// CRUD tests
// ---------------------------------------------------------------------------

/**
 * Tests creating, viewing, and deleting doc nodes via the DropDocs UI.
 */
class DropDocsCRUDTest extends DropDocsTestBase {

  public static function getInfo() {
    return array(
      'name'        => 'DropDocs CRUD',
      'description' => 'Create, view, and delete doc nodes; verify they appear on the index.',
      'group'       => 'DropDocs',
    );
  }

  public function setUp() {
    parent::setUp('drop_base', 'entityreference', 'dropdocs');

    $this->adminUser = $this->backdropCreateUser(array(
      'access dropdocs',
      'administer dropdocs',
      'create doc content',
      'edit any doc content',
      'delete any doc content',
    ));
    $this->viewerUser = $this->backdropCreateUser(array(
      'access dropdocs',
    ));
  }

  /**
   * Index shows "No documentation yet." when no docs exist.
   */
  public function testIndexShowsEmptyMessage() {
    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/docs');
    $this->assertText('No documentation yet.');
  }

  /**
   * A created doc appears by title on the index page.
   */
  public function testCreatedDocAppearsOnIndex() {
    $this->createTestDoc('Installation Guide');

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/docs');
    $this->assertText('Installation Guide');
  }

  /**
   * The doc view page renders the doc title and body content.
   */
  public function testDocViewPageRendersContent() {
    $doc = $this->createTestDoc('API Reference', NULL, 'Detailed API docs here.');

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/doc/' . $doc->nid);
    $this->assertResponse(200);
    $this->assertText('API Reference');
    $this->assertText('Detailed API docs here.');
  }

  /**
   * Multiple docs all appear on the index.
   */
  public function testMultipleDocsAppearOnIndex() {
    $this->createTestDoc('First Doc');
    $this->createTestDoc('Second Doc');
    $this->createTestDoc('Third Doc');

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/docs');
    $this->assertText('First Doc');
    $this->assertText('Second Doc');
    $this->assertText('Third Doc');
  }

  /**
   * The doc view page shows the sidebar tree navigation.
   */
  public function testDocViewPageShowsSidebar() {
    $doc = $this->createTestDoc('Sidebar Test Doc');

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/doc/' . $doc->nid);
    $this->assertText('Documentation');
    $this->assertRaw('dropdocs-sidebar');
  }

  /**
   * Visiting a non-doc node at the doc view path returns 404.
   */
  public function testNonDocNodeReturnsNotFound() {
    // Create a basic page node (not a doc).
    $node         = new Node();
    $node->type   = 'post';
    $node->title  = 'A regular post';
    $node->status = 1;
    $node->uid    = $this->adminUser->uid;
    node_save($node);

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/doc/' . $node->nid);
    $this->assertResponse(404);
  }
}

// ---------------------------------------------------------------------------
// Hierarchy tests
// ---------------------------------------------------------------------------

/**
 * Tests parent-child hierarchy: tree rendering, breadcrumbs, and ancestry.
 */
class DropDocsHierarchyTest extends DropDocsTestBase {

  public static function getInfo() {
    return array(
      'name'        => 'DropDocs Hierarchy',
      'description' => 'Verifies parent-child doc relationships, tree rendering, and breadcrumbs.',
      'group'       => 'DropDocs',
    );
  }

  public function setUp() {
    parent::setUp('drop_base', 'entityreference', 'dropdocs');

    $this->adminUser = $this->backdropCreateUser(array(
      'access dropdocs',
      'administer dropdocs',
      'create doc content',
      'edit any doc content',
      'delete any doc content',
    ));
    $this->viewerUser = $this->backdropCreateUser(array(
      'access dropdocs',
    ));
  }

  /**
   * A child doc appears nested under its parent in the index tree.
   */
  public function testChildDocAppearsUnderParentOnIndex() {
    $parent = $this->createTestDoc('Parent Section');
    $this->createTestDoc('Child Page', $parent->nid);

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/docs');

    // Both titles should appear; the HTML order shows parent before child.
    $content = $this->backdropGetContent();
    $parent_pos = strpos($content, 'Parent Section');
    $child_pos  = strpos($content, 'Child Page');
    $this->assertTrue($parent_pos !== FALSE, 'Parent section appears on index.');
    $this->assertTrue($child_pos !== FALSE, 'Child page appears on index.');
    $this->assertTrue($parent_pos < $child_pos, 'Parent appears before child in markup.');
  }

  /**
   * The doc view page sidebar marks the active doc distinctively.
   */
  public function testActiveDocMarkedInSidebar() {
    $parent = $this->createTestDoc('Active Parent');
    $child  = $this->createTestDoc('Active Child', $parent->nid);

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/doc/' . $child->nid);

    $this->assertRaw('dropdocs-tree-active');
  }

  /**
   * The breadcrumb on a child doc view page includes the parent title as a link.
   */
  public function testChildDocBreadcrumbIncludesParent() {
    $parent = $this->createTestDoc('Breadcrumb Parent');
    $child  = $this->createTestDoc('Breadcrumb Child', $parent->nid);

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/doc/' . $child->nid);

    $this->assertText('Breadcrumb Parent');
    // The breadcrumb and/or sidebar should include a link to the parent doc.
    $this->assertRaw('drop/doc/' . $parent->nid);
  }

  /**
   * A root doc's breadcrumb contains Docs but no parent doc link.
   */
  public function testRootDocBreadcrumbContainsDocs() {
    $root = $this->createTestDoc('Root Breadcrumb Doc');

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/doc/' . $root->nid);

    // Docs index link appears in the breadcrumb.
    $this->assertRaw('drop/docs');
  }

  /**
   * The "Add child page" tab redirects to node/add/doc with parent param.
   */
  public function testAddChildTabRedirectsWithParentParam() {
    $creator = $this->backdropCreateUser(array(
      'access dropdocs',
      'create doc content',
    ));
    $parent = $this->createTestDoc('Redirect Parent');

    $this->backdropLogin($creator);
    $this->backdropGet('drop/doc/' . $parent->nid . '/add-child');

    // Should redirect to node/add/doc?parent={nid}.
    $this->assertUrl('node/add/doc', array('query' => array('parent' => $parent->nid)));
  }

  /**
   * The tree sidebar shows docs at all nesting levels.
   */
  public function testSidebarShowsMultiLevelTree() {
    $root   = $this->createTestDoc('Root Section');
    $level2 = $this->createTestDoc('Sub Section', $root->nid);
    $level3 = $this->createTestDoc('Deep Page', $level2->nid);

    $this->backdropLogin($this->viewerUser);
    $this->backdropGet('drop/doc/' . $level3->nid);

    $this->assertText('Root Section');
    $this->assertText('Sub Section');
    $this->assertText('Deep Page');
  }
}

// ---------------------------------------------------------------------------
// Reorder tests
// ---------------------------------------------------------------------------

/**
 * Tests that the reorder form saves weights and affects display order.
 */
class DropDocsReorderTest extends DropDocsTestBase {

  public static function getInfo() {
    return array(
      'name'        => 'DropDocs Reorder',
      'description' => 'Verifies that the reorder form saves weights and changes display order.',
      'group'       => 'DropDocs',
    );
  }

  public function setUp() {
    parent::setUp('drop_base', 'entityreference', 'dropdocs');

    $this->adminUser = $this->backdropCreateUser(array(
      'access dropdocs',
      'administer dropdocs',
      'create doc content',
      'edit any doc content',
      'delete any doc content',
    ));
  }

  /**
   * The reorder form shows "No docs to reorder." when no docs exist.
   */
  public function testReorderFormShowsEmptyMessage() {
    $this->backdropLogin($this->adminUser);
    $this->backdropGet('drop/docs/reorder');
    $this->assertText('No docs to reorder.');
  }

  /**
   * The reorder form lists all existing docs.
   */
  public function testReorderFormListsDocs() {
    $this->createTestDoc('Doc Alpha');
    $this->createTestDoc('Doc Beta');

    $this->backdropLogin($this->adminUser);
    $this->backdropGet('drop/docs/reorder');
    $this->assertText('Doc Alpha');
    $this->assertText('Doc Beta');
  }

  /**
   * Submitting the reorder form saves successfully and shows a confirmation.
   */
  public function testReorderFormSubmitSucceeds() {
    $doc = $this->createTestDoc('Reorder Save Test');

    $this->backdropLogin($this->adminUser);
    $this->backdropPost('drop/docs/reorder', array(
      'groups[0][' . $doc->nid . '][weight]' => 5,
    ), t('Save order'));

    $this->assertText('Doc order saved.');
  }

  /**
   * After saving a weight, the dropdocs_weight table is updated.
   */
  public function testReorderFormPersistsWeightToDatabase() {
    $doc = $this->createTestDoc('Weight Persist Test');

    $this->backdropLogin($this->adminUser);
    $this->backdropPost('drop/docs/reorder', array(
      'groups[0][' . $doc->nid . '][weight]' => 7,
    ), t('Save order'));

    $saved_weight = db_select('dropdocs_weight', 'w')
      ->fields('w', array('weight'))
      ->condition('nid', $doc->nid)
      ->execute()
      ->fetchField();

    $this->assertEqual(7, (int) $saved_weight,
      'Weight 7 is persisted to dropdocs_weight table after form submit.');
  }

  /**
   * The reorder page shows a "Top-level pages" group label.
   */
  public function testReorderFormShowsGroupLabels() {
    $this->createTestDoc('Grouped Doc');

    $this->backdropLogin($this->adminUser);
    $this->backdropGet('drop/docs/reorder');
    $this->assertText('Top-level pages');
  }

  /**
   * Child docs produce a "Children of …" group label on the reorder page.
   */
  public function testReorderFormShowsChildGroupLabel() {
    $parent = $this->createTestDoc('Parent Group Label');
    $this->createTestDoc('Child in group', $parent->nid);

    $this->backdropLogin($this->adminUser);
    $this->backdropGet('drop/docs/reorder');
    $this->assertText('Children of');
    $this->assertText('Parent Group Label');
  }
}
