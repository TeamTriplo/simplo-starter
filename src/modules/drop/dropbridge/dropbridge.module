/**
 * Implements hook_drop_nav_links().
 */
function dropbridge_drop_nav_links() {
  return array(
    array(
      'title'      => t('Dashboard'),
      'path'       => 'drop',
      'permission' => 'access dropbridge',
      'weight'     => 0,
    ),
  );
}

// ---------------------------------------------------------------------------
// Site announcement banner
// ---------------------------------------------------------------------------

/**
 * Implements hook_preprocess_layout().
 *
 * Injects a dismissible site announcement banner above the messages area on
 * every page for team members who have not yet dismissed the current message.
 *
 * Runs before layout_preprocess_layout() (weight 60) so that once we set
 * $variables['messages'], layout will leave it alone.
 */
function dropbridge_preprocess_layout(&$variables) {
  global $user;

  if (!backdrop_is_html()) {
    return;
  }

  if (!$user->uid || !user_access('access dropbridge')) {
    return;
  }

  $text = (string) config_get('dropbridge.settings', 'announcement_text');
  if (empty(trim($text))) {
    return;
  }

  $hash = substr(md5($text), 0, 8);

  // Check if this user has already dismissed this announcement.
  $dismissed = state_get('dropbridge.announcement_dismissed_' . $user->uid, '');
  if ($dismissed === $hash) {
    return;
  }

  $dismiss_url = url('drop/announcement/dismiss', array('query' => array('h' => $hash, 'destination' => current_path())));

  $banner  = '<div class="dropbridge-announcement" id="dropbridge-announcement">';
  $banner .= '<span class="dropbridge-announcement-text">' . check_plain($text) . '</span>';
  $banner .= '<a class="dropbridge-announcement-dismiss" href="' . $dismiss_url . '" title="' . t('Dismiss') . '">&#x2715;</a>';
  $banner .= '</div>';

  backdrop_add_css(backdrop_get_path('module', 'dropbridge') . '/dropbridge.css');

  // Prepend banner to messages. Setting $variables['messages'] here prevents
  // layout_preprocess_layout() from overwriting it.
  $existing_messages = isset($variables['messages']) ? $variables['messages'] : theme('status_messages');
  $variables['messages'] = $banner . $existing_messages;
}

/**
 * Page callback: dismiss the current site announcement for the current user.
 */
function dropbridge_announcement_dismiss() {
  global $user;

  $hash = isset($_GET['h']) ? preg_replace('/[^a-f0-9]/', '', $_GET['h']) : '';
  if ($hash) {
    state_set('dropbridge.announcement_dismissed_' . $user->uid, $hash);
  }

  backdrop_goto(isset($_GET['destination']) ? $_GET['destination'] : 'drop');
}
