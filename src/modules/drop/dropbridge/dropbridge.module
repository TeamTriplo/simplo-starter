 */

// ---------------------------------------------------------------------------
// Config info
// ---------------------------------------------------------------------------

/**
 * Implements hook_config_info().
 */
function dropbridge_config_info() {
  return array(
    'dropbridge.settings' => array(
      'label' => t('DropBridge settings'),
      'group' => t('Configuration'),
    ),
    'dropbridge.inbound' => array(
      'label' => t('DropBridge inbound email settings'),
      'group' => t('Configuration'),
    ),
  );
}

// ---------------------------------------------------------------------------
// Mail
// ---------------------------------------------------------------------------

/**
 * Implements hook_mail().
 *
 * Handles the 'inbound_forward' key — a copy of an inbound email forwarded
 * to the configured support address with a link to the ticket.
 */
function dropbridge_mail($key, &$message, $params) {
  if ($key !== 'inbound_forward') {
    return;
  }

  $sender_label = !empty($params['original_name'])
    ? $params['original_name'] . ' <' . $params['original_from'] . '>'
    : $params['original_from'];

  $message['subject'] = '[FWD] ' . $params['subject'];

  $body  = t('--- Forwarded inbound email ---') . "\n\n";
  $body .= t('From: @sender', array('@sender' => $sender_label)) . "\n";
  $body .= t('To: @to', array('@to' => $params['original_to'])) . "\n";
  $body .= t('Subject: @subject', array('@subject' => $params['subject'])) . "\n\n";
  $body .= $params['body'];
  $body .= "\n\n--- " . t('Ticket link') . " ---\n";
  $body .= $params['ticket_url'];

  $message['body'][] = $body;
}

