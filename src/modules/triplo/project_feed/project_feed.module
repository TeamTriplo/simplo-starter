<?php
/**
 * @file
 * Pulls data from GitHub about Backdrop CMS contrib projects and creates
 * or updates local project nodes. Uses Backdrop's Batch API to process
 * all pages of repos without hitting PHP timeouts.
 *
 * Two separate batch processes are provided:
 *   1. "Fetch all projects" — repo data, .info, releases, PRs → node fields.
 *   2. "Analyze READMEs with AI" — README → parsed maintainers + Claude tags.
 */

// ---------------------------------------------------------------------------
// Seed tag list for Claude prompts. Curated from existing community tags,
// normalised for consistency. Claude is asked to pick from this list (and may
// add one or two of its own if nothing fits).
// ---------------------------------------------------------------------------
define('PROJECT_FEED_SEED_TAGS', implode(', ', array(
  'Access Control', 'Administration', 'Analytics', 'API', 'Appearance',
  'Authentication', 'Blocks', 'Bootstrap', 'Calendar', 'CiviCRM', 'CKEditor',
  'Comments', 'Commerce', 'Content', 'Content Types', 'CSS', 'Data Migration',
  'Database', 'Dates', 'Developer Tools', 'Display', 'E-commerce', 'Education',
  'Email', 'Entertainment', 'Entity', 'Feeds', 'Fields', 'Files', 'Forms',
  'Gallery', 'Images', 'Infrastructure', 'jQuery', 'Language', 'Layout',
  'Logging', 'Mapping', 'Media', 'Menus', 'Mobile', 'Multilingual', 'Navigation',
  'Paragraphs', 'PDF', 'Performance', 'Permissions', 'Photo Display', 'Recipes',
  'Roles', 'Rules', 'Search', 'Security', 'SEO', 'Social', 'Spam Control',
  'Structure', 'Taxonomy', 'Testing', 'Theme', 'Third Party Integrations',
  'Tokens', 'Ubercart', 'User Interface', 'User Management', 'Video', 'Views',
  'Webform', 'Workflow',
)));


// ===========================================================================
// HOOKS
// ===========================================================================

/**
 * Implements hook_cron().
 *
 * Once per week, queues all pages of backdrop-contrib repos for processing.
 * Each page is handled by the project_feed_fetch queue worker on subsequent
 * cron runs, avoiding PHP timeouts.
 */
function project_feed_cron() {
  $pf_config = config('project_feed.settings');

  $intervals = array(
    'daily'   => 60 * 60 * 24,
    'weekly'  => 60 * 60 * 24 * 7,
    'monthly' => 60 * 60 * 24 * 30,
  );
  $frequency = $pf_config->get('fetch_frequency') ?: 'weekly';

  if ($frequency === 'never') {
    return;
  }

  $last_run = state_get('project_feed_last_fetch', 0);
  $interval = isset($intervals[$frequency]) ? $intervals[$frequency] : $intervals['weekly'];

  if (REQUEST_TIME - $last_run < $interval) {
    return;
  }
  $user  = $pf_config->get('username');
  $token = $pf_config->get('github_auth_token');

  if (empty($user) || empty($token)) {
    watchdog('project_feed', 'Weekly fetch skipped: GitHub credentials not configured.', array(), WATCHDOG_WARNING);
    return;
  }

  // Fetch page 1 to discover total page count via Link header.
  $response = project_feed_github_request(
    'https://api.github.com/orgs/backdrop-contrib/repos?per_page=50&page=1',
    $user, $token
  );

  if ($response['code'] != 200) {
    watchdog('project_feed', 'Weekly fetch failed: GitHub API returned HTTP @code.', array('@code' => $response['code']), WATCHDOG_ERROR);
    return;
  }

  preg_match('/page=(\d+)>; rel="last"/', $response['headers'], $m);
  $total_pages = isset($m[1]) ? (int) $m[1] : 1;

  $queue = BackdropQueue::get('project_feed_fetch');
  $queue->createQueue();
  for ($page = 1; $page <= $total_pages; $page++) {
    $queue->createItem(array('page' => $page, 'total_pages' => $total_pages));
  }

  state_set('project_feed_last_fetch', REQUEST_TIME);
  watchdog('project_feed', 'Weekly GitHub fetch queued: @total pages to process.', array('@total' => $total_pages), WATCHDOG_INFO);
}

/**
 * Implements hook_cron_queue_info().
 */
function project_feed_cron_queue_info() {
  return array(
    'project_feed_fetch' => array(
      'worker callback' => 'project_feed_queue_process_page',
      'time'            => 30,
    ),
  );
}

/**
 * Queue worker: fetch and process one page of repos from GitHub.
 *
 * @param array $data
 *   Queue item data with keys 'page' and 'total_pages'.
 */
function project_feed_queue_process_page($data) {
  $context = array('results' => array('created' => 0, 'updated' => 0, 'errors' => array()));
  project_feed_fetch_page($data['page'], $data['total_pages'], $context);

  if (!empty($context['results']['errors'])) {
    foreach ($context['results']['errors'] as $error) {
      watchdog('project_feed', 'Cron fetch error: @error', array('@error' => $error), WATCHDOG_WARNING);
    }
  }
}

/**
 * Implements hook_config_info().
 */
function project_feed_config_info() {
  $prefixes['project_feed.settings'] = array(
    'label' => t('GitHub API settings'),
    'group' => t('Configuration'),
  );
  return $prefixes;
}

/**
 * Implements hook_menu().
 */
function project_feed_menu() {
  $items = array();

  $items['admin/config/services/projects/settings'] = array(
    'title'            => 'Backdrop Projects',
    'page callback'    => 'backdrop_get_form',
    'page arguments'   => array('project_feed_settings'),
    'access callback'  => 'user_access',
    'access arguments' => array('administer site configuration'),
    'description'      => 'Project Feed Configuration.',
    'file'             => 'project_feed.admin.inc',
    'type'             => MENU_LOCAL_TASK,
  );

  // Abort endpoint: sets a flag that the README analysis batch checks each tick.
  $items['admin/config/services/projects/abort'] = array(
    'title'            => 'Abort README analysis',
    'page callback'    => 'project_feed_abort_analysis',
    'access callback'  => 'user_access',
    'access arguments' => array('administer site configuration'),
    'type'             => MENU_CALLBACK,
  );

  return $items;
}

/**
 * Page callback: set the abort flag and redirect back to settings.
 */
function project_feed_abort_analysis() {
  $pf_config = config('project_feed.settings');
  $pf_config->set('abort_analysis', TRUE);
  $pf_config->save();
  backdrop_set_message(t('Abort requested — the analysis will stop after the current project finishes.'));
  backdrop_goto('admin/config/services/projects/settings');
}


// ===========================================================================
// BATCH 1 — GITHUB DATA FETCH
// ===========================================================================

/**
 * Form submit handler: start the GitHub data fetch batch.
 */
function project_feed_start_fetch($form, &$form_state) {
  $pf_config = config('project_feed.settings');
  $user  = $pf_config->get('username');
  $token = $pf_config->get('github_auth_token');

  if (empty($user) || empty($token)) {
    backdrop_set_message(t('Please configure your GitHub username and auth token before fetching.'), 'error');
    return;
  }

  // Fetch page 1 to discover the total number of pages via the Link header.
  $response = project_feed_github_request(
    'https://api.github.com/orgs/backdrop-contrib/repos?per_page=50&page=1',
    $user, $token
  );

  if ($response['code'] != 200) {
    backdrop_set_message(t('GitHub API returned HTTP @code. Check your credentials.', array('@code' => $response['code'])), 'error');
    return;
  }

  preg_match('/page=(\d+)>; rel="last"/', $response['headers'], $m);
  $total_pages = isset($m[1]) ? (int) $m[1] : 1;

  $operations = array();
  for ($page = 1; $page <= $total_pages; $page++) {
    $operations[] = array('project_feed_fetch_page', array($page, $total_pages));
  }

  state_set('project_feed_last_manual_fetch', REQUEST_TIME);

  batch_set(array(
    'operations'       => $operations,
    'finished'         => 'project_feed_fetch_finished',
    'title'            => t('Fetching Backdrop contrib projects from GitHub'),
    'init_message'     => t('Starting GitHub data fetch (@total pages)…', array('@total' => $total_pages)),
    'progress_message' => '',
    'error_message'    => t('An error occurred during the fetch.'),
  ));
}

/**
 * Batch operation: fetch and process one page of 50 repos from GitHub.
 */
function project_feed_fetch_page($page, $total_pages, &$context) {
  $context['results'] += array('created' => 0, 'updated' => 0, 'errors' => array());

  $pf_config = config('project_feed.settings');
  $user  = $pf_config->get('username');
  $token = $pf_config->get('github_auth_token');

  $response = project_feed_github_request(
    'https://api.github.com/orgs/backdrop-contrib/repos?per_page=50&page=' . $page,
    $user, $token
  );

  if ($response['code'] != 200) {
    $context['results']['errors'][] = t('Page @page: GitHub returned HTTP @code.', array('@page' => $page, '@code' => $response['code']));
    return;
  }

  $repos = json_decode($response['body'], TRUE);
  if (empty($repos)) {
    return;
  }

  foreach ($repos as $repo) {
    try {
      $result = project_feed_process_repo($repo, $user, $token);
      $context['results'][$result] = ($context['results'][$result] ?? 0) + 1;
    }
    catch (Exception $e) {
      $context['results']['errors'][] = t('@repo: @msg', array('@repo' => $repo['name'], '@msg' => $e->getMessage()));
    }
  }

  $context['message'] = t('Processed page @page of @total.', array('@page' => $page, '@total' => $total_pages));
}

/**
 * Fetch all GitHub data for one repo and save it as a project node.
 *
 * This is the single shared helper used by both the batch process and the
 * single-project fetch, ensuring both paths handle data identically.
 *
 * @param array $repo
 *   Repo array from the GitHub API (list or single-repo endpoint).
 * @param string $user
 *   GitHub username for API authentication.
 * @param string $token
 *   GitHub personal access token.
 *
 * @return string
 *   'created' or 'updated'.
 *
 * @throws Exception
 */
function project_feed_process_repo($repo, $user, $token) {
  // Fetch the .info file for Backdrop-specific metadata.
  $info_response = project_feed_github_request(
    'https://api.github.com/repos/backdrop-contrib/' . $repo['name'] . '/contents/' . $repo['name'] . '.info',
    $user, $token, 'application/vnd.github.raw+json'
  );
  $info = ($info_response['code'] == 200) ? backdrop_parse_info_format($info_response['body']) : array();

  // Releases count (up to 100).
  $rel = project_feed_github_request(
    'https://api.github.com/repos/backdrop-contrib/' . $repo['name'] . '/releases?per_page=100',
    $user, $token
  );
  $releases_count = 0;
  if ($rel['code'] == 200) {
    $r = json_decode($rel['body'], TRUE);
    $releases_count = is_array($r) ? count($r) : 0;
  }

  // Open PR count (up to 100).
  $prs = project_feed_github_request(
    'https://api.github.com/repos/backdrop-contrib/' . $repo['name'] . '/pulls?state=open&per_page=100',
    $user, $token
  );
  $open_prs = 0;
  if ($prs['code'] == 200) {
    $p = json_decode($prs['body'], TRUE);
    $open_prs = is_array($p) ? count($p) : 0;
  }

  // open_issues_count from GitHub includes PRs; subtract for issues only.
  $open_issues = max(0, (int) $repo['open_issues_count'] - $open_prs);

  return project_feed_save_project($repo, $info, $releases_count, $open_issues, $open_prs);
}

/**
 * Batch finished callback for the GitHub data fetch.
 */
function project_feed_fetch_finished($success, $results, $operations) {
  if ($success) {
    backdrop_set_message(t('GitHub sync complete: @created new, @updated updated.', array(
      '@created' => $results['created'] ?? 0,
      '@updated' => $results['updated'] ?? 0,
    )));
    foreach (($results['errors'] ?? array()) as $error) {
      backdrop_set_message($error, 'warning');
    }
  }
  else {
    backdrop_set_message(t('Fetch incomplete. @count page(s) not processed.', array('@count' => count($operations))), 'error');
  }
}


// ===========================================================================
// BATCH 2 — README ANALYSIS (MAINTAINERS + AI TAGS)
// ===========================================================================

/**
 * Form submit handler: start the README analysis batch.
 */
function project_feed_start_readme_analysis($form, &$form_state) {
  $pf_config  = config('project_feed.settings');
  $user       = $pf_config->get('username');
  $token      = $pf_config->get('github_auth_token');
  $claude_key = $pf_config->get('claude_api_key');

  if (empty($user) || empty($token)) {
    backdrop_set_message(t('GitHub credentials are required.'), 'error');
    return;
  }
  if (empty($claude_key)) {
    backdrop_set_message(t('An Anthropic API key is required for README analysis.'), 'error');
    return;
  }

  $all_nids = db_query("SELECT COUNT(*) FROM {node} WHERE type = 'project' AND status = 1")->fetchField();
  if (!$all_nids) {
    backdrop_set_message(t('No project nodes found. Run the GitHub fetch first.'), 'warning');
    return;
  }

  // Clear any leftover abort flag from a previous run.
  $pf_config->set('abort_analysis', FALSE);
  $pf_config->save();

  // A single looping operation uses $context['sandbox'] to track state.
  // This means setting $context['finished'] = 1 inside the operation truly
  // ends the entire batch — making the abort button work correctly.
  batch_set(array(
    'operations'       => array(array('project_feed_analyze_readme_operation', array())),
    'finished'         => 'project_feed_readme_analysis_finished',
    'title'            => t('Analyzing project READMEs with AI'),
    'init_message'     => t('Starting README analysis…'),
    'progress_message' => '',
    'error_message'    => t('An error occurred during README analysis.'),
  ));
}

/**
 * Batch operation: process one project node per call using sandbox state.
 *
 * Using a single looping operation (rather than one operation per node) means
 * that setting $context['finished'] = 1 genuinely ends the entire batch,
 * which is required for the abort button to work.
 *
 * @param array $context
 *   Batch API context.
 */
function project_feed_analyze_readme_operation(&$context) {
  // Initialize sandbox on the very first call.
  if (empty($context['sandbox'])) {
    $all_nids = db_query(
      "SELECT nid FROM {node} WHERE type = 'project' AND status = 1 ORDER BY nid"
    )->fetchCol();
    $tagged_nids = db_query(
      "SELECT DISTINCT entity_id FROM {field_data_field_auto_tags} WHERE bundle = 'project'"
    )->fetchCol();
    $nids = array_values(array_diff($all_nids, $tagged_nids));

    $context['sandbox']['nids']    = $nids;
    $context['sandbox']['total']   = count($nids);
    $context['sandbox']['current'] = 0;
    $context['results'] += array('processed' => 0, 'no_readme' => 0, 'errors' => array());

    $skipped = count($all_nids) - count($nids);
    if ($skipped) {
      $context['results']['skipped'] = $skipped;
    }
  }

  $total = $context['sandbox']['total'];

  // Nothing left to process (e.g. all nodes already tagged).
  if ($total === 0 || $context['sandbox']['current'] >= $total) {
    $context['finished'] = 1;
    return;
  }

  // Check for an abort request set via admin/config/services/projects/abort.
  $pf_config = config('project_feed.settings');
  if ($pf_config->get('abort_analysis')) {
    $pf_config->set('abort_analysis', FALSE);
    $pf_config->save();
    $context['finished'] = 1;
    $context['results']['aborted'] = TRUE;
    return;
  }

  $user       = $pf_config->get('username');
  $token      = $pf_config->get('github_auth_token');
  $claude_key = $pf_config->get('claude_api_key');

  $nid  = $context['sandbox']['nids'][$context['sandbox']['current']];
  $node = node_load($nid);

  if (!$node) {
    $context['results']['processed']++;
    $context['sandbox']['current']++;
    $context['finished'] = $context['sandbox']['current'] / $total;
    return;
  }

  $repo_name = $node->title; // Node title is the GitHub repo machine name.
  $lang      = LANGUAGE_NONE;
  $changed   = FALSE;

  // Fetch the README via the GitHub API (returns raw markdown).
  $readme_response = project_feed_github_request(
    'https://api.github.com/repos/backdrop-contrib/' . $repo_name . '/readme',
    $user, $token, 'application/vnd.github.raw+json'
  );
  $readme_text = ($readme_response['code'] == 200) ? $readme_response['body'] : '';

  // --- Parse maintainers (whenever we have a README) -----------------------
  if ($readme_text !== '') {
    $maintainers = project_feed_parse_maintainers($readme_text);
    if (!empty($maintainers)) {
      $node->field_maintainer_parsed[$lang] = array();
      foreach ($maintainers as $m) {
        $node->field_maintainer_parsed[$lang][] = array('value' => $m);
      }
      $changed = TRUE;
    }
  }

  // --- AI tag generation ---------------------------------------------------
  // Determine project type so we can apply special-case tag rules.
  $project_type = '';
  if (!empty($node->field_project_type[$lang][0]['tid'])) {
    $type_term    = taxonomy_term_load($node->field_project_type[$lang][0]['tid']);
    $project_type = $type_term ? strtolower(trim($type_term->name)) : '';
  }

  if ($project_type === 'theme' || $project_type === 'layout') {
    // Themes and layouts get exactly one tag — no Claude call needed.
    $tag_name = ($project_type === 'theme') ? 'Theme' : 'Layout';
    $tid = project_feed_get_or_create_term($tag_name, 'auto_tags');
    if ($tid) {
      $node->field_auto_tags[$lang] = array(array('tid' => $tid));
      $changed = TRUE;
    }
  }
  elseif ($readme_text === '') {
    // No README — tag so future runs skip this node and it surfaces in views.
    $tid = project_feed_get_or_create_term('No Readme', 'auto_tags');
    if ($tid) {
      $node->field_auto_tags[$lang] = array(array('tid' => $tid));
      $changed = TRUE;
    }
    $context['results']['no_readme']++;
  }
  else {
    // Normal case: ask Claude to categorise from the README text.
    // Small pause to avoid bursting over the 50 RPM Tier 1 limit.
    sleep(1);
    $tags = project_feed_claude_generate_tags($readme_text, $claude_key);
    if (!empty($tags)) {
      $node->field_auto_tags[$lang] = array();
      foreach ($tags as $tag_name) {
        $tid = project_feed_get_or_create_term($tag_name, 'auto_tags');
        if ($tid) {
          $node->field_auto_tags[$lang][] = array('tid' => $tid);
        }
      }
      $changed = TRUE;
    }
  }

  if ($changed) {
    node_save($node);
  }

  $context['results']['processed']++;
  $context['sandbox']['current']++;
  $context['finished'] = $context['sandbox']['current'] / $total;

  $abort_link = l(t('Abort analysis'), 'admin/config/services/projects/abort',
    array('attributes' => array('target' => '_blank')));
  $context['message'] = t('Analyzed @done of @total projects.', array(
    '@done'  => $context['results']['processed'],
    '@total' => $total,
  )) . ' &nbsp; [' . $abort_link . ']';
}

/**
 * Batch finished callback for README analysis.
 */
function project_feed_readme_analysis_finished($success, $results, $operations) {
  if (!empty($results['aborted'])) {
    backdrop_set_message(t('README analysis aborted after @processed projects. Run again to continue where it left off.', array(
      '@processed' => $results['processed'] ?? 0,
    )), 'warning');
    return;
  }
  if ($success) {
    $msg = t('README analysis complete: @processed projects analyzed, @no_readme had no README.', array(
      '@processed' => $results['processed'] ?? 0,
      '@no_readme' => $results['no_readme'] ?? 0,
    ));
    if (!empty($results['skipped'])) {
      $msg .= ' ' . t('(@skipped already-tagged nodes were skipped.)', array('@skipped' => $results['skipped']));
    }
    backdrop_set_message($msg);
    foreach (($results['errors'] ?? array()) as $error) {
      backdrop_set_message($error, 'warning');
    }
  }
  else {
    backdrop_set_message(t('README analysis did not complete successfully.'), 'error');
  }
}


// ===========================================================================
// MAINTAINER PARSING
// ===========================================================================

/**
 * Parse maintainer names and GitHub usernames from a README.
 *
 * Handles all common README formats used across backdrop-contrib repos:
 *   - [Display Name](https://github.com/username)
 *   - Display Name ([@username](https://github.com/username))
 *   - [Display Name (username)](https://github.com/username)
 *
 * Returns each maintainer as "Real Name (username)" when a real name is
 * available, or just "username" when only the GitHub handle is present.
 *
 * @param string $readme_text
 *   Raw README markdown content.
 *
 * @return array
 *   Array of maintainer strings, deduplicated.
 */
function project_feed_parse_maintainers($readme_text) {
  $maintainers = array();

  // Normalize line endings.
  $readme_text = str_replace("\r\n", "\n", $readme_text);

  // Step 1: Find the start of the maintainers section.
  //
  // Heading forms supported:
  //   ## Current Maintainers            ATX heading, optional "Current" prefix
  //   ## Current Maintainer(s):         (s) and trailing colon
  //   ## Current Maintainers for Backdrop  any trailing words
  //   Current Maintainers\n---          Setext underline heading
  //
  // [^\n]* after maintainers? lets any trailing text through so we don't
  // need to enumerate every variation authors use.
  if (!preg_match(
    '/(?:#{1,4}[ \t]*(?:current[ \t]+)?maintainers?[^\n]*\n|(?:current[ \t]+)?maintainers?[^\n]*\n[-=]+[ \t]*\n)/isu',
    $readme_text, $m, PREG_OFFSET_CAPTURE
  )) {
    return $maintainers;
  }

  // Step 2: Extract the section body — everything after the heading until the
  // next ATX heading (##) or the end of the string.
  $body_start = $m[0][1] + strlen($m[0][0]);
  $body = substr($readme_text, $body_start);
  // Stop at the next ATX heading.
  if (preg_match('/^#{1,4}[ \t]/mu', $body, $stop, PREG_OFFSET_CAPTURE)) {
    $body = substr($body, 0, $stop[0][1]);
  }

  // Step 3: Process each line.
  foreach (explode("\n", $body) as $line) {
    $line = trim($line);

    // Skip blank lines.
    if ($line === '') {
      continue;
    }

    // Strip leading list bullet (-, *, or +).
    $line = preg_replace('/^[-*+]\s+/', '', $line);
    $line = trim($line);

    if ($line === '') {
      continue;
    }

    // Skip "seeking maintainers", "unmaintained", "contributors welcome", etc.
    if (preg_match('/\b(?:seeking|unmaintained|additional maintainer|contributor|welcomed?)\b/i', $line)) {
      continue;
    }

    // -----------------------------------------------------------------
    // Identify the maintainer: prefer a GitHub URL as canonical ID.
    // -----------------------------------------------------------------
    if (preg_match('!https?://github\.com/([a-zA-Z0-9][a-zA-Z0-9_-]*)/?!', $line, $url_match)) {
      $username = $url_match[1];
      $display_name = '';

      // Format A: [Display Name](https://github.com/...)
      // Also handles trailing text: [Name](url) (extra text)
      if (preg_match('/^\[([^\]]+)\]\(https?:\/\/github\.com/i', $line, $nm)) {
        $display_name = $nm[1];
        // Strip embedded parenthetical username: "[Jason Flatt (oadaeh)]" → "Jason Flatt"
        $display_name = preg_replace('/\s*\([^)]+\)\s*$/', '', $display_name);
      }
      // Format B: Name ([@username](...)) or Name ([Name](...)) or Name (url)
      // Real name is everything before the first parenthesis or bracket.
      elseif (preg_match('/^([^(\[]+)\s*\(/', $line, $nm)) {
        $display_name = $nm[1];
      }

      $display_name = trim($display_name, " \t.");
    }
    // No GitHub URL — fall back to @username in parentheses.
    // Handles: Tim Erickson (@stpaultim)
    elseif (preg_match('/\(@([a-zA-Z0-9][a-zA-Z0-9_-]*)\)/', $line, $at_match)) {
      $username = $at_match[1];
      // Display name is everything before the (@...) block.
      $display_name = trim(preg_replace('/\s*\(@[^)]+\).*/', '', $line), " \t.");
    }
    else {
      // No GitHub URL and no @username — skip (can't reliably identify person).
      continue;
    }

    // Format the result as "Real Name (username)" or just "username".
    if (!empty($display_name) && strcasecmp($display_name, $username) !== 0) {
      $maintainers[] = $display_name . ' (' . $username . ')';
    }
    else {
      $maintainers[] = $username;
    }
  }

  return array_values(array_unique($maintainers));
}


// ===========================================================================
// CLAUDE API INTEGRATION
// ===========================================================================

/**
 * Call the Claude API to generate category tags for a module README.
 *
 * Sends up to the first 3000 characters of the README to claude-haiku,
 * asking it to choose from the curated seed tag list (PROJECT_FEED_SEED_TAGS).
 *
 * @param string $readme_text
 *   Raw README markdown.
 * @param string $api_key
 *   Anthropic API key.
 *
 * @return array
 *   Array of tag strings, or empty array on failure.
 */
function project_feed_claude_generate_tags($readme_text, $api_key) {
  // Truncate to keep token costs low; the first ~3000 chars hold the key info.
  $truncated = mb_substr($readme_text, 0, 3000);

  $prompt = 'You are categorizing a Backdrop CMS module based on its README.

Choose 3 to 6 tags from the list below that best describe what this module DOES.
Prefer more specific tags over generic ones.
You may add at most 2 tags not on the list if the module clearly fits a category not covered.

Rules:
- If the project is a theme or layout template, return ONLY the single tag "Theme" or "Layout".
- Use "Recipes" for modules that handle actual recipe content or provide tools for working with recipes. Do NOT use "Developer Tools" for these.
- Use "Entertainment" for fun or novelty modules with little practical value (examples: novelty text filters, visual jokes, games, "Aussie Slang", "Do a barrel roll", "Pirate Filter").
- Use "PDF" for modules that generate, display, import, or process PDF files.
- Use "Database" for modules focused on direct database management, query builders, or low-level database utilities.

Available tags:
' . PROJECT_FEED_SEED_TAGS . '

Return ONLY a JSON array of tag strings, no explanation, no markdown fences.
Example: ["Views", "Fields", "Content"]

README:
' . $truncated;

  $payload = json_encode(array(
    'model'      => 'claude-haiku-4-5-20251001',
    'max_tokens' => 200,
    'messages'   => array(
      array('role' => 'user', 'content' => $prompt),
    ),
  ));

  $ch = curl_init('https://api.anthropic.com/v1/messages');
  curl_setopt($ch, CURLOPT_HTTPHEADER, array(
    'Content-Type: application/json',
    'x-api-key: ' . $api_key,
    'anthropic-version: 2023-06-01',
  ));
  curl_setopt($ch, CURLOPT_POST, TRUE);
  curl_setopt($ch, CURLOPT_POSTFIELDS, $payload);
  curl_setopt($ch, CURLOPT_RETURNTRANSFER, TRUE);
  curl_setopt($ch, CURLOPT_TIMEOUT, 30);

  $response  = curl_exec($ch);
  $http_code = curl_getinfo($ch, CURLINFO_HTTP_CODE);
  curl_close($ch);

  if ($http_code != 200) {
    watchdog('project_feed', 'Claude API returned HTTP @code: @body', array('@code' => $http_code, '@body' => substr($response, 0, 500)), WATCHDOG_WARNING);
    return array();
  }

  $data = json_decode($response, TRUE);
  $text = isset($data['content'][0]['text']) ? trim($data['content'][0]['text']) : '';

  if (empty($text)) {
    return array();
  }

  // Strip any accidental markdown fences before decoding.
  $text = preg_replace('/^```[a-z]*\n?/i', '', $text);
  $text = preg_replace('/\n?```$/', '', $text);

  $tags = json_decode(trim($text), TRUE);
  if (!is_array($tags)) {
    return array();
  }

  // Sanitise: keep only non-empty strings, max 255 chars each.
  $clean = array();
  foreach ($tags as $tag) {
    $tag = trim((string) $tag);
    if ($tag !== '' && strlen($tag) <= 255) {
      $clean[] = $tag;
    }
  }

  return $clean;
}


// ===========================================================================
// NODE SAVE HELPER
// ===========================================================================

/**
 * Create a new project node or update GitHub-sourced fields on an existing one.
 *
 * User-entered fields (maintainer, community tags, editor notes, official page,
 * related modules, seeking maintainers, maintenance check) are never touched
 * when updating an existing node.
 *
 * @return string 'created' or 'updated'.
 */
function project_feed_save_project($repo, $info, $releases_count, $open_issues, $open_prs) {
  $nid = db_query(
    "SELECT nid FROM {node} WHERE title = :title AND type = 'project'",
    array(':title' => $repo['name'])
  )->fetchField();

  if ($nid) {
    $node   = node_load($nid);
    $is_new = FALSE;
  }
  else {
    $node = new Node(array(
      'type'     => 'project',
      'title'    => $repo['name'],
      'uid'      => 1,
      'status'   => 1,
      'language' => LANGUAGE_NONE,
    ));
    $is_new = TRUE;
  }

  $lang = LANGUAGE_NONE;

  $node->field_name[$lang][0]['value'] = !empty($info['name']) ? $info['name'] : $repo['name'];

  // Strip 4-byte UTF-8 characters (emoji, etc.) — the DB connection uses utf8mb3
  // which cannot store them, even though the column is utf8mb4.
  $description = isset($repo['description']) ? $repo['description'] : '';
  $description = preg_replace('/[\x{10000}-\x{10FFFF}]/u', '', $description);
  $node->body[$lang][0] = array(
    'value'  => $description,
    'format' => 'filtered_html',
  );

  $node->field_github[$lang][0] = array(
    'url'        => $repo['svn_url'],
    'title'      => '',
    'attributes' => array(),
  );

  if (!empty($repo['homepage'])) {
    $node->field_home_page[$lang][0] = array(
      'url'        => $repo['homepage'],
      'title'      => '',
      'attributes' => array(),
    );
  }
  elseif (!$is_new) {
    $node->field_home_page[$lang] = array();
  }

  $node->field_created[$lang][0] = array(
    'value'       => strtotime($repo['created_at']),
    'timezone'    => 'UTC',
    'timezone_db' => 'UTC',
    'date_type'   => 'datestamp',
  );
  $node->field_updated[$lang][0] = array(
    'value'       => strtotime($repo['pushed_at']),
    'timezone'    => 'UTC',
    'timezone_db' => 'UTC',
    'date_type'   => 'datestamp',
  );

  $node->field_releases[$lang][0]['value']    = $releases_count;
  $node->field_open_issues[$lang][0]['value'] = $open_issues;
  $node->field_forks[$lang][0]['value']       = $repo['forks_count'];
  $node->field_open_prs[$lang][0] = array(
    'value'  => (string) $open_prs,
    'format' => 'filtered_html',
  );

  $node->field_package[$lang][0]['value'] = !empty($info['package']) ? $info['package'] : '';

  if (!empty($info['type'])) {
    $type_tid = db_query(
      "SELECT tid FROM {taxonomy_term_data} WHERE name = :name AND vocabulary = 'project_type'",
      array(':name' => trim($info['type']))
    )->fetchField();
    if ($type_tid) {
      $node->field_project_type[$lang][0] = array('tid' => (int) $type_tid);
    }
  }

  if (!empty($info['tags'])) {
    $tags = is_array($info['tags']) ? $info['tags'] : array($info['tags']);
    $node->field_tags_maintainer[$lang] = array();
    foreach ($tags as $tag_name) {
      $tag_name = trim($tag_name);
      if ($tag_name === '') {
        continue;
      }
      $tid = project_feed_get_or_create_term($tag_name, 'tags');
      if ($tid) {
        $node->field_tags_maintainer[$lang][] = array('tid' => $tid);
      }
    }
  }

  // Maintainers from .info file.
  if (!empty($info['maintainers'])) {
    $maintainers = is_array($info['maintainers']) ? $info['maintainers'] : array($info['maintainers']);
    $node->field_info_maintainers[$lang] = array();
    foreach ($maintainers as $username) {
      $username = trim($username);
      if ($username !== '') {
        $node->field_info_maintainers[$lang][] = array('value' => $username);
      }
    }
  }
  elseif (!$is_new) {
    $node->field_info_maintainers[$lang] = array();
  }

  // Set the seeking maintainers flag if the .info file declares it.
  // Only set to TRUE from .info data; never override a manually set TRUE value.
  if (!empty($info['maintainers_wanted'])) {
    $node->field_seeking_maintainers[$lang][0]['value'] = 1;
  }

  node_save($node);
  return $is_new ? 'created' : 'updated';
}


// ===========================================================================
// SHARED HELPERS
// ===========================================================================

/**
 * Look up a taxonomy term by name, creating it if absent.
 *
 * Uses a direct DB query for the lookup to avoid a PHP 8.3 incompatibility
 * in Backdrop's entity controller (taxonomy_term_load_multiple_by_name).
 *
 * @param string $name
 *   Term name.
 * @param string $vocabulary
 *   Vocabulary machine name.
 *
 * @return int|null
 *   Term ID, or NULL on failure.
 */
function project_feed_get_or_create_term($name, $vocabulary) {
  $tid = db_query(
    "SELECT tid FROM {taxonomy_term_data} WHERE name = :name AND vocabulary = :vocab",
    array(':name' => trim($name), ':vocab' => $vocabulary)
  )->fetchField();

  if ($tid) {
    return (int) $tid;
  }

  // Verify the vocabulary exists via Backdrop config (no {taxonomy_vocabulary} table).
  if (!taxonomy_vocabulary_load($vocabulary)) {
    return NULL;
  }

  $term = new TaxonomyTerm(array(
    'name'        => trim($name),
    'vocabulary'  => $vocabulary,
    'description' => '',
    'format'      => NULL,
    'weight'      => 0,
    'langcode'    => LANGUAGE_NONE,
  ));
  taxonomy_term_save($term);

  return isset($term->tid) ? (int) $term->tid : NULL;
}

/**
 * Make an authenticated GET request to the GitHub API.
 *
 * @param string $url
 * @param string $user   GitHub username (used as User-Agent).
 * @param string $token  GitHub personal access token.
 * @param string $accept Accept header; use 'application/vnd.github.raw+json'
 *                       for file-contents endpoints.
 *
 * @return array Keys: 'code' (int), 'headers' (string), 'body' (string).
 */
function project_feed_github_request($url, $user, $token, $accept = 'application/vnd.github+json') {
  $ch = curl_init($url);
  curl_setopt($ch, CURLOPT_HTTPHEADER, array(
    'Accept: ' . $accept,
    'User-Agent: ' . $user,
    'Authorization: token ' . $token,
    'X-GitHub-Api-Version: 2022-11-28',
  ));
  curl_setopt($ch, CURLOPT_RETURNTRANSFER, TRUE);
  curl_setopt($ch, CURLOPT_HEADER, TRUE);
  curl_setopt($ch, CURLOPT_TIMEOUT, 30);

  $response  = curl_exec($ch);
  $http_code = curl_getinfo($ch, CURLINFO_HTTP_CODE);
  $hdr_size  = curl_getinfo($ch, CURLINFO_HEADER_SIZE);
  curl_close($ch);

  return array(
    'code'    => $http_code,
    'headers' => substr($response, 0, $hdr_size),
    'body'    => substr($response, $hdr_size),
  );
}
