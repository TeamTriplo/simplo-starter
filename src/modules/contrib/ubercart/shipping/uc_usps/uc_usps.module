    'MMNB' => 'Media Mail Nonstandard Basic',
    'MMNS' => 'Media Mail Nonstandard Single-piece',
    'MMMS' => 'Media Mail Machinable Single-piece',
    'MMM5' => 'Media Mail Machinable 5-digit',
    'MMN5' => 'Media Mail Nonstandard 5-digit',
  );
}

