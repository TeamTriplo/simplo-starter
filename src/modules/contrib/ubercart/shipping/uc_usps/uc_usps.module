/**
 * Returns TRUE if country code is domestic. (newapi)
 */
function _uc_usps_is_domestic($country) {
  $countries = _uc_usps_domestic_countries();
  return isset($countries[$country]);
}

/**
 * Return whether package contents fit within a specified type of envelope. If
 * the type isn't an envelope, return TRUE, because USPS automatically accounts
 * for the size for the fixed-size boxes. (newapi)
 *
 * @param object $package
 *   The package object containing the products.
 * @param string $service_key
 *   The service key for the rate returned by USPS, constructed from the first
 *   letters of the rate description.
 *
 * @return bool
 *   Return whether the package fits into the envelope for envelope services or
 *   TRUE for non-envelope USPS rates.
 */
function _uc_usps_newapi_package_fits_envelope($package, $service_key) {
  $legal = (strpos($service_key, 'LFRE') !== FALSE);
  $regular = (strpos($service_key, 'FRE') !== FALSE) && !$legal;
  if ($regular) {
    if ($package->length <= 12.5 && $package->width <= 9.5 && $package->height <= 0.5) {
      return TRUE;
    }
    if ($package->length <= 13.5 && $package->width <= 8.5 && $package->height <= 0.625) {
      return TRUE;
    }
    return FALSE;
  }
  elseif ($legal) {
    if ($package->length <= 11.25 && $package->width <= 9.25 && $package->height <= 0.75) {
      return TRUE;
    }
    if ($package->length <= 12.5 && $package->width <= 8.5 && $package->height <= 1.0) {
      return TRUE;
    }
    return FALSE;
  }
  return TRUE;
}

