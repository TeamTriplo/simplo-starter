<?php
/**
 * @file
 * Tags outgoing SimpleNews emails with SendGrid categories and provides a
 * per-newsletter stats report pulled from the SendGrid Stats API.
 *
 * Category tagging is done via hook_sendgrid_integration_categories_alter(),
 * which sets categories directly in the SendGrid v3 API payload. This works
 * when email is sent via the sendgrid_integration module's HTTP API path.
 *
 * Each newsletter email is tagged with:
 *   - The newsletter category name (e.g. "Demo Newsletter")
 *   - The node title of the specific issue (e.g. "March 2026 Update")
 *
 * @see https://docs.sendgrid.com/for-developers/sending-email/categories
 * @see https://docs.sendgrid.com/api-reference/category-statistics/
 */

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------

/**
 * Implements hook_menu().
 */
function simplenews_sendgrid_menu() {
  $items['admin/config/services/simplenews/stats'] = array(
    'title'            => 'Newsletter stats',
    'description'      => 'Per-newsletter open and click statistics from SendGrid.',
    'page callback'    => 'simplenews_sendgrid_stats_page',
    'access arguments' => array('administer simplenews subscriptions'),
    'file'             => 'simplenews_sendgrid.pages.inc',
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 10,
  );
  $items['admin/config/services/simplenews/stats/refresh'] = array(
    'title'            => 'Refresh newsletter stats',
    'page callback'    => 'simplenews_sendgrid_stats_refresh',
    'access arguments' => array('administer simplenews subscriptions'),
    'file'             => 'simplenews_sendgrid.pages.inc',
    'type'             => MENU_CALLBACK,
  );
  return $items;
}

// ---------------------------------------------------------------------------
// SendGrid API category tagging
// ---------------------------------------------------------------------------

/**
 * Implements hook_sendgrid_integration_categories_alter().
 *
 * Sets the SendGrid categories on newsletter sends when the sendgrid_integration
 * module sends via the HTTP API. This is the correct integration point for
 * API-based sends; the X-SMTPAPI header approach only works over SMTP.
 *
 * Replaces the default [sitename, module, id] categories with:
 *   - The newsletter category name (e.g. "Demo Newsletter")
 *   - The node title of the specific issue (e.g. "March 2026 Update")
 */
function simplenews_sendgrid_sendgrid_integration_categories_alter($message, $categories) {
  if ($message['module'] !== 'simplenews' || $message['key'] !== 'node') {
    return $categories;
  }

  $source = isset($message['params']['simplenews_source'])
    ? $message['params']['simplenews_source']
    : NULL;

  if (!$source || !($source instanceof SimplenewsSourceInterface)) {
    return $categories;
  }

  $newsletter_categories = array();

  $category = $source->getCategory();
  if ($category && !empty($category->name)) {
    $newsletter_categories[] = _simplenews_sendgrid_clean_category($category->name);
  }

  $node = $source->getNode();
  if ($node && !empty($node->title)) {
    $newsletter_categories[] = _simplenews_sendgrid_clean_category($node->title);
  }

  if (empty($newsletter_categories)) {
    return $categories;
  }

  return array_slice(array_values(array_unique($newsletter_categories)), 0, 10);
}

// ---------------------------------------------------------------------------
// API helpers
// ---------------------------------------------------------------------------

/**
 * Fetches per-category stats from the SendGrid API.
 *
 * Uses a 365-day lookback window so all historical newsletter issues appear.
 * Results are stored in state for manual refresh on demand.
 *
 * @return array|false  Parsed stats array on success, FALSE on failure.
 */
function simplenews_sendgrid_fetch_stats() {
  $api_key = config_get('sendgrid_integration.settings', 'sendgrid_integration_apikey');
  if (empty($api_key)) {
    return FALSE;
  }

  $start_date = date('Y-m-d', strtotime('-365 days'));
  $end_date   = date('Y-m-d');

  $url = 'https://api.sendgrid.com/v3/categories/stats/sums'
    . '?start_date=' . $start_date
    . '&end_date=' . $end_date
    . '&sort_by_metric=delivered'
    . '&sort_by_direction=desc'
    . '&limit=50';

  $response = backdrop_http_request($url, array(
    'headers' => array(
      'Authorization' => 'Bearer ' . $api_key,
      'Content-Type'  => 'application/json',
    ),
    'timeout' => 15,
  ));

  watchdog('simplenews_sendgrid', 'SendGrid API request: @code — URL: @url',
    array('@code' => $response->code, '@url' => $url),
    WATCHDOG_DEBUG);

  if ($response->code != 200) {
    watchdog('simplenews_sendgrid', 'SendGrid API request failed: @code @error — Body: @body',
      array(
        '@code'  => $response->code,
        '@error' => isset($response->error) ? $response->error : '',
        '@body'  => isset($response->data) ? $response->data : '',
      ),
      WATCHDOG_ERROR);
    return FALSE;
  }

  watchdog('simplenews_sendgrid', 'SendGrid API raw response: @body',
    array('@body' => $response->data),
    WATCHDOG_DEBUG);

  $data = json_decode($response->data, TRUE);
  if (!is_array($data)) {
    watchdog('simplenews_sendgrid', 'SendGrid API response could not be decoded as JSON: @body',
      array('@body' => $response->data),
      WATCHDOG_ERROR);
    return FALSE;
  }

  watchdog('simplenews_sendgrid', 'SendGrid API returned @count items.',
    array('@count' => count($data)),
    WATCHDOG_INFO);

  return $data;
}

/**
 * Sanitises a string for use as a SendGrid category name.
 *
 * @param string $name
 * @return string
 */
function _simplenews_sendgrid_clean_category($name) {
  $name = trim((string) $name);
  if (backdrop_strlen($name) > 255) {
    $name = backdrop_substr($name, 0, 255);
  }
  return $name;
}
