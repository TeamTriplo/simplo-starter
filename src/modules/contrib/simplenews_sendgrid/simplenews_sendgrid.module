<?php
/**
 * @file
 * Tags outgoing SimpleNews emails with SendGrid X-SMTPAPI categories and
 * provides a per-newsletter stats report pulled from the SendGrid Stats API.
 *
 * Category tagging allows per-newsletter open and click stats to appear in
 * the SendGrid dashboard under Stats → Categories.
 *
 * Each newsletter email is tagged with:
 *   - The newsletter category name (e.g. "Demo Newsletter")
 *   - The node title of the specific issue (e.g. "March 2026 Update")
 *
 * @see https://docs.sendgrid.com/for-developers/sending-email/categories
 * @see https://docs.sendgrid.com/api-reference/category-statistics/
 */

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------

/**
 * Implements hook_menu().
 */
function simplenews_sendgrid_menu() {
  $items['admin/config/services/simplenews/stats'] = array(
    'title'            => 'Newsletter stats',
    'description'      => 'Per-newsletter open and click statistics from SendGrid.',
    'page callback'    => 'simplenews_sendgrid_stats_page',
    'access arguments' => array('administer simplenews'),
    'file'             => 'simplenews_sendgrid.pages.inc',
    'type'             => MENU_LOCAL_TASK,
    'weight'           => 10,
  );
  $items['admin/config/services/simplenews/stats/refresh'] = array(
    'title'            => 'Refresh newsletter stats',
    'page callback'    => 'simplenews_sendgrid_stats_refresh',
    'access arguments' => array('administer simplenews'),
    'file'             => 'simplenews_sendgrid.pages.inc',
    'type'             => MENU_CALLBACK,
  );
  return $items;
}

// ---------------------------------------------------------------------------
// Mail alter — inject X-SMTPAPI category header
// ---------------------------------------------------------------------------

/**
 * Implements hook_mail_alter().
 *
 * Injects the X-SMTPAPI header with category tags when the outgoing mail is
 * a SimpleNews newsletter send (key = 'node'). Subscription confirmation and
 * other SimpleNews transactional mails are left untagged.
 */
function simplenews_sendgrid_mail_alter(&$message) {
  if ($message['module'] !== 'simplenews' || $message['key'] !== 'node') {
    return;
  }

  $source = isset($message['params']['simplenews_source'])
    ? $message['params']['simplenews_source']
    : NULL;

  if (!$source || !($source instanceof SimplenewsSourceInterface)) {
    return;
  }

  $categories = array();

  $category = $source->getCategory();
  if ($category && !empty($category->name)) {
    $categories[] = _simplenews_sendgrid_clean_category($category->name);
  }

  $node = $source->getNode();
  if ($node && !empty($node->title)) {
    $categories[] = _simplenews_sendgrid_clean_category($node->title);
  }

  if (empty($categories)) {
    return;
  }

  $existing = isset($message['headers']['X-SMTPAPI'])
    ? json_decode($message['headers']['X-SMTPAPI'], TRUE)
    : array();

  $existing_categories = isset($existing['category']) ? $existing['category'] : array();
  $merged = array_values(array_unique(array_merge($existing_categories, $categories)));
  $merged = array_slice($merged, 0, 10);

  $existing['category'] = $merged;
  $message['headers']['X-SMTPAPI'] = json_encode($existing);
}

// ---------------------------------------------------------------------------
// API helpers
// ---------------------------------------------------------------------------

/**
 * Fetches per-category stats from the SendGrid API.
 *
 * Uses a 365-day lookback window so all historical newsletter issues appear.
 * Results are stored in state for manual refresh on demand.
 *
 * @return array|false  Parsed stats array on success, FALSE on failure.
 */
function simplenews_sendgrid_fetch_stats() {
  $api_key = config_get('sendgrid_integration.settings', 'sendgrid_integration_apikey');
  if (empty($api_key)) {
    return FALSE;
  }

  $start_date = date('Y-m-d', strtotime('-365 days'));
  $end_date   = date('Y-m-d');

  $url = 'https://api.sendgrid.com/v3/categories/stats/sums'
    . '?start_date=' . $start_date
    . '&end_date=' . $end_date
    . '&sort_by_metric=delivered'
    . '&sort_by_direction=desc'
    . '&limit=50';

  $response = backdrop_http_request($url, array(
    'headers' => array(
      'Authorization' => 'Bearer ' . $api_key,
      'Content-Type'  => 'application/json',
    ),
    'timeout' => 15,
  ));

  if ($response->code != 200) {
    watchdog('simplenews_sendgrid', 'SendGrid API request failed: @code @error',
      array('@code' => $response->code, '@error' => isset($response->error) ? $response->error : ''),
      WATCHDOG_ERROR);
    return FALSE;
  }

  $data = json_decode($response->data, TRUE);
  if (!is_array($data)) {
    return FALSE;
  }

  return $data;
}

/**
 * Sanitises a string for use as a SendGrid category name.
 *
 * @param string $name
 * @return string
 */
function _simplenews_sendgrid_clean_category($name) {
  $name = trim((string) $name);
  if (backdrop_strlen($name) > 255) {
    $name = backdrop_substr($name, 0, 255);
  }
  return $name;
}
