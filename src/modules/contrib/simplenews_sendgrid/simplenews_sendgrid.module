<?php
/**
 * @file
 * Tags outgoing SimpleNews emails with SendGrid X-SMTPAPI categories.
 *
 * This allows per-newsletter open and click stats to appear in the SendGrid
 * dashboard under Stats → Categories, rather than being invisible in the
 * aggregate transactional stream.
 *
 * Each newsletter email is tagged with:
 *   - The newsletter category name (e.g. "Demo Newsletter")
 *   - The node title of the specific issue (e.g. "March 2026 Update")
 *
 * SendGrid category names are capped at 255 characters and the API allows
 * a maximum of 10 categories per message.
 *
 * @see https://docs.sendgrid.com/for-developers/sending-email/categories
 */

/**
 * Implements hook_mail_alter().
 *
 * Injects the X-SMTPAPI header with category tags when the outgoing mail is
 * a SimpleNews newsletter send (key = 'node'). Subscription confirmation and
 * other SimpleNews transactional mails are left untagged.
 */
function simplenews_sendgrid_mail_alter(&$message) {
  // Only act on SimpleNews newsletter sends, not subscription confirmations.
  if ($message['module'] !== 'simplenews' || $message['key'] !== 'node') {
    return;
  }

  $source = isset($message['params']['simplenews_source'])
    ? $message['params']['simplenews_source']
    : NULL;

  if (!$source || !($source instanceof SimplenewsSourceInterface)) {
    return;
  }

  $categories = array();

  // Tag with the newsletter category name (e.g. "Demo Newsletter").
  $category = $source->getCategory();
  if ($category && !empty($category->name)) {
    $categories[] = _simplenews_sendgrid_clean_category($category->name);
  }

  // Tag with the individual issue title (e.g. "March 2026 Update").
  $node = $source->getNode();
  if ($node && !empty($node->title)) {
    $categories[] = _simplenews_sendgrid_clean_category($node->title);
  }

  if (empty($categories)) {
    return;
  }

  // Merge with any existing X-SMTPAPI header (e.g. set by another module).
  $existing = isset($message['headers']['X-SMTPAPI'])
    ? json_decode($message['headers']['X-SMTPAPI'], TRUE)
    : array();

  $existing_categories = isset($existing['category']) ? $existing['category'] : array();
  $merged = array_values(array_unique(array_merge($existing_categories, $categories)));

  // SendGrid enforces a maximum of 10 categories per message.
  $merged = array_slice($merged, 0, 10);

  $existing['category'] = $merged;
  $message['headers']['X-SMTPAPI'] = json_encode($existing);
}

/**
 * Sanitises a string for use as a SendGrid category name.
 *
 * SendGrid categories must be strings, max 255 characters.
 * We strip leading/trailing whitespace and truncate if necessary.
 *
 * @param string $name
 * @return string
 */
function _simplenews_sendgrid_clean_category($name) {
  $name = trim((string) $name);
  if (backdrop_strlen($name) > 255) {
    $name = backdrop_substr($name, 0, 255);
  }
  return $name;
}
