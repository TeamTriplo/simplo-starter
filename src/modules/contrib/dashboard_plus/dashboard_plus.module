/**
 * Implements hook_init().
 * Attach dashboard assets on admin dashboard pages.
 */
function dashboard_plus_init() {
  if (strpos(current_path(), 'admin/dashboard') === 0) {
    $module_path = backdrop_get_path('module', 'dashboard_plus');
    $config = config('dashboard_plus.settings');
    if ($config->get('collapsible_blocks') !== NULL ? $config->get('collapsible_blocks') : TRUE) {
      backdrop_add_js($module_path . '/js/dashboard-block-toggle.js');
      backdrop_add_css($module_path . '/css/dashboard-block-toggle.css');
    }
    // Contextual remove buttons and reorganize UI for layout admins.
    if (current_path() === 'admin/dashboard' && user_access('administer layouts')) {
      backdrop_add_css($module_path . '/css/remove-block.css');
      backdrop_add_js($module_path . '/js/remove-block.js');
      _dashboard_plus_init_reorganize($module_path);
    }
  }
}

/**
 * Loads reorganize assets and passes layout data to JS.
 */
function _dashboard_plus_init_reorganize($module_path) {
  $layouts = layout_load_multiple_by_path('admin/dashboard');
  $layout = reset($layouts);
  if (!$layout) {
    return;
  }

  $known_labels = _dashboard_plus_region_label_map();
  $skip = array('title');

  // Regions that should always span the full modal width — they sit alone in
  // their row, the same way they appear as full-width bands on the dashboard.
  $full_width = array('header', 'top', 'content', 'bottom', 'footer');

  $regions = array();
  foreach ($layout->positions as $region_key => $uuids) {
    if (in_array($region_key, $skip)) {
      continue;
    }
    $label = isset($known_labels[$region_key])
      ? $known_labels[$region_key]
      : ucwords(str_replace('_', ' ', $region_key));

    $blocks = array();
    foreach ($uuids as $uuid) {
      if (!isset($layout->content[$uuid])) {
        continue;
      }
      $block = $layout->content[$uuid];
      $info = layout_get_block_info($block->module, $block->delta);
      $blocks[] = array(
        'uuid'  => $uuid,
        'label' => is_array($info) && isset($info['info']) ? $info['info'] : $block->delta,
      );
    }
    $regions[$region_key] = array(
      'label'      => $label,
      'blocks'     => $blocks,
      'full_width' => in_array($region_key, $full_width),
    );
  }

  backdrop_add_js(array(
    'dashboardPlus' => array(
      'reorganize' => array(
        'regions'  => $regions,
        'token'    => backdrop_get_token('dashboard-plus-reorder'),
        'saveUrl'  => url('dashboard-plus/reorder-blocks'),
      ),
    ),
  ), 'setting');

  backdrop_add_library('system', 'ui.sortable');
  backdrop_add_library('system', 'ui.dialog');
  backdrop_add_css($module_path . '/css/reorganize.css');
  backdrop_add_js($module_path . '/js/reorganize.js');
}

/**
 * Returns a map of region machine names to human-readable labels.
 */
function _dashboard_plus_region_label_map() {
  return array(
    'header'          => t('Header'),
    'footer'          => t('Footer'),
    'top'             => t('Top — full width'),
    'bottom'          => t('Bottom — full width'),
    'content'         => t('Main content'),
    'sidebar_first'   => t('Left sidebar'),
    'sidebar_second'  => t('Right sidebar'),
    'half1'           => t('Left column'),
    'half2'           => t('Right column'),
    'third1'          => t('First third'),
    'third2'          => t('Second third'),
    'third3'          => t('Third third'),
    'quarter1'        => t('First quarter'),
    'quarter2'        => t('Second quarter'),
    'quarter3'        => t('Third quarter'),
    'quarter4'        => t('Fourth quarter'),
    'left'            => t('Left'),
    'right'           => t('Right'),
    'center'          => t('Center'),
  );
}

/**
 * Implements hook_form_FORM_ID_alter().
 * Add collapsible dashboard blocks setting to dashboard settings form.
 */
function dashboard_plus_form_dashboard_admin_settings_alter(&$form, &$form_state, $form_id) {
  $config = config('dashboard_plus.settings');
  $form['dashboard_plus_collapsible_blocks'] = array(
    '#type' => 'checkbox',
    '#title' => t('Enable collapsible dashboard blocks'),
    '#default_value' => $config->get('collapsible_blocks') !== NULL ? $config->get('collapsible_blocks') : TRUE,
    '#description' => t('Allow dashboard blocks to be collapsed and expanded. State is remembered per user.'),
  );
  $form['#submit'][] = 'dashboard_plus_dashboard_settings_submit';
}

/**
 * Submit handler for dashboard settings form.
 */
function dashboard_plus_dashboard_settings_submit($form, &$form_state) {
  $config = config('dashboard_plus.settings');
  $config->set('collapsible_blocks', !empty($form_state['values']['dashboard_plus_collapsible_blocks']));
  $config->save();
}

/**
 * Implements hook_block_view_alter().
 *
 * Injects a contextual × remove button into each block on the main dashboard
 * overview for people who can administer layouts.
 */
function dashboard_plus_block_view_alter(&$data, $block) {
  // Only on the main dashboard overview tab, not sub-pages like /architecture.
  if (current_path() !== 'admin/dashboard') {
    return;
  }
  if (!user_access('administer layouts')) {
    return;
  }
  // The block must have a UUID (i.e. be a layout-placed block).
  if (empty($block->uuid)) {
    return;
  }

  $token = backdrop_get_token('dashboard-plus-remove-' . $block->uuid);
  $remove_url = url('dashboard-plus/remove-block/' . $block->uuid, array(
    'query' => array('token' => $token),
  ));

  // A hidden span carries the remove URL for JS to pick up. JS will inject
  // "Remove from dashboard" into the contextual links menu if one exists,
  // or leave the fallback × button visible if there is no contextual menu.
  $trigger = '<span class="dashboard-plus-remove-trigger" aria-hidden="true"'
    . ' data-remove-url="' . check_plain($remove_url) . '"></span>';

  // Fallback × button for blocks without a contextual links menu.
  $fallback = l('&times;', 'dashboard-plus/remove-block/' . $block->uuid, array(
    'html' => TRUE,
    'query' => array('token' => $token),
    'attributes' => array(
      'class' => array('dashboard-plus-remove-block'),
      'title' => t('Remove from dashboard'),
      'aria-label' => t('Remove this block from the dashboard'),
    ),
  ));

  $inject = $trigger . $fallback;

  if (is_array($data['content'])) {
    $existing = isset($data['content']['#prefix']) ? $data['content']['#prefix'] : '';
    $data['content']['#prefix'] = $inject . $existing;
  }
  else {
    $data['content'] = $inject . (string) $data['content'];
  }
}
