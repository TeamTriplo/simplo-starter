<?php

/**
 * Implements hook_permission().
 */
function dashboard_plus_permission() {
  return array(
    'view architecture report' => array(
      'title' => t('View architecture report'),
      'description' => t('Access the Architecture tab on the dashboard and the site architecture report.'),
      'restrict access' => TRUE,
    ),
  );
}

/**
 * Implements hook_menu().
 */
function dashboard_plus_menu() {
  $items['admin/dashboard/architecture'] = array(
    'title' => 'Architecture',
    'page callback' => 'backdrop_get_form',
    'page arguments' => array('dashboard_plus_architecture_form'),
    'access arguments' => array('view architecture report'),
    'type' => MENU_LOCAL_TASK,
    'file' => 'includes/architecture.inc',
    'weight' => -50,
  );
  $items['admin/reports/site-architect'] = array(
    'title' => 'Site architecture',
    'page callback' => 'backdrop_get_form',
    'page arguments' => array('dashboard_plus_architecture_form'),
    'access arguments' => array('view architecture report'),
    'type' => MENU_NORMAL_ITEM,
    'file' => 'includes/architecture.inc',
  );
  $items['dashboard-plus/motd-next'] = array(
    'page callback' => 'dashboard_plus_motd_next',
    'access callback' => 'user_access',
    'access arguments' => array('access administration pages'),
    'type' => MENU_CALLBACK,
  );
  $items['dashboard-plus/remove-block/%'] = array(
    'page callback' => 'dashboard_plus_remove_dashboard_block',
    'page arguments' => array(2),
    'access arguments' => array('administer layouts'),
    'type' => MENU_CALLBACK,
  );
  $items['dashboard-plus/reorder-blocks'] = array(
    'page callback' => 'dashboard_plus_reorder_blocks',
    'access arguments' => array('administer layouts'),
    'type' => MENU_CALLBACK,
  );
  $items['dashboard-plus/quick-link/%/remove/%'] = array(
    'page callback'   => 'dashboard_plus_quick_link_remove',
    'page arguments'  => array(2, 4),
    'access arguments' => array('administer layouts'),
    'type'            => MENU_CALLBACK,
  );
  return $items;
}

/**
 * Page callback: Save reordered block positions for the dashboard layout.
 *
 * Accepts a POST with 'token' and 'positions' (JSON-encoded region => [uuid]).
 */
function dashboard_plus_reorder_blocks() {
  if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    backdrop_json_output(array('success' => FALSE, 'message' => 'Invalid request method.'));
    return;
  }

  $token = isset($_POST['token']) ? $_POST['token'] : '';
  if (!backdrop_valid_token($token, 'dashboard-plus-reorder')) {
    backdrop_json_output(array('success' => FALSE, 'message' => 'Invalid token.'));
    return;
  }

  $new_positions = isset($_POST['positions']) ? json_decode($_POST['positions'], TRUE) : NULL;
  if (!is_array($new_positions)) {
    backdrop_json_output(array('success' => FALSE, 'message' => 'Invalid positions data.'));
    return;
  }

  $layouts = layout_load_multiple_by_path('admin/dashboard');
  $layout = reset($layouts);
  if (!$layout) {
    backdrop_json_output(array('success' => FALSE, 'message' => 'Dashboard layout not found.'));
    return;
  }

  // Validate every submitted UUID belongs to this layout.
  $valid_uuids = array_keys($layout->content);
  foreach ($new_positions as $region => $uuids) {
    foreach ((array) $uuids as $uuid) {
      if (!in_array($uuid, $valid_uuids)) {
        backdrop_json_output(array('success' => FALSE, 'message' => 'Unknown block UUID.'));
        return;
      }
    }
  }

  // Apply new positions for each submitted region.
  foreach ($new_positions as $region => $uuids) {
    if (array_key_exists($region, $layout->positions)) {
      $layout->positions[$region] = array_values((array) $uuids);
    }
  }

  $layout->save();
  backdrop_json_output(array('success' => TRUE));
}

/**
 * Page callback: Remove a block from the dashboard layout.
 *
 * Expects a valid CSRF token in $_GET['token'].
 */
function dashboard_plus_remove_dashboard_block($uuid) {
  if (empty($_GET['token']) || !backdrop_valid_token($_GET['token'], 'dashboard-plus-remove-' . $uuid)) {
    backdrop_set_message(t('Invalid or expired token. Block was not removed.'), 'error');
    backdrop_goto('admin/dashboard');
    return;
  }

  $layouts = layout_load_multiple_by_path('admin/dashboard');
  $layout = reset($layouts);

  if (!$layout || !isset($layout->content[$uuid])) {
    backdrop_set_message(t('Block not found in the dashboard layout.'), 'error');
    backdrop_goto('admin/dashboard');
    return;
  }

  $block = $layout->content[$uuid];
  $block_info = layout_get_block_info($block->module, $block->delta);
  $label = is_array($block_info) && isset($block_info['info']) ? $block_info['info'] : $block->delta;

  $layout->removeBlock($uuid);
  $layout->save();

  backdrop_set_message(t('!block has been removed from the dashboard.', array(
    '!block' => check_plain($label),
  )));
  backdrop_goto('admin/dashboard');
}

/**
 * Page callback: remove a single quick link from a Quick Links block.
 */
function dashboard_plus_quick_link_remove($uuid, $link_id) {
  $token = isset($_GET['token']) ? $_GET['token'] : '';
  if (!backdrop_valid_token($token, 'dashboard-plus-ql-remove-' . $uuid . '-' . $link_id)) {
    backdrop_set_message(t('Invalid or expired token. Link was not removed.'), 'error');
    backdrop_goto('admin/dashboard');
    return;
  }

  $layouts = layout_load_multiple_by_path('admin/dashboard');
  $layout  = reset($layouts);

  if (!$layout || !isset($layout->content[$uuid])) {
    backdrop_set_message(t('Block not found.'), 'error');
    backdrop_goto('admin/dashboard');
    return;
  }

  $block = $layout->content[$uuid];
  $links = isset($block->settings['links']) ? $block->settings['links'] : array();
  $links = array_values(array_filter($links, function ($link) use ($link_id) {
    return $link['id'] !== $link_id;
  }));
  $block->settings['links'] = $links;
  $layout->save();

  backdrop_set_message(t('Link removed.'));
  backdrop_goto('admin/dashboard');
}

/**
 * AJAX callback: increments the module-of-day skip counter and returns new HTML.
 */
function dashboard_plus_motd_next() {
  $today = date('Y-m-d');

  // Initialise and clean up the session skip counter.
  if (!isset($_SESSION['dashboard_plus_motd_skip'])) {
    $_SESSION['dashboard_plus_motd_skip'] = array();
  }
  // Remove stale dates so the session doesn't grow indefinitely.
  foreach (array_keys($_SESSION['dashboard_plus_motd_skip']) as $date) {
    if ($date !== $today) {
      unset($_SESSION['dashboard_plus_motd_skip'][$date]);
    }
  }
  if (!isset($_SESSION['dashboard_plus_motd_skip'][$today])) {
    $_SESSION['dashboard_plus_motd_skip'][$today] = 0;
  }
  $_SESSION['dashboard_plus_motd_skip'][$today]++;

  $block = new DashboardModuleOfDayBlock('dashboard_plus:module_of_day', array());
  backdrop_json_output(array('html' => $block->renderModuleHtml()));
}

